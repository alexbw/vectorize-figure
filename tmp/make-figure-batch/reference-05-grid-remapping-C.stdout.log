+    {"id": "shared-y-domain", "type": "sameDomain", "targets": ["env-a.plot.y", "env-b.plot.y"]},
+    {"id": "colorbar-scale-link", "type": "referencesColorScale", "source": "colorbar", "target": "norm-counts"},
