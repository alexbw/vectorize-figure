+      const right = ys.map((y) => [category.x + densityAt(dist, y) / maxDensity * dist.violin.maxHalfWidth, yScale(plot, y)]);
+      const left = ys.slice().reverse().map((y) => [category.x - densityAt(dist, y) / maxDensity * dist.violin.maxHalfWidth, yScale(plot, y)]);
+      return right.concat(left).map((pt, i) => `${i ? "L" : "M"} ${pt[0].toFixed(2)} ${pt[1].toFixed(2)}`).join(" ") + " Z";
+    }
+    function text(svg, obj) {
+      const node = make("text", {
+        x: obj.x, y: obj.y, fill: obj.fill || "#111111", "font-size": obj.fontSize,
+        "font-weight": obj.fontWeight || 400, "font-style": obj.fontStyle || "normal",
+        "text-anchor": obj.anchor || "start", "dominant-baseline": obj.baseline || "alphabetic",
+        transform: obj.rotation ? `rotate(${obj.rotation} ${obj.x} ${obj.y})` : null
+      });
+      node.textContent = obj.text;
+      svg.appendChild(node);
+      return node;
+    }
+    function render(spec) {
+      $("title").textContent = spec.id;
+      const frame = $("frame");
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      $("reference").src = spec.source.path;
+      const surface = $("surface");
+      surface.innerHTML = "";
+      const canvas = document.createElement("canvas");
+      canvas.width = spec.canvas.width;
+      canvas.height = spec.canvas.height;
+      surface.appendChild(canvas);
+      const ctx = canvas.getContext("2d");
+      const svg = make("svg", {width: spec.canvas.width, height: spec.canvas.height, viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`});
+      svg.style.fontFamily = spec.typography.fontFamily;
+      surface.appendChild(svg);
+      const panel = spec.panels[0];
+      const plot = panel.plot;
+
+      text(svg, panel.label);
+      text(svg, panel.title);
+
+      const yAxis = make("line", {x1: plot.axisBbox.x, y1: plot.axisBbox.y, x2: plot.axisBbox.x, y2: plot.axisBbox.y + plot.axisBbox.height, stroke: "#111111", "stroke-width": 1.4});
+      svg.appendChild(yAxis);
+      for (const tick of plot.y.ticks) {
+        const y = yScale(plot, tick.value);
+        svg.appendChild(make("line", {x1: plot.axisBbox.x - 6, y1: y, x2: plot.axisBbox.x, y2: y, stroke: "#111111", "stroke-width": 1.2, "data-axis": "y", "data-value": tick.value}));
+        text(svg, {text: tick.label, x: plot.axisBbox.x - 14, y: y + 5, fontSize: 18, anchor: "end"});
+      }
+      text(svg, {...plot.y.label, fontSize: 20, anchor: "middle"});
+
+      const zero = panel.marks.find((m) => m.id === "zero-line");
+      svg.appendChild(make("line", {x1: zero.x1, y1: yScale(plot, zero.value), x2: zero.x2, y2: yScale(plot, zero.value), stroke: zero.stroke, "stroke-width": zero.strokeWidth, "stroke-dasharray": zero.dasharray}));
+
+      for (const mark of panel.marks.filter((m) => m.type === "violin")) {
+        const dist = distFor(panel, mark.distribution);
+        svg.appendChild(make("path", {d: violinPath(panel, plot, dist), fill: dist.violin.fill, "fill-opacity": dist.violin.fillOpacity, stroke: dist.violin.stroke, "stroke-width": dist.violin.strokeWidth, "data-mark-id": mark.id}));
+      }
+
+      for (const mark of panel.marks.filter((m) => m.type === "scatter")) {
+        const dist = distFor(panel, mark.distribution);
+        const category = catFor(panel, dist.category);
+        const rand = mulberry32(dist.seed + 99);
+        ctx.fillStyle = mark.fill;
+        ctx.globalAlpha = mark.opacity;
+        for (const value of generateValues(dist)) {
+          const x = category.x + (rand() * 2 - 1) * mark.jitterHalfWidth * Math.pow(rand(), 0.55);
+          const y = yScale(plot, value);
+          ctx.beginPath();
+          ctx.arc(x, y, mark.radius, 0, Math.PI * 2);
+          ctx.fill();
+        }
+        ctx.globalAlpha = 1;
+      }
+
+      const summary = panel.marks.find((m) => m.type === "summaryOverlay");
+      for (const distId of summary.distributions) {
+        const dist = distFor(panel, distId);
+        const category = catFor(panel, dist.category);
+        svg.appendChild(make("line", {x1: category.x, y1: yScale(plot, dist.iqr[0]), x2: category.x, y2: yScale(plot, dist.iqr[1]), stroke: summary.iqrLine.stroke, "stroke-width": summary.iqrLine.strokeWidth}));
+        svg.appendChild(make("line", {x1: category.x - summary.categoryBarHalfWidth, y1: yScale(plot, 0), x2: category.x + summary.categoryBarHalfWidth, y2: yScale(plot, 0), stroke: "#111111", "stroke-width": 1.2}));
