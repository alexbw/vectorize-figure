+      const yAxis = make("line", {x1: plot.axisBbox.x, y1: plot.axisBbox.y, x2: plot.axisBbox.x, y2: plot.axisBbox.y + plot.axisBbox.height, stroke: "#111111", "stroke-width": 1.4});
+      svg.appendChild(yAxis);
+      for (const tick of plot.y.ticks) {
