+      svg.appendChild(make("line", {x1: zero.x1, y1: yScale(plot, zero.value), x2: zero.x2, y2: yScale(plot, zero.value), stroke: zero.stroke, "stroke-width": zero.strokeWidth, "stroke-dasharray": zero.dasharray}));
+
+      for (const mark of panel.marks.filter((m) => m.type === "violin")) {
+        const dist = distFor(panel, mark.distribution);
+        svg.appendChild(make("path", {d: violinPath(panel, plot, dist), fill: dist.violin.fill, "fill-opacity": dist.violin.fillOpacity, stroke: dist.violin.stroke, "stroke-width": dist.violin.strokeWidth, "data-mark-id": mark.id}));
