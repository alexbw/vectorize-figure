+      sup.textContent = "-5";
+      p.appendChild(sup);
+      svg.appendChild(p);
+
+      for (const ann of panel.annotations.filter((a) => a.type !== "bracket")) text(svg, ann);
+    }
+    async function init() {
+      const response = await fetch(JSON_PATH);
+      render(await response.json());
