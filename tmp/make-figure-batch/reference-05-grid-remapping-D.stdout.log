+        svg.appendChild(make("line", {x1: plot.axisBbox.x - 6, y1: y, x2: plot.axisBbox.x, y2: y, stroke: "#111111", "stroke-width": 1.2, "data-axis": "y", "data-value": tick.value}));
+        text(svg, {text: tick.label, x: plot.axisBbox.x - 14, y: y + 5, fontSize: 18, anchor: "end"});
+      }
