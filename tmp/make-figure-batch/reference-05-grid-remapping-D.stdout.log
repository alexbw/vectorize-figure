+      }
+
+      const bracket = panel.annotations.find((a) => a.type === "bracket");
+      svg.appendChild(make("line", {x1: bracket.x1, y1: bracket.y, x2: bracket.x2, y2: bracket.y, stroke: bracket.stroke, "stroke-width": bracket.strokeWidth}));
