+          'data-axis': 'x',
+          'data-value': tick.value
+        }, tick.label);
+      }
+
+      const categoryLabelAnnotation = panel.annotations.find(annotation => annotation.id === 'y-category-labels');
+      for (const category of coord.y.categories) {
+        const lines = category.labelLines;
+        const firstY = category.y - (lines.length - 1) * categoryLabelAnnotation.lineHeight / 2 + 6;
+        for (let i = 0; i < lines.length; i += 1) {
