+      const colorScales = Object.fromEntries((spec.coordinateSystems || []).filter((system) => system.type === 'linearColor').map((system) => [system.id, system]));
+      spec.panels.forEach((panel) => {
+        addText(svg, panel.label, typography);
+        addText(svg, panel.title, typography);
+        renderAxes(svg, panel, typography);
