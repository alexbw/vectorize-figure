+        if (!response.ok) throw new Error(`HTTP ${response.status}`);
+        return await response.json();
+      } catch (error) {
+        const fallback = JSON.parse($('fallback-spec').textContent);
+        if (!fallback || !fallback.schema) throw error;
+        return fallback;
+      }
+    }
