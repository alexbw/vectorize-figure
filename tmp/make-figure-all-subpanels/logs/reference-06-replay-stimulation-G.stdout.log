+      margin-top: 3px;
+      font-size: 12px;
+      color: #555555;
+    }
+    .toggle {
+      display: inline-flex;
+      border: 1px solid #999999;
+      border-radius: 4px;
+      overflow: hidden;
+      flex: 0 0 auto;
+    }
+    .toggle button {
+      border: 0;
+      padding: 5px 10px;
+      background: #ffffff;
+      color: #111111;
+      font: inherit;
+      font-size: 12px;
+      cursor: pointer;
+    }
+    .toggle button.active {
+      background: #111111;
+      color: #ffffff;
+    }
+    main {
+      min-height: calc(100vh - 50px);
+      display: grid;
+      place-items: center;
+      padding: 16px;
+      box-sizing: border-box;
+    }
+    .frame {
+      position: relative;
+      background: #ffffff;
+      border: 1px solid #d0d0d0;
+      box-shadow: 0 1px 5px rgba(0, 0, 0, 0.08);
+      overflow: hidden;
+    }
+    .surface, .reference-wrap {
+      position: absolute;
+      inset: 0;
+    }
+    .reference-wrap {
+      display: none;
+      background: #ffffff;
+    }
+    .reference-wrap img {
+      width: 100%;
+      height: 100%;
+      object-fit: contain;
+      display: block;
+    }
+    .reference-label {
+      position: absolute;
+      left: 8px;
+      bottom: 8px;
+      padding: 3px 6px;
+      background: rgba(255, 255, 255, 0.92);
+      border: 1px solid #999999;
+      font-size: 11px;
+      font-weight: 700;
+    }
+    .show-reference .surface {
+      display: none;
+    }
+    .show-reference .reference-wrap {
+      display: block;
+    }
+    svg {
+      position: absolute;
+      inset: 0;
+      overflow: visible;
+    }
+  </style>
+</head>
+<body>
+  <header>
+    <div>
+      <h1 id="title">reference-06-replay-stimulation-G</h1>
+      <div class="note">Generated candidate is rendered from JSON. Source image is QA-only.</div>
+    </div>
+    <div class="toggle" aria-label="View mode">
+      <button id="generatedButton" class="active" type="button">Generated</button>
+      <button id="referenceButton" type="button">Reference</button>
+    </div>
+  </header>
+
+  <main>
+    <div id="frame" class="frame">
+      <div id="surface" class="surface"></div>
+      <div class="reference-wrap" aria-label="QA reference only">
+        <img id="reference" alt="QA reference source image">
+        <div class="reference-label">QA reference only</div>
+      </div>
+    </div>
+  </main>
+
+  <script id="fallback-spec" type="application/json">{}</script>
+  <script>
+    const SVG_NS = 'http://www.w3.org/2000/svg';
+
+    function make(tag, attrs = {}) {
+      const node = document.createElementNS(SVG_NS, tag);
+      for (const [key, value] of Object.entries(attrs)) {
+        if (value !== undefined && value !== null) node.setAttribute(key, value);
+      }
+      return node;
+    }
+
+    function linear(domain, range, value) {
+      return range[0] + ((value - domain[0]) / (domain[1] - domain[0])) * (range[1] - range[0]);
+    }
+
+    function findSystem(spec, id) {
+      for (const panel of spec.panels) {
+        const system = (panel.coordinateSystems || []).find(item => item.id === id);
+        if (system) return system;
+      }
+      throw new Error(`Unknown coordinate system: ${id}`);
+    }
+
+    function projector(system) {
+      const box = system.plotBox;
+      return {
+        x: value => linear(system.xDomain, [box.x, box.x + box.width], value),
+        y: value => linear(system.yDomain, [box.y + box.height, box.y], value)
+      };
+    }
+
+    function appendText(svg, textSpec, typography, defaults = {}) {
+      const lines = String(textSpec.text || '').split('\n');
+      const fontSize = textSpec.fontSize || defaults.fontSize || typography.defaultSize;
+      const lineHeight = textSpec.lineHeight || defaults.lineHeight || typography.calibration.lineHeight || 1.1;
+      const text = make('text', {
+        x: textSpec.x,
+        y: textSpec.y,
+        fill: textSpec.fill || defaults.fill || typography.color,
+        'font-family': textSpec.fontFamily || typography.fontFamily,
+        'font-size': fontSize,
+        'font-weight': textSpec.fontWeight || defaults.fontWeight || 400,
+        'letter-spacing': typography.calibration.letterSpacing || 0,
+        'text-anchor': textSpec.anchor || defaults.anchor || 'start',
+        'dominant-baseline': textSpec.baseline || 'alphabetic',
+        transform: textSpec.rotation ? `rotate(${textSpec.rotation} ${textSpec.x} ${textSpec.y})` : undefined,
+        'data-object-id': textSpec.id
+      });
+      lines.forEach((line, index) => {
+        const tspan = make('tspan', {x: textSpec.x, dy: index === 0 ? 0 : fontSize * lineHeight});
+        tspan.textContent = line;
+        text.appendChild(tspan);
+      });
+      svg.appendChild(text);
+      return text;
+    }
+
+    function renderAxes(svg, plot, typography, tokens) {
+      const box = plot.plotBox;
+      const stroke = tokens.axisStroke || '#111111';
+      const axisWidth = tokens.axisWidth || 1;
+      const tickLength = tokens.tickLength || 5;
+      const tickFontSize = tokens.tickFontSize || 14;
+
+      svg.appendChild(make('line', {x1: box.x, y1: box.y, x2: box.x, y2: box.y + box.height, stroke, 'stroke-width': axisWidth, 'data-object-id': 'y-axis-line'}));
+      svg.appendChild(make('line', {x1: box.x, y1: box.y + box.height, x2: box.x + box.width, y2: box.y + box.height, stroke, 'stroke-width': axisWidth, 'data-object-id': 'x-axis-line'}));
+
+      for (const tick of plot.x.ticks) {
+        const x = linear(plot.x.domain, [box.x, box.x + box.width], tick.value);
+        const y = box.y + box.height;
+        svg.appendChild(make('line', {x1: x, y1: y, x2: x, y2: y + tickLength, stroke, 'stroke-width': axisWidth, 'data-axis': 'x', 'data-value': tick.value}));
+        appendText(svg, {text: tick.label, x, y: y + 28, fontSize: tickFontSize, anchor: 'middle'}, typography);
+      }
+
+      for (const tick of plot.y.ticks) {
+        const x = box.x;
+        const y = linear(plot.y.domain, [box.y + box.height, box.y], tick.value);
+        svg.appendChild(make('line', {x1: x - tickLength, y1: y, x2: x, y2: y, stroke, 'stroke-width': axisWidth, 'data-axis': 'y', 'data-value': tick.value}));
+        appendText(svg, {text: tick.label, x: x - 8, y: y + 5, fontSize: tickFontSize, anchor: 'end'}, typography);
+      }
+
+      appendText(svg, plot.x.label, typography);
+      appendText(svg, plot.y.label, typography);
+    }
+
+    function renderReferenceLine(svg, mark, system) {
+      const project = projector(system);
+      if (mark.orientation === 'vertical') {
+        const x = project.x(mark.value);
+        svg.appendChild(make('line', {
+          x1: x,
+          y1: project.y(mark.yRange[0]),
+          x2: x,
+          y2: project.y(mark.yRange[1]),
+          stroke: mark.stroke,
+          'stroke-width': mark.strokeWidth,
+          'stroke-dasharray': mark.strokeDasharray,
+          'data-object-id': mark.id
+        }));
+      }
+    }
+
+    function pathFromPoints(points, project) {
+      return points.map((point, index) => `${index === 0 ? 'M' : 'L'} ${project.x(point[0]).toFixed(2)} ${project.y(point[1]).toFixed(2)}`).join(' ');
+    }
+
+    function renderLineSeries(svg, mark, system) {
+      const project = projector(system);
+      svg.appendChild(make('path', {
+        d: pathFromPoints(mark.points, project),
+        fill: mark.fill || 'none',
+        stroke: mark.stroke,
+        'stroke-width': mark.strokeWidth,
+        'stroke-linecap': 'round',
+        'stroke-linejoin': 'round',
+        'data-object-id': mark.id,
+        'data-mark-type': mark.type
+      }));
+    }
+
+    function renderLegendItem(svg, item, typography) {
+      svg.appendChild(make('line', {
+        x1: item.line.x1,
+        y1: item.line.y1,
+        x2: item.line.x2,
+        y2: item.line.y2,
+        stroke: item.line.stroke,
+        'stroke-width': item.line.strokeWidth,
+        'data-object-id': `${item.id}-swatch`
+      }));
+      appendText(svg, item.label, typography);
+    }
+
+    function render(spec) {
+      document.title = `${spec.id} reconstruction`;
+      document.getElementById('title').textContent = spec.id;
+      const frame = document.getElementById('frame');
+      const surface = document.getElementById('surface');
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      surface.replaceChildren();
+
+      const svg = make('svg', {
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`,
+        role: 'img',
+        'aria-label': `${spec.id} generated reconstruction`
+      });
+      svg.appendChild(make('rect', {x: 0, y: 0, width: spec.canvas.width, height: spec.canvas.height, fill: spec.canvas.background}));
+      surface.appendChild(svg);
+
+      const panel = spec.panels[0];
+      appendText(svg, panel.label, spec.typography);
+      appendText(svg, panel.title, spec.typography);
+
+      const plot = panel.plots[0];
+      const system = findSystem(spec, 'rho-cdf.xy');
+      renderAxes(svg, plot, spec.typography, spec.rendering.styleTokens);
+
+      for (const mark of panel.marks) {
+        const markSystem = findSystem(spec, mark.usesTransform);
+        if (mark.type === 'referenceLine') renderReferenceLine(svg, mark, markSystem);
+        if (mark.type === 'lineSeries') renderLineSeries(svg, mark, markSystem);
+      }
+
+      for (const annotation of panel.annotations) {
+        if (annotation.type === 'legendItem') renderLegendItem(svg, annotation, spec.typography);
+        if (annotation.type === 'text') appendText(svg, annotation, spec.typography);
+      }
+
+      const reference = document.getElementById('reference');
+      reference.src = spec.source.path;
+    }
+
+    async function loadSpec() {
+      try {
+        const response = await fetch('./reference-06-replay-stimulation-G.json', {cache: 'no-store'});
+        if (!response.ok) throw new Error(`HTTP ${response.status}`);
+        return response.json();
+      } catch (error) {
+        const fallback = document.getElementById('fallback-spec').textContent.trim();
+        if (fallback && fallback !== '{}') return JSON.parse(fallback);
+        throw error;
+      }
+    }
+
+    function setupToggle() {
+      const frame = document.getElementById('frame');
+      const generatedButton = document.getElementById('generatedButton');
+      const referenceButton = document.getElementById('referenceButton');
+      generatedButton.addEventListener('click', () => {
+        frame.classList.remove('show-reference');
+        generatedButton.classList.add('active');
+        referenceButton.classList.remove('active');
+      });
+      referenceButton.addEventListener('click', () => {
+        frame.classList.add('show-reference');
+        referenceButton.classList.add('active');
+        generatedButton.classList.remove('active');
+      });
+    }
+
+    setupToggle();
+    loadSpec().then(render).catch(error => {
+      document.getElementById('surface').textContent = `Failed to load reconstruction JSON: ${error.message}`;
+    });
+  </script>
+</body>
+</html>
