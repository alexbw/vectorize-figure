+        appendText(svg, {text: tick.label, x: x - 8, y: y + 5, fontSize: tickFontSize, anchor: 'end'}, typography);
+      }
+
+      appendText(svg, plot.x.label, typography);
+      appendText(svg, plot.y.label, typography);
+    }
+
+    function renderReferenceLine(svg, mark, system) {
+      const project = projector(system);
+      if (mark.orientation === 'vertical') {
+        const x = project.x(mark.value);
+        svg.appendChild(make('line', {
+          x1: x,
+          y1: project.y(mark.yRange[0]),
+          x2: x,
+          y2: project.y(mark.yRange[1]),
+          stroke: mark.stroke,
+          'stroke-width': mark.strokeWidth,
+          'stroke-dasharray': mark.strokeDasharray,
+          'data-object-id': mark.id
+        }));
+      }
+    }
+
+    function pathFromPoints(points, project) {
+      return points.map((point, index) => `${index === 0 ? 'M' : 'L'} ${project.x(point[0]).toFixed(2)} ${project.y(point[1]).toFixed(2)}`).join(' ');
+    }
+
+    function renderLineSeries(svg, mark, system) {
+      const project = projector(system);
+      svg.appendChild(make('path', {
+        d: pathFromPoints(mark.points, project),
+        fill: mark.fill || 'none',
+        stroke: mark.stroke,
+        'stroke-width': mark.strokeWidth,
+        'stroke-linecap': 'round',
+        'stroke-linejoin': 'round',
+        'data-object-id': mark.id,
+        'data-mark-type': mark.type
+      }));
+    }
+
+    function renderLegendItem(svg, item, typography) {
+      svg.appendChild(make('line', {
+        x1: item.line.x1,
+        y1: item.line.y1,
+        x2: item.line.x2,
+        y2: item.line.y2,
+        stroke: item.line.stroke,
+        'stroke-width': item.line.strokeWidth,
+        'data-object-id': `${item.id}-swatch`
+      }));
+      appendText(svg, item.label, typography);
+    }
+
+    function render(spec) {
+      document.title = `${spec.id} reconstruction`;
+      document.getElementById('title').textContent = spec.id;
+      const frame = document.getElementById('frame');
+      const surface = document.getElementById('surface');
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      surface.replaceChildren();
+
+      const svg = make('svg', {
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`,
+        role: 'img',
+        'aria-label': `${spec.id} generated reconstruction`
+      });
+      svg.appendChild(make('rect', {x: 0, y: 0, width: spec.canvas.width, height: spec.canvas.height, fill: spec.canvas.background}));
+      surface.appendChild(svg);
+
+      const panel = spec.panels[0];
+      appendText(svg, panel.label, spec.typography);
+      appendText(svg, panel.title, spec.typography);
+
+      const plot = panel.plots[0];
+      const system = findSystem(spec, 'rho-cdf.xy');
+      renderAxes(svg, plot, spec.typography, spec.rendering.styleTokens);
+
+      for (const mark of panel.marks) {
+        const markSystem = findSystem(spec, mark.usesTransform);
+        if (mark.type === 'referenceLine') renderReferenceLine(svg, mark, markSystem);
+        if (mark.type === 'lineSeries') renderLineSeries(svg, mark, markSystem);
+      }
+
+      for (const annotation of panel.annotations) {
+        if (annotation.type === 'legendItem') renderLegendItem(svg, annotation, spec.typography);
+        if (annotation.type === 'text') appendText(svg, annotation, spec.typography);
+      }
+
+      const reference = document.getElementById('reference');
+      reference.src = spec.source.path;
+    }
+
+    async function loadSpec() {
+      try {
+        const response = await fetch('./reference-06-replay-stimulation-G.json', {cache: 'no-store'});
+        if (!response.ok) throw new Error(`HTTP ${response.status}`);
+        return response.json();
+      } catch (error) {
+        const fallback = document.getElementById('fallback-spec').textContent.trim();
+        if (fallback && fallback !== '{}') return JSON.parse(fallback);
+        throw error;
+      }
+    }
+
+    function setupToggle() {
+      const frame = document.getElementById('frame');
+      const generatedButton = document.getElementById('generatedButton');
+      const referenceButton = document.getElementById('referenceButton');
+      generatedButton.addEventListener('click', () => {
+        frame.classList.remove('show-reference');
+        generatedButton.classList.add('active');
+        referenceButton.classList.remove('active');
+      });
+      referenceButton.addEventListener('click', () => {
+        frame.classList.add('show-reference');
+        referenceButton.classList.add('active');
+        generatedButton.classList.remove('active');
+      });
+    }
+
+    setupToggle();
+    loadSpec().then(render).catch(error => {
+      document.getElementById('surface').textContent = `Failed to load reconstruction JSON: ${error.message}`;
+    });
+  </script>
+</body>
+</html>
