+        'text-anchor': panel.title.textAnchor
+      }, panel.title.text));
+      panel.annotations.forEach((annotation) => {
+        labels.appendChild(textEl({
+          id: annotation.id,
+          class: 'annotation-text',
+          'data-annotation-type': annotation.type,
+          x: annotation.x,
+          y: annotation.y,
+          'font-size': annotation.fontSize,
+          fill: annotation.fill,
+          'text-anchor': annotation.textAnchor
+        }, annotation.text));
+      });
+      svg.appendChild(labels);
+
+      const target = document.getElementById('candidate');
+      target.innerHTML = '';
+      target.appendChild(svg);
+    }
+
+    async function loadSpec() {
+      try {
+        const response = await fetch(specUrl);
+        if (!response.ok) throw new Error(`Unable to load ${specUrl}`);
+        return await response.json();
+      } catch (error) {
+        const fallback = JSON.parse(document.getElementById('fallback-spec').textContent);
+        fallback.panels = [];
+        throw new Error(`Spec load failed and fallback is metadata only: ${error.message}`);
+      }
+    }
+
+    document.getElementById('qaToggle').addEventListener('change', (event) => {
+      document.getElementById('qaReference').classList.toggle('is-visible', event.target.checked);
+    });
+
+    loadSpec().then(render).catch((error) => {
+      document.getElementById('candidate').textContent = error.message;
+    });
+  </script>
+</body>
+</html>
