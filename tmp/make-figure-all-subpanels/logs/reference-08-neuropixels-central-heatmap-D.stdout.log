+          'data-value': tick.value,
+          x: x.toFixed(2),
+          y: 197,
+          'font-size': 14,
+          fill: '#111111',
+          'text-anchor': 'middle'
+        }, tick.label));
+      });
+      plot.y.ticks.forEach((tick) => {
+        const y = yScale(tick.value);
+        axes.appendChild(el('line', {
+          class: 'tick-mark',
+          'data-axis': 'y',
+          'data-value': tick.value,
+          x1: plot.axes.yAxis.line.x1,
+          y1: y.toFixed(2),
+          x2: plot.axes.yAxis.line.x1 - plot.axes.yAxis.tickLength,
+          y2: y.toFixed(2),
+          stroke: plot.axes.yAxis.stroke,
+          'stroke-width': plot.axes.yAxis.strokeWidth
+        }));
+        axes.appendChild(textEl({
+          class: 'tick-label',
+          'data-axis': 'y',
+          'data-value': tick.value,
+          x: 89,
+          y: (y + 5).toFixed(2),
+          'font-size': 14,
+          fill: '#111111',
+          'text-anchor': 'end'
+        }, tick.label));
+      });
+      axes.appendChild(textEl({
+        id: plot.y.label.id,
+        class: 'axis-label',
+        x: plot.y.label.x,
+        y: plot.y.label.y,
+        transform: `rotate(${plot.y.label.rotation} ${plot.y.label.x} ${plot.y.label.y})`,
+        'font-size': plot.y.label.fontSize,
+        fill: '#111111',
+        'text-anchor': plot.y.label.textAnchor
+      }, plot.y.label.text));
+      svg.appendChild(axes);
+
+      const seriesLayer = el('g', {'data-layer': 'series'});
+      const observed = panel.marks.find((mark) => mark.id === 'observed-line');
+      const uncertainty = panel.marks.find((mark) => mark.id === 'observed-uncertainty');
+      seriesLayer.appendChild(el('path', {
+        id: uncertainty.id,
+        'data-mark-type': uncertainty.type,
+        'data-series': uncertainty.series,
+        d: bandPath(observed.points, uncertainty.lowerOffset, uncertainty.upperOffset, xScale, yScale),
+        fill: uncertainty.fill,
+        opacity: uncertainty.opacity,
+        stroke: 'none'
+      }));
+      [observed, panel.marks.find((mark) => mark.id === 'chance-line')].forEach((mark) => {
+        seriesLayer.appendChild(el('path', {
+          id: mark.id,
+          'data-mark-type': mark.type,
+          'data-series': mark.series,
+          d: linePath(mark.points, xScale, yScale),
+          fill: mark.fill,
+          stroke: mark.stroke,
+          'stroke-width': mark.strokeWidth,
+          'stroke-dasharray': mark.dashArray || null,
+          'stroke-linejoin': 'round',
+          'stroke-linecap': 'round'
+        }));
+      });
+      svg.appendChild(seriesLayer);
+
+      const labels = el('g', {'data-layer': 'labels'});
+      labels.appendChild(textEl({
+        id: panel.label.id,
+        class: 'panel-label',
+        x: panel.label.x,
+        y: panel.label.y,
+        'font-size': panel.label.fontSize,
+        'font-weight': panel.label.fontWeight,
+        fill: '#000000',
+        'text-anchor': panel.label.textAnchor
+      }, panel.label.text));
+      labels.appendChild(textEl({
+        id: panel.title.id,
+        class: 'panel-title',
+        x: panel.title.x,
+        y: panel.title.y,
+        'font-size': panel.title.fontSize,
+        'font-weight': panel.title.fontWeight,
+        fill: '#111111',
+        'text-anchor': panel.title.textAnchor
+      }, panel.title.text));
+      panel.annotations.forEach((annotation) => {
+        labels.appendChild(textEl({
+          id: annotation.id,
+          class: 'annotation-text',
+          'data-annotation-type': annotation.type,
+          x: annotation.x,
+          y: annotation.y,
+          'font-size': annotation.fontSize,
+          fill: annotation.fill,
+          'text-anchor': annotation.textAnchor
+        }, annotation.text));
+      });
+      svg.appendChild(labels);
+
+      const target = document.getElementById('candidate');
+      target.innerHTML = '';
+      target.appendChild(svg);
+    }
+
+    async function loadSpec() {
+      try {
+        const response = await fetch(specUrl);
+        if (!response.ok) throw new Error(`Unable to load ${specUrl}`);
+        return await response.json();
+      } catch (error) {
+        const fallback = JSON.parse(document.getElementById('fallback-spec').textContent);
+        fallback.panels = [];
+        throw new Error(`Spec load failed and fallback is metadata only: ${error.message}`);
+      }
+    }
+
+    document.getElementById('qaToggle').addEventListener('change', (event) => {
+      document.getElementById('qaReference').classList.toggle('is-visible', event.target.checked);
+    });
+
+    loadSpec().then(render).catch((error) => {
+      document.getElementById('candidate').textContent = error.message;
+    });
+  </script>
+</body>
+</html>
