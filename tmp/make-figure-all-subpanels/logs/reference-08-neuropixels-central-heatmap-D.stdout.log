+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>reference-08-neuropixels-central-heatmap-D reconstruction</title>
+  <style>
+    :root {
+      color-scheme: light;
+      --page-bg: #f5f5f5;
+      --ink: #111111;
+      --muted: #666666;
+      --panel-bg: #ffffff;
+      --rule: #d9d9d9;
+    }
+    * {
+      box-sizing: border-box;
+    }
+    body {
+      margin: 0;
+      min-height: 100vh;
+      background: var(--page-bg);
+      color: var(--ink);
+      font-family: Arial, Helvetica, sans-serif;
+      padding: 16px;
+    }
+    .wrap {
+      display: grid;
+      gap: 12px;
+      align-items: start;
+      width: max-content;
+      max-width: 100%;
+    }
+    .toolbar {
+      display: flex;
+      align-items: center;
+      gap: 10px;
+      font-size: 13px;
+      color: var(--muted);
+    }
+    .toolbar label {
+      display: inline-flex;
+      align-items: center;
+      gap: 6px;
+      user-select: none;
+    }
+    .stage {
+      display: grid;
+      grid-template-columns: auto;
+      gap: 12px;
+    }
+    .candidate,
+    .qa-reference {
+      width: 440px;
+      max-width: 100%;
+      background: var(--panel-bg);
+    }
+    .candidate {
+      box-shadow: 0 0 0 1px var(--rule);
+    }
+    .qa-reference {
+      display: none;
+      padding: 8px;
+      border: 1px solid var(--rule);
+    }
+    .qa-reference.is-visible {
+      display: block;
+    }
+    .qa-reference strong {
+      display: block;
+      margin: 0 0 6px;
+      font-size: 12px;
+      color: var(--muted);
+      font-weight: 700;
+    }
+    .qa-reference img {
+      display: block;
+      width: 440px;
+      height: 198px;
+      max-width: 100%;
+      object-fit: contain;
+    }
+    svg {
+      display: block;
+      width: 440px;
+      height: 198px;
+      max-width: 100%;
+      background: #ffffff;
+      overflow: visible;
+    }
+    .axis-line,
+    .tick-mark {
+      stroke: #1a1a1a;
+      stroke-linecap: square;
+      shape-rendering: crispEdges;
+    }
+    .tick-label,
+    .axis-label,
+    .panel-title,
+    .panel-label,
+    .annotation-text {
+      font-family: Arial, Helvetica, sans-serif;
+      letter-spacing: 0;
+    }
+  </style>
+</head>
+<body>
+  <main class="wrap">
+    <div class="toolbar">
+      <label><input id="qaToggle" type="checkbox"> Show QA reference</label>
+      <span>Generated SVG candidate is rendered from semantic JSON.</span>
+    </div>
+    <section class="stage" aria-label="Figure reconstruction">
+      <div id="candidate" class="candidate" aria-label="Generated reconstruction"></div>
+      <aside id="qaReference" class="qa-reference" aria-label="QA reference only">
+        <strong>QA reference only: source raster is not used in the generated candidate</strong>
+        <img alt="Reference raster for QA only" src="../../../assets/reference/reference-08-neuropixels-central-heatmap-D-reference.png">
+      </aside>
+    </section>
+  </main>
+
+  <script type="application/json" id="fallback-spec">
+  {
+    "schema": "scientific_figure_reconstruction.v1",
+    "id": "reference-08-neuropixels-central-heatmap-D",
+    "source": {
+      "path": "../../../assets/reference/reference-08-neuropixels-central-heatmap-D-reference.png",
+      "usage": "QA-only; not used by generated candidate."
+    }
+  }
+  </script>
+  <script>
+    const specUrl = './reference-08-neuropixels-central-heatmap-D.json';
+    const ns = 'http://www.w3.org/2000/svg';
+
+    function el(name, attrs = {}, children = []) {
+      const node = document.createElementNS(ns, name);
+      Object.entries(attrs).forEach(([key, value]) => {
+        if (value !== undefined && value !== null) node.setAttribute(key, value);
+      });
+      children.forEach((child) => node.appendChild(child));
+      return node;
+    }
+
+    function textEl(attrs, text) {
+      const node = el('text', attrs);
+      node.textContent = text;
+      return node;
+    }
+
+    function linePath(points, xScale, yScale) {
+      return points.map((point, index) => {
+        const cmd = index === 0 ? 'M' : 'L';
+        return `${cmd}${xScale(point[0]).toFixed(2)},${yScale(point[1]).toFixed(2)}`;
+      }).join(' ');
+    }
+
+    function bandPath(points, lowerOffset, upperOffset, xScale, yScale) {
+      const upper = points.map((point) => [point[0], Math.min(1, point[1] + upperOffset)]);
+      const lower = points.slice().reverse().map((point) => [point[0], Math.max(0, point[1] - lowerOffset)]);
+      const joined = upper.concat(lower);
+      return joined.map((point, index) => {
+        const cmd = index === 0 ? 'M' : 'L';
+        return `${cmd}${xScale(point[0]).toFixed(2)},${yScale(point[1]).toFixed(2)}`;
+      }).join(' ') + ' Z';
+    }
+
+    function render(spec) {
+      const panel = spec.panels[0];
+      const plot = panel.plot;
+      const bbox = plot.dataBbox;
+      const xDomain = plot.x.domain;
+      const yDomain = plot.y.domain;
+      const xScale = (value) => bbox.x + ((value - xDomain[0]) / (xDomain[1] - xDomain[0])) * bbox.width;
+      const yScale = (value) => bbox.y + bbox.height - ((value - yDomain[0]) / (yDomain[1] - yDomain[0])) * bbox.height;
+
+      const svg = el('svg', {
+        viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`,
+        role: 'img',
+        'aria-labelledby': 'svg-title svg-desc',
+        'data-figure-id': spec.id
+      });
+      svg.appendChild(textEl({id: 'svg-title'}, 'Decoding position reconstruction'));
+      svg.appendChild(textEl({id: 'svg-desc'}, 'Editable reconstruction of line chart panel D'));
+      svg.appendChild(el('rect', {x: 0, y: 0, width: spec.canvas.width, height: spec.canvas.height, fill: spec.canvas.background}));
+
+      const context = el('g', {'data-layer': 'context-bands'});
+      const bandGroup = panel.marks.find((mark) => mark.id === 'panel-d-context-bands');
+      bandGroup.bands.forEach((band, index) => {
+        context.appendChild(el('rect', {
+          id: `${bandGroup.id}-${index}`,
+          'data-mark-type': 'rectBand',
+          'data-axis': 'x',
+          x: xScale(band.x0).toFixed(2),
+          y: yScale(bandGroup.y1).toFixed(2),
+          width: (xScale(band.x1) - xScale(band.x0)).toFixed(2),
+          height: (yScale(bandGroup.y0) - yScale(bandGroup.y1)).toFixed(2),
+          fill: bandGroup.fill,
+          opacity: bandGroup.opacity
+        }));
+      });
+      svg.appendChild(context);
+
+      const axes = el('g', {'data-layer': 'axes'});
+      axes.appendChild(el('line', {...plot.axes.xAxis.line, id: plot.axes.xAxis.id, class: 'axis-line', stroke: plot.axes.xAxis.stroke, 'stroke-width': plot.axes.xAxis.strokeWidth}));
+      axes.appendChild(el('line', {...plot.axes.yAxis.line, id: plot.axes.yAxis.id, class: 'axis-line', stroke: plot.axes.yAxis.stroke, 'stroke-width': plot.axes.yAxis.strokeWidth}));
+      plot.x.ticks.forEach((tick) => {
+        const x = xScale(tick.value);
+        axes.appendChild(el('line', {
+          class: 'tick-mark',
+          'data-axis': 'x',
+          'data-value': tick.value,
+          x1: x.toFixed(2),
+          y1: plot.axes.xAxis.line.y1,
+          x2: x.toFixed(2),
+          y2: plot.axes.xAxis.line.y1 + plot.axes.xAxis.tickLength,
+          stroke: plot.axes.xAxis.stroke,
+          'stroke-width': plot.axes.xAxis.strokeWidth
+        }));
+        axes.appendChild(textEl({
+          class: 'tick-label',
+          'data-axis': 'x',
+          'data-value': tick.value,
+          x: x.toFixed(2),
+          y: 197,
+          'font-size': 14,
+          fill: '#111111',
+          'text-anchor': 'middle'
+        }, tick.label));
+      });
+      plot.y.ticks.forEach((tick) => {
+        const y = yScale(tick.value);
+        axes.appendChild(el('line', {
+          class: 'tick-mark',
+          'data-axis': 'y',
+          'data-value': tick.value,
+          x1: plot.axes.yAxis.line.x1,
+          y1: y.toFixed(2),
+          x2: plot.axes.yAxis.line.x1 - plot.axes.yAxis.tickLength,
+          y2: y.toFixed(2),
+          stroke: plot.axes.yAxis.stroke,
+          'stroke-width': plot.axes.yAxis.strokeWidth
+        }));
+        axes.appendChild(textEl({
+          class: 'tick-label',
+          'data-axis': 'y',
+          'data-value': tick.value,
+          x: 89,
+          y: (y + 5).toFixed(2),
+          'font-size': 14,
+          fill: '#111111',
+          'text-anchor': 'end'
+        }, tick.label));
+      });
+      axes.appendChild(textEl({
+        id: plot.y.label.id,
+        class: 'axis-label',
+        x: plot.y.label.x,
+        y: plot.y.label.y,
+        transform: `rotate(${plot.y.label.rotation} ${plot.y.label.x} ${plot.y.label.y})`,
+        'font-size': plot.y.label.fontSize,
+        fill: '#111111',
+        'text-anchor': plot.y.label.textAnchor
+      }, plot.y.label.text));
+      svg.appendChild(axes);
+
+      const seriesLayer = el('g', {'data-layer': 'series'});
+      const observed = panel.marks.find((mark) => mark.id === 'observed-line');
+      const uncertainty = panel.marks.find((mark) => mark.id === 'observed-uncertainty');
+      seriesLayer.appendChild(el('path', {
+        id: uncertainty.id,
+        'data-mark-type': uncertainty.type,
+        'data-series': uncertainty.series,
+        d: bandPath(observed.points, uncertainty.lowerOffset, uncertainty.upperOffset, xScale, yScale),
+        fill: uncertainty.fill,
+        opacity: uncertainty.opacity,
+        stroke: 'none'
+      }));
+      [observed, panel.marks.find((mark) => mark.id === 'chance-line')].forEach((mark) => {
