+          'data-mark-type': 'rectBand',
+          'data-axis': 'x',
+          x: xScale(band.x0).toFixed(2),
+          y: yScale(bandGroup.y1).toFixed(2),
+          width: (xScale(band.x1) - xScale(band.x0)).toFixed(2),
+          height: (yScale(bandGroup.y0) - yScale(bandGroup.y1)).toFixed(2),
+          fill: bandGroup.fill,
+          opacity: bandGroup.opacity
+        }));
+      });
+      svg.appendChild(context);
+
+      const axes = el('g', {'data-layer': 'axes'});
+      axes.appendChild(el('line', {...plot.axes.xAxis.line, id: plot.axes.xAxis.id, class: 'axis-line', stroke: plot.axes.xAxis.stroke, 'stroke-width': plot.axes.xAxis.strokeWidth}));
+      axes.appendChild(el('line', {...plot.axes.yAxis.line, id: plot.axes.yAxis.id, class: 'axis-line', stroke: plot.axes.yAxis.stroke, 'stroke-width': plot.axes.yAxis.strokeWidth}));
+      plot.x.ticks.forEach((tick) => {
+        const x = xScale(tick.value);
+        axes.appendChild(el('line', {
+          class: 'tick-mark',
+          'data-axis': 'x',
+          'data-value': tick.value,
