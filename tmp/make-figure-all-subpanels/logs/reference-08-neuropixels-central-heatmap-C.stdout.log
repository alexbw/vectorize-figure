+</head>
+<body>
+  <header>
+    <div>
+      <h1 id="pageTitle">Neuropixels heatmap C reconstruction</h1>
+      <div class="note">Generated candidate is JSON-rendered. Source image appears only in the labeled QA/reference view.</div>
+    </div>
+    <div class="toggle" aria-label="View mode">
+      <button id="generatedButton" class="active" type="button">Generated</button>
+      <button id="referenceButton" type="button">QA reference</button>
+    </div>
+  </header>
+
+  <main>
+    <div id="frame" class="frame">
+      <div id="surface" class="surface"></div>
+      <div id="referencePane" class="reference-pane">
+        <img id="referenceImage" alt="QA reference source image">
+        <div class="reference-label">QA reference only</div>
+      </div>
+    </div>
+  </main>
+
+  <script>
+    const SVG_NS = 'http://www.w3.org/2000/svg';
+
+    function $(id) {
+      return document.getElementById(id);
+    }
+
+    function svgEl(tag, attrs = {}) {
+      const node = document.createElementNS(SVG_NS, tag);
+      for (const [key, value] of Object.entries(attrs)) {
+        if (value !== undefined && value !== null) node.setAttribute(key, value);
+      }
+      return node;
+    }
+
+    function rng(seed) {
+      return function random() {
+        let t = seed += 0x6D2B79F5;
+        t = Math.imul(t ^ (t >>> 15), t | 1);
+        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
+        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
+      };
+    }
+
+    function clamp(value, min, max) {
+      return Math.max(min, Math.min(max, value));
+    }
+
+    function scale(domain, range, value) {
+      return range[0] + (value - domain[0]) / (domain[1] - domain[0]) * (range[1] - range[0]);
+    }
+
+    function xScale(panel, value) {
+      const box = panel.plot.dataBbox;
+      return scale(panel.plot.x.domain, [box.x, box.x + box.width], value);
+    }
+
+    function yScale(panel, value) {
+      const box = panel.plot.dataBbox;
+      return scale(panel.plot.y.domain, [box.y, box.y + box.height], value);
+    }
+
+    function hexToRgb(hex) {
+      const clean = hex.replace('#', '');
+      return {
+        r: parseInt(clean.slice(0, 2), 16),
+        g: parseInt(clean.slice(2, 4), 16),
+        b: parseInt(clean.slice(4, 6), 16)
+      };
+    }
+
+    function interpolateColor(stops, value) {
+      const sorted = stops.slice().sort((a, b) => a.value - b.value);
+      if (value <= sorted[0].value) return hexToRgb(sorted[0].color);
+      if (value >= sorted[sorted.length - 1].value) return hexToRgb(sorted[sorted.length - 1].color);
+      for (let i = 0; i < sorted.length - 1; i += 1) {
+        const a = sorted[i];
+        const b = sorted[i + 1];
+        if (value >= a.value && value <= b.value) {
+          const t = (value - a.value) / (b.value - a.value);
+          const ca = hexToRgb(a.color);
+          const cb = hexToRgb(b.color);
+          return {
+            r: Math.round(ca.r + (cb.r - ca.r) * t),
+            g: Math.round(ca.g + (cb.g - ca.g) * t),
+            b: Math.round(ca.b + (cb.b - ca.b) * t)
+          };
+        }
+      }
+      return hexToRgb('#101311');
+    }
+
+    function gaussian(x, y, blob) {
+      const dx = (x - blob.centerX) / blob.sigmaX;
+      const dy = (y - blob.centerY) / blob.sigmaY;
+      return blob.amplitude * Math.exp(-0.5 * (dx * dx + dy * dy));
+    }
+
+    function renderHeatmap(ctx, spec, panel, mark) {
+      const box = panel.plot.dataBbox;
+      const recipe = mark.recipe;
+      const random = rng(recipe.seed);
+      const rows = mark.matrix.rows;
+      const columns = mark.matrix.columns;
+      const colorScale = spec.coordinateSystems.find(item => item.id === mark.colorScale);
+      const rowOffsets = Array.from({length: rows}, () => (random() - 0.5) * recipe.rowTextureStrength);
+      const rowGates = Array.from({length: rows}, () => random());
+
+      ctx.fillStyle = panel.plot.background;
+      ctx.fillRect(box.x, box.y, box.width, box.height);
+      ctx.save();
+      ctx.beginPath();
+      ctx.rect(box.x, box.y, box.width, box.height);
+      ctx.clip();
+
+      for (let row = 0; row < rows; row += 1) {
+        const yData = 1 + row;
+        const y = Math.round(yScale(panel, yData));
+        const nextY = Math.round(yScale(panel, yData + 1));
+        const h = Math.max(1, Math.abs(nextY - y));
+        const sparseRow = rowGates[row] < recipe.horizontalLineProbability;
+        for (let col = 0; col < columns; col += 1) {
+          const xData = col;
+          let value = recipe.baseline + rowOffsets[row] * 0.35;
+          value += (random() - 0.5) * recipe.noise;
+          value += Math.sin((row * 0.052) + (col * 0.11)) * recipe.columnBandStrength;
+
+          for (const blob of recipe.eventResponses) value += gaussian(xData, yData, blob);
+          for (const blob of recipe.cyanSuppressions) value += gaussian(xData, yData, blob);
+
+          if (!sparseRow && random() > 0.18) value *= 0.45;
+          if (random() > 0.965) value += 1.2 * random();
+          if (random() < 0.035) value -= 0.9 * random();
+
+          const color = interpolateColor(colorScale.stops, clamp(value, colorScale.domain[0], colorScale.domain[1]));
+          const x = Math.round(xScale(panel, xData));
+          const nextX = Math.round(xScale(panel, xData + 1));
+          const w = Math.max(2, nextX - x + 1);
+          ctx.fillStyle = `rgb(${color.r}, ${color.g}, ${color.b})`;
+          ctx.globalAlpha = sparseRow ? 0.9 : 0.44;
+          ctx.fillRect(x, Math.min(y, nextY), w, h);
+        }
+      }
+
+      ctx.globalAlpha = 1;
+      ctx.restore();
+    }
+
+    function appendText(svg, textSpec, extra = {}) {
+      const node = svgEl('text', {
+        x: textSpec.x,
+        y: textSpec.y,
+        fill: textSpec.fill || '#111111',
+        'font-size': textSpec.fontSize,
+        'font-weight': textSpec.fontWeight || 400,
+        'text-anchor': textSpec.anchor || 'start',
+        'dominant-baseline': extra.baseline || 'alphabetic',
+        transform: textSpec.rotation ? `rotate(${textSpec.rotation} ${textSpec.x} ${textSpec.y})` : null,
+        id: textSpec.id || null
+      });
+      node.textContent = textSpec.text;
+      svg.appendChild(node);
+    }
+
+    function renderAxes(svg, panel) {
+      const plot = panel.plot;
+      const box = plot.dataBbox;
+      svg.appendChild(svgEl('rect', {
+        x: box.x,
+        y: box.y,
+        width: box.width,
+        height: box.height,
+        fill: 'none',
+        stroke: '#111111',
+        'stroke-width': 1
+      }));
+
+      for (const tick of plot.x.ticks) {
+        const x = xScale(panel, tick.value);
+        svg.appendChild(svgEl('line', {
+          x1: x,
+          y1: box.y + box.height,
+          x2: x,
+          y2: box.y + box.height + plot.axes.xAxis.tickLength,
+          stroke: '#111111',
+          'stroke-width': 1,
+          'data-axis': 'x',
+          'data-value': tick.value
+        }));
+        const label = svgEl('text', {
+          x,
+          y: box.y + box.height + 18,
+          fill: '#111111',
+          'font-size': 16,
+          'font-weight': 400,
+          'text-anchor': 'middle'
+        });
+        label.textContent = tick.label;
+        svg.appendChild(label);
+      }
+
+      for (const tick of plot.y.ticks) {
+        const y = yScale(panel, tick.value);
+        svg.appendChild(svgEl('line', {
+          x1: box.x - plot.axes.yAxis.tickLength,
+          y1: y,
+          x2: box.x,
+          y2: y,
+          stroke: '#111111',
+          'stroke-width': 1,
+          'data-axis': 'y',
+          'data-value': tick.value
+        }));
+        const label = svgEl('text', {
+          x: box.x - 12,
+          y: y + 5,
+          fill: '#111111',
+          'font-size': 16,
+          'font-weight': 400,
+          'text-anchor': 'end'
+        });
+        label.textContent = tick.label;
+        svg.appendChild(label);
+      }
+
+      if (plot.y.label) appendText(svg, plot.y.label, {baseline: 'middle'});
+    }
+
+    function renderEventLines(svg, panel, mark) {
+      const box = panel.plot.dataBbox;
+      for (const value of mark.values) {
+        const x = xScale(panel, value);
+        svg.appendChild(svgEl('line', {
+          x1: x,
+          y1: box.y,
+          x2: x,
+          y2: box.y + box.height,
+          stroke: mark.stroke,
+          'stroke-width': mark.strokeWidth,
+          'stroke-dasharray': mark.dasharray,
+          opacity: mark.opacity,
+          'data-mark-id': mark.id,
+          'data-event-value': value
+        }));
+      }
+    }
+
+    function renderColorStrip(svg, panel) {
+      for (const item of panel.layoutObjects || []) {
+        if (item.type !== 'segmentedColorbar') continue;
+        for (const segment of item.segments) {
+          svg.appendChild(svgEl('rect', {
+            x: item.bbox.x,
+            y: segment.fromY,
+            width: item.bbox.width,
+            height: segment.toY - segment.fromY,
+            fill: segment.fill,
+            stroke: 'none',
+            'data-layout-id': item.id,
+            'data-segment-id': segment.id
+          }));
+        }
+        svg.appendChild(svgEl('rect', {
+          x: item.bbox.x,
+          y: item.bbox.y,
+          width: item.bbox.width,
+          height: item.bbox.height,
+          fill: 'none',
+          stroke: '#ffffff',
+          'stroke-width': 0.6
+        }));
+      }
+    }
+
+    async function loadSpec() {
+      const jsonPath = 'reference-08-neuropixels-central-heatmap-C.json';
