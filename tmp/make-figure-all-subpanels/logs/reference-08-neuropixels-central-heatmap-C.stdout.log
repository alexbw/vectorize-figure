+      return response.json();
+    }
+
+    function render(spec) {
+      const panel = spec.panels[0];
+      const frame = $('frame');
+      const surface = $('surface');
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      surface.replaceChildren();
+
+      $('pageTitle').textContent = `${spec.id} reconstruction`;
+      $('referenceImage').src = spec.source.path;
+
+      const canvas = document.createElement('canvas');
+      canvas.width = spec.canvas.width;
+      canvas.height = spec.canvas.height;
+      canvas.setAttribute('aria-label', 'Generated synthetic heatmap layer');
+      const ctx = canvas.getContext('2d');
+      ctx.fillStyle = spec.canvas.background;
+      ctx.fillRect(0, 0, spec.canvas.width, spec.canvas.height);
+      surface.appendChild(canvas);
+
+      const svg = svgEl('svg', {
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`,
+        role: 'img',
+        'aria-label': 'Generated axes, ticks, labels, and event lines'
+      });
+      svg.style.fontFamily = spec.typography.fontFamily;
+      surface.appendChild(svg);
+
+      for (const mark of panel.marks) {
+        if (mark.type === 'heatmap') renderHeatmap(ctx, spec, panel, mark);
+      }
+
+      renderColorStrip(svg, panel);
+      for (const mark of panel.marks) {
+        if (mark.type === 'eventLines') renderEventLines(svg, panel, mark);
+      }
+      renderAxes(svg, panel);
+      appendText(svg, panel.label);
+      appendText(svg, panel.title);
+    }
+
+    $('generatedButton').addEventListener('click', () => {
+      $('frame').classList.remove('show-reference');
+      $('generatedButton').classList.add('active');
+      $('referenceButton').classList.remove('active');
+    });
+
+    $('referenceButton').addEventListener('click', () => {
+      $('frame').classList.add('show-reference');
+      $('referenceButton').classList.add('active');
+      $('generatedButton').classList.remove('active');
+    });
+
+    loadSpec().then(render).catch(error => {
+      console.error(error);
+      $('surface').textContent = error.message;
+    });
+  </script>
+</body>
+</html>
