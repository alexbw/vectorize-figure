+
+    function appendText(svg, textSpec, extra = {}) {
+      const node = svgEl('text', {
+        x: textSpec.x,
+        y: textSpec.y,
+        fill: textSpec.fill || '#111111',
+        'font-size': textSpec.fontSize,
+        'font-weight': textSpec.fontWeight || 400,
+        'text-anchor': textSpec.anchor || 'start',
+        'dominant-baseline': extra.baseline || 'alphabetic',
+        transform: textSpec.rotation ? `rotate(${textSpec.rotation} ${textSpec.x} ${textSpec.y})` : null,
+        id: textSpec.id || null
+      });
+      node.textContent = textSpec.text;
+      svg.appendChild(node);
+    }
+
+    function renderAxes(svg, panel) {
+      const plot = panel.plot;
+      const box = plot.dataBbox;
+      svg.appendChild(svgEl('rect', {
+        x: box.x,
+        y: box.y,
+        width: box.width,
+        height: box.height,
+        fill: 'none',
+        stroke: '#111111',
+        'stroke-width': 1
+      }));
+
+      for (const tick of plot.x.ticks) {
+        const x = xScale(panel, tick.value);
+        svg.appendChild(svgEl('line', {
+          x1: x,
+          y1: box.y + box.height,
+          x2: x,
+          y2: box.y + box.height + plot.axes.xAxis.tickLength,
+          stroke: '#111111',
+          'stroke-width': 1,
+          'data-axis': 'x',
+          'data-value': tick.value
+        }));
+        const label = svgEl('text', {
+          x,
+          y: box.y + box.height + 18,
+          fill: '#111111',
+          'font-size': 16,
+          'font-weight': 400,
+          'text-anchor': 'middle'
+        });
+        label.textContent = tick.label;
+        svg.appendChild(label);
+      }
+
+      for (const tick of plot.y.ticks) {
+        const y = yScale(panel, tick.value);
+        svg.appendChild(svgEl('line', {
+          x1: box.x - plot.axes.yAxis.tickLength,
+          y1: y,
+          x2: box.x,
+          y2: y,
+          stroke: '#111111',
+          'stroke-width': 1,
+          'data-axis': 'y',
+          'data-value': tick.value
+        }));
+        const label = svgEl('text', {
+          x: box.x - 12,
+          y: y + 5,
+          fill: '#111111',
+          'font-size': 16,
+          'font-weight': 400,
+          'text-anchor': 'end'
+        });
+        label.textContent = tick.label;
+        svg.appendChild(label);
+      }
+
+      if (plot.y.label) appendText(svg, plot.y.label, {baseline: 'middle'});
+    }
+
+    function renderEventLines(svg, panel, mark) {
+      const box = panel.plot.dataBbox;
+      for (const value of mark.values) {
+        const x = xScale(panel, value);
+        svg.appendChild(svgEl('line', {
+          x1: x,
+          y1: box.y,
+          x2: x,
+          y2: box.y + box.height,
+          stroke: mark.stroke,
+          'stroke-width': mark.strokeWidth,
+          'stroke-dasharray': mark.dasharray,
+          opacity: mark.opacity,
+          'data-mark-id': mark.id,
+          'data-event-value': value
+        }));
+      }
+    }
+
+    function renderColorStrip(svg, panel) {
+      for (const item of panel.layoutObjects || []) {
+        if (item.type !== 'segmentedColorbar') continue;
+        for (const segment of item.segments) {
+          svg.appendChild(svgEl('rect', {
+            x: item.bbox.x,
+            y: segment.fromY,
+            width: item.bbox.width,
+            height: segment.toY - segment.fromY,
+            fill: segment.fill,
+            stroke: 'none',
+            'data-layout-id': item.id,
+            'data-segment-id': segment.id
+          }));
+        }
+        svg.appendChild(svgEl('rect', {
+          x: item.bbox.x,
+          y: item.bbox.y,
+          width: item.bbox.width,
+          height: item.bbox.height,
+          fill: 'none',
+          stroke: '#ffffff',
+          'stroke-width': 0.6
+        }));
+      }
+    }
+
+    async function loadSpec() {
+      const jsonPath = 'reference-08-neuropixels-central-heatmap-C.json';
+      const response = await fetch(jsonPath);
+      if (!response.ok) throw new Error(`Unable to load ${jsonPath}`);
+      return response.json();
+    }
+
+    function render(spec) {
+      const panel = spec.panels[0];
+      const frame = $('frame');
+      const surface = $('surface');
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      surface.replaceChildren();
+
+      $('pageTitle').textContent = `${spec.id} reconstruction`;
+      $('referenceImage').src = spec.source.path;
+
+      const canvas = document.createElement('canvas');
+      canvas.width = spec.canvas.width;
+      canvas.height = spec.canvas.height;
+      canvas.setAttribute('aria-label', 'Generated synthetic heatmap layer');
+      const ctx = canvas.getContext('2d');
+      ctx.fillStyle = spec.canvas.background;
+      ctx.fillRect(0, 0, spec.canvas.width, spec.canvas.height);
+      surface.appendChild(canvas);
+
+      const svg = svgEl('svg', {
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`,
+        role: 'img',
+        'aria-label': 'Generated axes, ticks, labels, and event lines'
+      });
+      svg.style.fontFamily = spec.typography.fontFamily;
+      surface.appendChild(svg);
+
+      for (const mark of panel.marks) {
+        if (mark.type === 'heatmap') renderHeatmap(ctx, spec, panel, mark);
+      }
+
+      renderColorStrip(svg, panel);
+      for (const mark of panel.marks) {
+        if (mark.type === 'eventLines') renderEventLines(svg, panel, mark);
+      }
+      renderAxes(svg, panel);
+      appendText(svg, panel.label);
+      appendText(svg, panel.title);
+    }
+
+    $('generatedButton').addEventListener('click', () => {
+      $('frame').classList.remove('show-reference');
+      $('generatedButton').classList.add('active');
+      $('referenceButton').classList.remove('active');
+    });
+
+    $('referenceButton').addEventListener('click', () => {
+      $('frame').classList.add('show-reference');
+      $('referenceButton').classList.add('active');
+      $('generatedButton').classList.remove('active');
+    });
+
+    loadSpec().then(render).catch(error => {
+      console.error(error);
+      $('surface').textContent = error.message;
+    });
+  </script>
+</body>
+</html>
