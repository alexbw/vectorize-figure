+            x: (x + cellW / 2).toFixed(2),
+            y: (y + cellH / 2 + 1).toFixed(2),
+            'font-family': font,
+            'font-size': panel.marks[0].label.fontSize,
+            'font-weight': panel.marks[0].label.fontWeight,
+            fill: textFill,
+            'text-anchor': panel.marks[0].label.anchor,
+            'dominant-baseline': panel.marks[0].label.baseline,
+            'data-mark': 'cell-value',
+            'data-row': matrix.rowOrder[rowIndex],
+            'data-column': matrix.columnOrder[columnIndex]
+          }));
+        });
+      });
+
+      svg.appendChild(svgEl('rect', {
+        x: box.x,
+        y: box.y,
+        width: box.width,
+        height: box.height,
+        fill: 'none',
+        stroke: spec.styleTokens.matrixBorder,
+        'stroke-width': 1.1,
+        'data-mark': 'matrix-border'
+      }));
+
+      plot.x.categories.forEach((category, index) => {
+        svg.appendChild(textNode(category.label, {
+          x: (box.x + index * cellW + cellW / 2).toFixed(2),
+          y: plot.x.tickBand.y,
+          'font-family': font,
+          'font-size': plot.x.tickBand.fontSize,
+          fill: category.color,
+          'text-anchor': plot.x.tickBand.anchor,
+          'data-mark': 'category-label',
+          'data-axis': 'x',
+          'data-category': category.label
+        }));
+      });
+
+      plot.y.categories.forEach((category, index) => {
+        svg.appendChild(textNode(category.label, {
+          x: plot.y.tickBand.x,
+          y: (box.y + index * cellH + cellH / 2 + 5).toFixed(2),
+          'font-family': font,
+          'font-size': plot.y.tickBand.fontSize,
+          fill: category.color,
+          'text-anchor': plot.y.tickBand.anchor,
+          'data-mark': 'category-label',
+          'data-axis': 'y',
+          'data-category': category.label
+        }));
+      });
+
+      const gradient = svgEl('linearGradient', {
+        id: 'pearson-r-gradient',
+        x1: '0%',
+        x2: '100%',
+        y1: '0%',
+        y2: '0%'
+      });
+      colorStops.forEach((color, index) => {
+        gradient.appendChild(svgEl('stop', {
+          offset: `${index / (colorStops.length - 1) * 100}%`,
+          'stop-color': color
+        }));
+      });
+      defs.appendChild(gradient);
+
+      const colorbar = panel.colorbar;
+      svg.appendChild(textNode(colorbar.title.text, {
+        x: colorbar.title.x,
+        y: colorbar.title.y,
+        'font-family': font,
+        'font-size': colorbar.title.fontSize,
+        fill: spec.typography.color,
+        'text-anchor': colorbar.title.anchor,
+        'data-mark': 'colorbar-title'
+      }));
+      svg.appendChild(svgEl('rect', {
+        x: colorbar.bbox.x,
+        y: colorbar.bbox.y,
+        width: colorbar.bbox.width,
+        height: colorbar.bbox.height,
+        fill: 'url(#pearson-r-gradient)',
+        stroke: '#333333',
+        'stroke-width': 0.8,
+        'data-mark': 'colorbar-ramp'
+      }));
+
+      const domain = colorSystem.domain;
+      colorbar.ticks.forEach(tick => {
+        const tx = colorbar.bbox.x + (tick.value - domain[0]) / (domain[1] - domain[0]) * colorbar.bbox.width;
+        svg.appendChild(svgEl('line', {
+          x1: tx.toFixed(2),
+          y1: colorbar.bbox.y + colorbar.bbox.height,
+          x2: tx.toFixed(2),
+          y2: colorbar.bbox.y + colorbar.bbox.height + colorbar.tickLength,
+          stroke: spec.styleTokens.tick,
+          'stroke-width': 0.8,
+          'data-mark': 'colorbar-tick',
+          'data-value': tick.value
+        }));
+        svg.appendChild(textNode(tick.label, {
+          x: tx.toFixed(2),
+          y: colorbar.tickLabelY,
+          'font-family': font,
+          'font-size': 14,
+          fill: spec.typography.color,
+          'text-anchor': 'middle',
+          'data-mark': 'colorbar-tick-label',
+          'data-value': tick.value
+        }));
+      });
+    }
+
+    async function loadSpec() {
+      try {
+        const response = await fetch('reference-07-cross-region-small-multiples-D.json', {cache: 'no-store'});
+        if (!response.ok) throw new Error(`HTTP ${response.status}`);
+        return await response.json();
+      } catch (error) {
+        throw new Error(`Unable to load adjacent JSON spec: ${error.message}`);
+      }
+    }
+
+    function setMode(showReference) {
+      $('frame').classList.toggle('show-reference', showReference);
+      $('generatedButton').classList.toggle('active', !showReference);
+      $('referenceButton').classList.toggle('active', showReference);
+    }
+
+    $('generatedButton').addEventListener('click', () => setMode(false));
+    $('referenceButton').addEventListener('click', () => setMode(true));
+
+    loadSpec().then(renderSpec).catch(error => {
+      $('surface').textContent = error.message;
+      console.error(error);
+    });
+  </script>
+</body>
+</html>
