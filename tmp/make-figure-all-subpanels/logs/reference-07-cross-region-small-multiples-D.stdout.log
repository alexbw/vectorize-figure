+            'data-column': matrix.columnOrder[columnIndex]
+          }));
+        });
+      });
+
+      svg.appendChild(svgEl('rect', {
+        x: box.x,
+        y: box.y,
+        width: box.width,
+        height: box.height,
+        fill: 'none',
+        stroke: spec.styleTokens.matrixBorder,
+        'stroke-width': 1.1,
+        'data-mark': 'matrix-border'
+      }));
+
+      plot.x.categories.forEach((category, index) => {
+        svg.appendChild(textNode(category.label, {
+          x: (box.x + index * cellW + cellW / 2).toFixed(2),
+          y: plot.x.tickBand.y,
+          'font-family': font,
+          'font-size': plot.x.tickBand.fontSize,
+          fill: category.color,
+          'text-anchor': plot.x.tickBand.anchor,
+          'data-mark': 'category-label',
+          'data-axis': 'x',
+          'data-category': category.label
+        }));
+      });
+
+      plot.y.categories.forEach((category, index) => {
+        svg.appendChild(textNode(category.label, {
+          x: plot.y.tickBand.x,
+          y: (box.y + index * cellH + cellH / 2 + 5).toFixed(2),
+          'font-family': font,
+          'font-size': plot.y.tickBand.fontSize,
+          fill: category.color,
+          'text-anchor': plot.y.tickBand.anchor,
+          'data-mark': 'category-label',
+          'data-axis': 'y',
+          'data-category': category.label
+        }));
+      });
+
+      const gradient = svgEl('linearGradient', {
+        id: 'pearson-r-gradient',
+        x1: '0%',
+        x2: '100%',
+        y1: '0%',
+        y2: '0%'
+      });
+      colorStops.forEach((color, index) => {
+        gradient.appendChild(svgEl('stop', {
+          offset: `${index / (colorStops.length - 1) * 100}%`,
+          'stop-color': color
+        }));
+      });
+      defs.appendChild(gradient);
+
+      const colorbar = panel.colorbar;
+      svg.appendChild(textNode(colorbar.title.text, {
+        x: colorbar.title.x,
+        y: colorbar.title.y,
+        'font-family': font,
+        'font-size': colorbar.title.fontSize,
