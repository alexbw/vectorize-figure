+      for (const tick of bar.ticks) {
+        const y = bar.bbox.y + (1 - tick.value) * bar.bbox.height;
+        svg.appendChild(el('line', {x1: bar.bbox.x + bar.bbox.width, y1: y, x2: bar.bbox.x + bar.bbox.width + 4, y2: y, stroke: '#333333', 'stroke-width': 0.8, 'data-colorbar-tick': tick.value}));
+        addText(svg, tick.label, bar.bbox.x + bar.bbox.width + 9, y + 4, {size: 12});
+      }
+    }
+
+    function render(spec) {
+      document.getElementById('title').textContent = spec.id;
+      const frame = document.getElementById('frame');
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      document.getElementById('reference').src = spec.source.path;
+
+      const surface = document.getElementById('surface');
+      surface.innerHTML = '';
+      const canvas = document.createElement('canvas');
+      canvas.className = 'heatmap-layer';
+      canvas.width = spec.canvas.width;
+      canvas.height = spec.canvas.height;
+      surface.appendChild(canvas);
+      renderHeatmaps(spec, canvas);
+
+      const svg = el('svg', {viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`, width: spec.canvas.width, height: spec.canvas.height, role: 'img', 'aria-label': spec.id});
+      svg.style.backgroundColor = 'transparent';
+      svg.appendChild(el('defs'));
+      renderLegend(svg, spec);
+      addText(svg, 'F', 160, 32, {size: 22, weight: 700, class: 'panel-label'});
+      addText(svg, 'Crosss-validated confusion matrices', 192, 32, {size: 17, weight: 700, class: 'figure-title'});
+      addText(svg, '(movement epoch)', 459, 32, {size: 15, class: 'figure-title'});
+      spec.panels.forEach((panel, index) => renderMatrixAxes(svg, spec, panel, index));
+      addText(svg, 'True dir. (deg)', 174, 147, {size: 15, rotate: -90, anchor: 'middle', class: 'axis-title'});
+      addText(svg, 'Predicted dir. (deg)', 405, 258, {size: 16, anchor: 'middle', class: 'axis-title'});
+      renderColorbar(svg, spec);
+      surface.appendChild(svg);
+    }
+
+    async function boot() {
+      const response = await fetch(SPEC_PATH);
+      const spec = await response.json();
+      render(spec);
+      const frame = document.getElementById('frame');
+      const generatedButton = document.getElementById('generatedButton');
+      const referenceButton = document.getElementById('referenceButton');
+      generatedButton.addEventListener('click', () => {
+        frame.classList.remove('show-reference');
+        generatedButton.classList.add('active');
+        referenceButton.classList.remove('active');
+      });
+      referenceButton.addEventListener('click', () => {
+        frame.classList.add('show-reference');
+        referenceButton.classList.add('active');
+        generatedButton.classList.remove('active');
+      });
+    }
+
+    boot().catch(error => {
+      document.getElementById('surface').textContent = `Unable to load reconstruction JSON: ${error.message}`;
+      console.error(error);
+    });
+  </script>
+</body>
+</html>
