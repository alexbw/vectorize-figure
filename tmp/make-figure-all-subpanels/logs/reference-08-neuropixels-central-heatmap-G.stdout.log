+      brain.connectors.forEach(c => svg.appendChild(make('polyline', { points: c.points.map(p => p.join(',')).join(' '), fill: 'none', stroke: '#9a9a9a', 'stroke-width': 1, 'stroke-dasharray': c.dasharray })));
+      const heat = top.find(o => o.id === 'partial-heatmap');
+      renderHeatmap(canvas, heat);
+      const g = canvas.getContext('2d');
+      const cb = heat.colorbar;
+      const grad = g.createLinearGradient(0, cb.y + cb.height, 0, cb.y);
+      cb.colors.forEach((c, i) => grad.addColorStop(i / (cb.colors.length - 1), c));
+      g.fillStyle = grad; g.fillRect(cb.x, cb.y, cb.width, cb.height);
+      line(svg, heat.axisLine);
+      heat.colorbar.tickLabels.forEach(l => text(svg, {fontSize: 14, ...l}));
+      heat.labels.forEach(l => text(svg, l));
+    }
+    function renderAxes(svg, panel) {
+      const plot = panel.plot, box = plot.dataBbox;
+      line(svg, {...plot.axes.xAxis.line, stroke: '#222222', strokeWidth: 1.2});
+      line(svg, {...plot.axes.yAxis.line, stroke: '#222222', strokeWidth: 1.2});
+      plot.x.ticks.forEach(t => {
+        const x = scale(plot.x.domain, [box.x, box.x + box.width], t.value);
+        line(svg, {x1: x, y1: plot.axes.xAxis.line.y1, x2: x, y2: plot.axes.xAxis.line.y1 + plot.axes.xAxis.tickLength, stroke: '#222222', strokeWidth: 1});
+        text(svg, {text: t.label, x, y: plot.axes.xAxis.line.y1 + 22, fontSize: 16, anchor: 'middle'});
+      });
+      plot.y.ticks.forEach(t => {
+        const y = scale(plot.y.domain, [box.y + box.height, box.y], t.value);
+        line(svg, {x1: plot.axes.yAxis.line.x1 - plot.axes.yAxis.tickLength, y1: y, x2: plot.axes.yAxis.line.x1, y2: y, stroke: '#222222', strokeWidth: 1});
