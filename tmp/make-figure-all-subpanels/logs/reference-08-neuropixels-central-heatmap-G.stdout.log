+  <script>
+    const SVG_NS = 'http://www.w3.org/2000/svg';
+    const $ = id => document.getElementById(id);
+    const make = (tag, attrs = {}) => {
+      const node = document.createElementNS(SVG_NS, tag);
+      for (const [key, value] of Object.entries(attrs)) if (value !== undefined && value !== null) node.setAttribute(key, value);
+      return node;
+    };
+    const clamp = (value, min, max) => Math.max(min, Math.min(max, value));
+    const scale = (domain, range, value) => range[0] + (value - domain[0]) / (domain[1] - domain[0]) * (range[1] - range[0]);
+    function rng(seed) {
+      return function random() {
+        let t = seed += 0x6D2B79F5;
+        t = Math.imul(t ^ (t >>> 15), t | 1);
+        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
+        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
+      };
+    }
+    function hexToRgb(hex) {
+      const n = parseInt(hex.slice(1), 16);
+      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
+    }
+    function mix(a, b, t) {
+      const ar = hexToRgb(a), br = hexToRgb(b);
+      return `rgb(${Math.round(ar[0] + (br[0] - ar[0]) * t)},${Math.round(ar[1] + (br[1] - ar[1]) * t)},${Math.round(ar[2] + (br[2] - ar[2]) * t)})`;
+    }
+    function text(svg, obj) {
+      const node = make('text', {
+        x: obj.x, y: obj.y, fill: obj.fill || '#111111', 'font-size': obj.fontSize || 14,
+        'font-weight': obj.fontWeight || 400, 'text-anchor': obj.anchor || 'start',
+        'dominant-baseline': obj.baseline || 'alphabetic',
+        transform: obj.rotation ? `rotate(${obj.rotation} ${obj.x} ${obj.y})` : null
+      });
+      node.textContent = obj.text;
+      svg.appendChild(node);
+    }
+    function path(svg, obj) {
+      svg.appendChild(make('path', { d: obj.d, fill: obj.fill || 'none', stroke: obj.stroke || 'none', 'stroke-width': obj.strokeWidth || 1, opacity: obj.opacity, 'stroke-dasharray': obj.dasharray }));
+    }
+    function line(svg, obj) {
+      svg.appendChild(make('line', { x1: obj.x1, y1: obj.y1, x2: obj.x2, y2: obj.y2, stroke: obj.stroke || '#111111', 'stroke-width': obj.strokeWidth || 1, 'stroke-dasharray': obj.dasharray }));
+    }
+    function renderHeatmap(canvas, obj) {
+      const ctx = canvas.getContext('2d');
+      const {x, y, width, height} = obj.bbox;
+      const rows = obj.matrix.rows, cols = obj.matrix.cols, rand = rng(obj.matrix.seed);
+      const cw = width / cols, rh = height / rows;
+      ctx.fillStyle = obj.matrix.base;
+      ctx.fillRect(x, y, width, height);
+      for (let r = 0; r < rows; r++) {
+        for (let c = 0; c < cols; c++) {
+          const band = Math.exp(-Math.pow((r - rows * (0.28 + 0.16 * Math.sin(c / 22))) / 5.5, 2));
+          const streak = (Math.sin(c / 7 + r * 0.6) + 1) * 0.12;
+          const impulse = rand() < obj.matrix.speckle ? rand() * 0.75 : 0;
+          const t = clamp(band * 0.55 + streak + impulse, 0, 1);
+          ctx.fillStyle = mix(obj.matrix.base, obj.matrix.hot, t);
+          ctx.fillRect(x + c * cw, y + r * rh, Math.ceil(cw) + 0.2, Math.ceil(rh) + 0.2);
+        }
+      }
+    }
+    function interpAnchors(anchors, x) {
+      for (let i = 1; i < anchors.length; i++) {
+        if (x <= anchors[i][0]) {
+          const a = anchors[i - 1], b = anchors[i], t = (x - a[0]) / (b[0] - a[0]);
+          return a[1] + (b[1] - a[1]) * t;
+        }
+      }
+      return anchors[anchors.length - 1][1];
+    }
+    function lineSeriesPath(plot, recipe, series) {
+      const box = plot.dataBbox, rand = rng(series.noiseSeed);
+      const xMap = v => scale(plot.x.domain, [box.x, box.x + box.width], v);
+      const yMap = v => scale(plot.y.domain, [box.y + box.height, box.y], v);
+      const count = recipe.xValues.count;
+      const pts = [];
+      for (let i = 0; i < count; i++) {
+        const x = recipe.xValues.start + (recipe.xValues.end - recipe.xValues.start) * i / (count - 1);
+        const wobble = (rand() - 0.5) * 2 * (series.noise || 0);
+        pts.push([xMap(x), yMap(clamp(interpAnchors(series.anchors, x) + wobble, 0, 1))]);
+      }
+      return pts.map((p, i) => `${i ? 'L' : 'M'}${p[0].toFixed(1)} ${p[1].toFixed(1)}`).join(' ');
+    }
+    function renderTop(svg, canvas, panel) {
+      const top = panel.layoutObjects;
+      const probe = top.find(o => o.id === 'probe-layer-legend');
+      svg.appendChild(make('polygon', { points: probe.probe.outline.map(p => p.join(',')).join(' '), fill: '#ffffff', stroke: '#111111', 'stroke-width': 1.2 }));
+      probe.probe.segments.forEach(s => svg.appendChild(make('rect', { x: 29, y: s.y1, width: 10, height: s.y2 - s.y1, fill: s.fill, stroke: 'none' })));
+      probe.probe.dashConnectors.forEach(c => svg.appendChild(make('polyline', { points: c.from.join(',') + ' ' + c.to.join(','), fill: 'none', stroke: '#8a8a8a', 'stroke-width': 1, 'stroke-dasharray': '3 4' })));
