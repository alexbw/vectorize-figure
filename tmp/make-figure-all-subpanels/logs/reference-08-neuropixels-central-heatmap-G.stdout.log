+      });
+      text(svg, plot.x.label);
+      text(svg, plot.y.label);
+    }
+    function renderChart(svg, panel) {
+      text(svg, panel.label);
+      text(svg, panel.title);
+      renderAxes(svg, panel);
+      const group = make('g', {'data-mark-type': 'lineSeriesGroup'});
+      panel.data.series.forEach(s => {
