+        "font-size": 14,
+        fill: "#111",
+        "text-anchor": "middle",
+        "data-object": "table-header"
+      }, "95% CI");
+
+      const candidate = document.getElementById("candidate");
+      candidate.replaceChildren(svg);
+    }
+
+    async function loadSpec() {
+      try {
+        const response = await fetch("reference-07-cross-region-small-multiples-E.json");
