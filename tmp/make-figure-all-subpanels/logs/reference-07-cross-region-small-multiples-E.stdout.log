+      }
+
+      addText(svg, {
+        x: 326,
+        y: 72,
+        "font-size": 14,
+        "font-style": "italic",
+        fill: "#111",
+        "text-anchor": "middle",
+        "data-object": "table-header"
+      }, "d");
+      addText(svg, {
+        x: 382,
