+<body>
+  <div class="toolbar">
+    <label><input id="qa-toggle" type="checkbox"> Show QA reference image</label>
+    <span>Generated SVG candidate from editable JSON</span>
+  </div>
+  <div class="stage">
+    <div id="candidate" class="figure-frame" aria-label="generated reconstruction"></div>
+    <div id="qa-reference" class="qa-reference" aria-label="QA reference only">
+      <div class="label">QA reference only: source raster, not part of generated candidate</div>
