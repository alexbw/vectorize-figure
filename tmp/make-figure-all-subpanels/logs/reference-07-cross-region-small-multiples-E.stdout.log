+          stroke: "none",
+          "data-row": row.id,
+          "data-mark": "effect-point"
+        }));
+        addText(svg, {
+          x: 326,
+          y: row.y + 5,
+          "font-size": 14,
+          fill: "#111",
+          "text-anchor": "middle",
+          "data-row": row.id,
+          "data-column": "d"
+        }, row.d.toFixed(2));
+        const lo = row.ci[0].toFixed(2).replace("-", "\u2212");
+        const hi = row.ci[1].toFixed(2).replace("-", "\u2212");
+        addText(svg, {
+          x: 382,
+          y: row.y + 5,
+          "font-size": 14,
+          fill: "#111",
+          "text-anchor": "middle",
+          "data-row": row.id,
+          "data-column": "ci"
+        }, `[${lo}, ${hi}]`);
+      }
+
+      addText(svg, {
+        x: 326,
+        y: 72,
+        "font-size": 14,
+        "font-style": "italic",
+        fill: "#111",
+        "text-anchor": "middle",
+        "data-object": "table-header"
+      }, "d");
+      addText(svg, {
+        x: 382,
+        y: 72,
+        "font-size": 14,
+        fill: "#111",
+        "text-anchor": "middle",
+        "data-object": "table-header"
+      }, "95% CI");
+
+      const candidate = document.getElementById("candidate");
+      candidate.replaceChildren(svg);
+    }
+
+    async function loadSpec() {
+      try {
+        const response = await fetch("reference-07-cross-region-small-multiples-E.json");
+        if (!response.ok) throw new Error(`HTTP ${response.status}`);
+        return await response.json();
+      } catch (error) {
+        if (fallbackSpec) return fallbackSpec;
+        throw error;
+      }
+    }
+
+    document.getElementById("qa-toggle").addEventListener("change", event => {
+      document.getElementById("qa-reference").classList.toggle("visible", event.target.checked);
+    });
+
+    loadSpec().then(renderFigure).catch(error => {
+      document.getElementById("candidate").textContent = `Unable to load JSON spec: ${error.message}`;
+    });
+  </script>
+</body>
+</html>
