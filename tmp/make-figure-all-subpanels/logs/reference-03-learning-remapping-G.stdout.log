+      display: none;
+      width: 100%;
+      height: 100%;
+      object-fit: contain;
+      background-color: #ffffff;
+    }
+
+    .show-reference .surface {
+      display: none;
+    }
+
+    .show-reference .reference {
+      display: block;
+    }
+
+    svg {
+      position: absolute;
+      inset: 0;
+      overflow: visible;
+    }
+  </style>
+</head>
+<body>
+  <header>
+    <div>
+      <h1 id="title">reference-03-learning-remapping-G</h1>
+      <div class="note">Generated candidate is rendered from JSON. Source image is QA-only.</div>
+    </div>
+    <div class="toggle" aria-label="View mode">
+      <button id="generatedButton" class="active" type="button">Generated</button>
+      <button id="referenceButton" type="button">Reference</button>
+    </div>
+  </header>
+
+  <main>
+    <div id="frame" class="frame">
+      <div id="surface" class="surface"></div>
+      <img id="reference" class="reference" alt="QA reference source image">
+    </div>
+  </main>
+
+  <script>
+    const SVG_NS = 'http://www.w3.org/2000/svg';
+
+    function $(id) {
+      return document.getElementById(id);
+    }
+
+    function make(tag, attrs = {}) {
+      const node = document.createElementNS(SVG_NS, tag);
+      for (const [key, value] of Object.entries(attrs)) {
+        if (value !== undefined && value !== null) node.setAttribute(key, value);
+      }
+      return node;
+    }
+
+    function renderText(svg, item, defaults = {}) {
+      const text = make('text', {
+        id: item.id,
+        'data-type': item.type || 'text',
+        x: item.x,
+        y: item.y,
+        fill: item.fill || defaults.fill || '#111111',
+        'font-family': item.fontFamily || defaults.fontFamily,
+        'font-size': item.fontSize || defaults.fontSize,
+        'font-weight': item.fontWeight || defaults.fontWeight || 400,
+        'font-style': item.fontStyle || defaults.fontStyle || 'normal',
+        'text-anchor': item.anchor || 'start',
+        'dominant-baseline': item.dominantBaseline || 'alphabetic'
+      });
+      text.textContent = item.text;
+      svg.appendChild(text);
+    }
+
+    function renderTextBlock(svg, block, defaults = {}) {
+      let currentY = block.anchor.y;
+      for (const line of block.lines) {
+        if (line.dy !== undefined) currentY = block.anchor.y + line.dy;
+        renderText(svg, {
+          ...line,
+          type: 'text',
+          x: block.anchor.x,
+          y: currentY,
+          anchor: line.anchor || 'start'
+        }, defaults);
+        currentY += line.lineGap || block.lineGap || 20;
+      }
+    }
+
+    function renderRule(svg, rule) {
+      svg.appendChild(make('line', {
+        id: rule.id,
+        'data-type': 'rule',
+        x1: rule.x1,
+        y1: rule.y1,
+        x2: rule.x2,
+        y2: rule.y2,
+        stroke: rule.stroke || '#888888',
+        'stroke-width': rule.strokeWidth || 1,
+        'shape-rendering': 'crispEdges'
+      }));
+    }
+
+    async function loadSpec() {
+      const url = new URL('reference-03-learning-remapping-G.json', window.location.href);
+      const response = await fetch(url);
+      if (!response.ok) throw new Error(`Could not load ${url}`);
+      return response.json();
+    }
+
+    function render(spec) {
+      document.title = `${spec.id} reconstruction`;
+      $('title').textContent = spec.id;
+
+      const frame = $('frame');
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      frame.style.backgroundColor = spec.canvas.background;
+
+      const reference = $('reference');
+      reference.src = spec.source.path;
+
+      const surface = $('surface');
+      surface.innerHTML = '';
+      const svg = make('svg', {
+        id: 'generated-svg',
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`,
+        role: 'img',
+        'aria-label': `${spec.id} generated reconstruction`
+      });
+      svg.style.backgroundColor = spec.canvas.background;
+      surface.appendChild(svg);
+
+      const defaults = {
+        fontFamily: spec.typography.fontFamily,
+        fontSize: spec.typography.defaultSize,
+        fill: spec.typography.color
+      };
+
+      for (const panel of spec.panels) {
+        const group = make('g', {'id': panel.id, 'data-panel-type': panel.type});
+        svg.appendChild(group);
+        renderText(group, panel.label, defaults);
+        renderText(group, panel.title, defaults);
+        for (const object of panel.layoutObjects || []) {
+          if (object.type === 'textBlock') renderTextBlock(group, object, defaults);
+          if (object.type === 'rule') renderRule(group, object);
+          if (object.type === 'text') renderText(group, object, defaults);
+        }
+      }
+    }
+
+    function setMode(mode) {
+      const referenceMode = mode === 'reference';
+      $('frame').classList.toggle('show-reference', referenceMode);
+      $('generatedButton').classList.toggle('active', !referenceMode);
+      $('referenceButton').classList.toggle('active', referenceMode);
+    }
+
+    $('generatedButton').addEventListener('click', () => setMode('generated'));
+    $('referenceButton').addEventListener('click', () => setMode('reference'));
+
+    loadSpec().then(render).catch(error => {
+      const surface = $('surface');
+      surface.textContent = error.message;
+      surface.style.padding = '16px';
+      surface.style.boxSizing = 'border-box';
+      console.error(error);
+    });
+  </script>
+</body>
+</html>
