+          id: `region-label-${row.region}`,
+          text: row.region,
+          x: rowLabels.x,
+          y: rowPosition[row.region] + 5,
+          fill: row.color,
+          fontSize: rowLabels.fontSize,
+          fontWeight: rowLabels.fontWeight,
+          anchor: rowLabels.anchor
+        }, {fontFamily, type: 'region-label'});
+      });
+      svg.appendChild(labelGroup);
+
+      const forestGroup = svgNode('g', {'id': 'region-model-fit-marks', 'data-layer': 'forest-marks'});
+      const markSpec = panel.marks.find(mark => mark.id === 'region-model-fit-marks');
+      rows.forEach(row => {
+        const y = rowPosition[row.region];
+        const low = xScale(row.ciLow);
+        const high = xScale(row.ciHigh);
+        const point = xScale(row.estimate);
+        forestGroup.appendChild(svgNode('line', {
+          id: `ci-${row.region}`,
+          x1: low,
+          y1: y,
+          x2: high,
+          y2: y,
+          stroke: row.color,
+          'stroke-width': markSpec.errorBar.strokeWidth,
+          'data-object-type': 'confidence-interval',
+          'data-region': row.region
+        }));
+        forestGroup.appendChild(svgNode('line', {
+          id: `ci-low-cap-${row.region}`,
+          x1: low,
+          y1: y - markSpec.errorBar.capHeight / 2,
+          x2: low,
+          y2: y + markSpec.errorBar.capHeight / 2,
+          stroke: row.color,
+          'stroke-width': markSpec.errorBar.strokeWidth
+        }));
+        forestGroup.appendChild(svgNode('line', {
+          id: `ci-high-cap-${row.region}`,
+          x1: high,
+          y1: y - markSpec.errorBar.capHeight / 2,
+          x2: high,
+          y2: y + markSpec.errorBar.capHeight / 2,
+          stroke: row.color,
+          'stroke-width': markSpec.errorBar.strokeWidth
+        }));
+        forestGroup.appendChild(svgNode('circle', {
+          id: `estimate-point-${row.region}`,
+          cx: point,
+          cy: y,
+          r: markSpec.point.radius,
+          fill: row.color,
+          stroke: row.color,
+          'data-object-type': 'point-estimate',
+          'data-region': row.region,
+          'data-estimate': row.estimate
+        }));
+      });
+      svg.appendChild(forestGroup);
+
+      const estimateGroup = svgNode('g', {'id': 'estimate-text', 'data-layer': 'estimate-labels'});
+      rows.forEach(row => {
+        addText(estimateGroup, {
+          id: `estimate-text-${row.region}`,
+          text: row.labelText,
+          x: estimateLabels.x,
+          y: rowPosition[row.region] + 5,
+          fontSize: estimateLabels.fontSize,
+          fontWeight: estimateLabels.fontWeight,
+          anchor: estimateLabels.anchor
+        }, {fontFamily, type: 'estimate-label'});
+      });
+      svg.appendChild(estimateGroup);
+    }
+
+    async function loadSpec() {
+      const response = await fetch('reference-07-cross-region-small-multiples-G.json');
+      if (!response.ok) throw new Error(`Could not load JSON spec: ${response.status}`);
+      return response.json();
+    }
+
+    function setMode(mode) {
+      const frame = $('frame');
+      const generated = mode === 'generated';
+      frame.classList.toggle('show-reference', !generated);
+      $('generatedButton').classList.toggle('active', generated);
+      $('referenceButton').classList.toggle('active', !generated);
+    }
+
+    $('generatedButton').addEventListener('click', () => setMode('generated'));
+    $('referenceButton').addEventListener('click', () => setMode('reference'));
+
+    loadSpec().then(render).catch(error => {
+      $('surface').textContent = error.message;
+      console.error(error);
+    });
+  </script>
+</body>
+</html>
