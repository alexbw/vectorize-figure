@@ -0,0 +1,394 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>reference-07-cross-region-small-multiples-G reconstruction</title>
+  <style>
+    html, body {
+      margin: 0;
+      background: #eeeeee;
+      color: #111111;
+      font-family: Arial, Helvetica, sans-serif;
+    }
+
+    header {
+      display: flex;
+      align-items: center;
+      justify-content: space-between;
+      gap: 16px;
+      padding: 10px 14px;
+      background: #ffffff;
+      border-bottom: 1px solid #cfcfcf;
+    }
+
+    h1 {
+      margin: 0;
+      font-size: 15px;
+      font-weight: 700;
+    }
+
+    .note {
+      margin-top: 3px;
+      font-size: 12px;
+      color: #555555;
+    }
+
+    .toggle {
+      display: inline-flex;
+      border: 1px solid #aaaaaa;
+      border-radius: 4px;
+      overflow: hidden;
+      flex: 0 0 auto;
+    }
+
+    .toggle button {
+      border: 0;
+      padding: 5px 10px;
+      background: #ffffff;
+      color: #111111;
+      font: inherit;
+      font-size: 12px;
+      cursor: pointer;
+    }
+
+    .toggle button.active {
+      background: #111111;
+      color: #ffffff;
+    }
+
+    main {
+      min-height: calc(100vh - 48px);
+      display: grid;
+      place-items: center;
+      padding: 16px;
+      box-sizing: border-box;
+    }
+
+    .frame {
+      position: relative;
+      background: #ffffff;
+      border: 1px solid #d0d0d0;
+      box-shadow: 0 1px 5px rgba(0, 0, 0, 0.08);
+      overflow: hidden;
+    }
+
+    .surface,
+    .reference-wrap {
+      position: absolute;
+      inset: 0;
+    }
+
+    .reference-wrap {
+      display: none;
+      background: #ffffff;
+    }
+
+    .reference-wrap img {
+      width: 100%;
+      height: 100%;
+      object-fit: contain;
+      display: block;
+    }
+
+    .reference-label {
+      position: absolute;
+      top: 6px;
+      left: 6px;
+      padding: 2px 5px;
+      background: rgba(255, 255, 255, 0.92);
+      border: 1px solid #888888;
+      font-size: 10px;
+      font-weight: 700;
+    }
+
+    .show-reference .surface {
+      display: none;
+    }
+
+    .show-reference .reference-wrap {
+      display: block;
+    }
+
+    svg {
+      position: absolute;
+      inset: 0;
+      overflow: hidden;
+    }
+  </style>
+</head>
+<body>
+  <header>
+    <div>
+      <h1 id="title">Panel G reconstruction</h1>
+      <div class="note">Generated candidate is rendered from JSON. Source image is QA-only.</div>
+    </div>
+    <div class="toggle" aria-label="View mode">
+      <button id="generatedButton" class="active" type="button">Generated</button>
+      <button id="referenceButton" type="button">Reference</button>
+    </div>
+  </header>
+
+  <main>
+    <div id="frame" class="frame">
+      <div id="surface" class="surface"></div>
+      <div id="referenceWrap" class="reference-wrap">
+        <img id="reference" alt="QA reference source image">
+        <div class="reference-label">QA reference only</div>
+      </div>
+    </div>
+  </main>
+
+  <script>
+    const SVG_NS = 'http://www.w3.org/2000/svg';
+
+    function $(id) {
+      return document.getElementById(id);
+    }
+
+    function svgNode(tag, attrs = {}) {
+      const node = document.createElementNS(SVG_NS, tag);
+      for (const [key, value] of Object.entries(attrs)) {
+        if (value !== undefined && value !== null) node.setAttribute(key, value);
+      }
+      return node;
+    }
+
+    function linear(domain, range, value) {
+      return range[0] + (value - domain[0]) / (domain[1] - domain[0]) * (range[1] - range[0]);
+    }
+
+    function addText(parent, spec, fallback = {}) {
+      const node = svgNode('text', {
+        id: spec.id,
+        x: spec.x,
+        y: spec.y,
+        fill: spec.fill || fallback.fill || '#111111',
+        'font-family': spec.fontFamily || fallback.fontFamily,
+        'font-size': spec.fontSize || fallback.fontSize || 12,
+        'font-weight': spec.fontWeight || fallback.fontWeight || 400,
+        'text-anchor': spec.anchor || fallback.anchor || 'start',
+        'dominant-baseline': spec.dominantBaseline || fallback.dominantBaseline || 'alphabetic',
+        'data-object-type': spec.type || fallback.type || 'text'
+      });
+      node.textContent = spec.text;
+      parent.appendChild(node);
+      return node;
+    }
+
+    function render(spec) {
+      document.title = `${spec.id} reconstruction`;
+      $('title').textContent = 'Panel G reconstruction';
+
+      const frame = $('frame');
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+
+      const reference = $('reference');
+      reference.src = spec.source.path;
+
+      const surface = $('surface');
+      surface.replaceChildren();
+
+      const svg = svgNode('svg', {
+        id: `${spec.id}-svg`,
+        viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`,
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        role: 'img',
+        'aria-label': 'Generated reconstruction of panel G'
+      });
+      surface.appendChild(svg);
+
+      svg.appendChild(svgNode('rect', {
+        id: 'canvas-background',
+        x: 0,
+        y: 0,
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        fill: spec.canvas.background,
+        'data-layer': 'background'
+      }));
+
+      const panel = spec.panels[0];
+      const plot = panel.plot;
+      const xScale = value => linear(plot.x.domain, [plot.dataBbox.x, plot.dataBbox.x + plot.dataBbox.width], value);
+      const rowPosition = Object.fromEntries(spec.coordinateSystems.find(cs => cs.id === 'panel-g.rows').categories.map(name => {
+        return [name, spec.coordinateSystems.find(cs => cs.id === 'panel-g.rows').positions[name]];
+      }));
+      const fontFamily = spec.typography.fontFamily;
+
+      const fragmentsGroup = svgNode('g', {'id': 'left-clipped-neighbor-remnants', 'data-layer': 'clipped-neighbor-remnants'});
+      panel.layoutObjects[0].fragments.forEach((fragment, index) => {
+        fragmentsGroup.appendChild(svgNode('path', {
+          id: `left-fragment-${index + 1}`,
+          d: `M ${fragment.x + fragment.width} ${fragment.y} H ${fragment.x} V ${fragment.y + fragment.height} H ${fragment.x + fragment.width}`,
+          fill: 'none',
+          stroke: spec.rendering.styleTokens.fragmentStroke,
+          'stroke-width': 1,
+          'data-object-type': 'adjacent-panel-fragment'
+        }));
+      });
+      svg.appendChild(fragmentsGroup);
+
+      addText(svg, panel.plot.x.label, {fontFamily, fontSize: 13, anchor: 'middle', type: 'axis-label'});
+      addText(svg, panel.label, {fontFamily, type: 'panel-label'});
+      addText(svg, panel.title, {fontFamily, type: 'panel-title'});
+
+      const axisGroup = svgNode('g', {'id': 'panel-g-x-axis', 'data-layer': 'axis'});
+      axisGroup.appendChild(svgNode('line', {
+        id: 'panel-g-x-axis-line',
+        x1: plot.x.axisLine.x1,
+        y1: plot.x.axisLine.y1,
+        x2: plot.x.axisLine.x2,
+        y2: plot.x.axisLine.y2,
+        stroke: spec.rendering.styleTokens.axisStroke,
+        'stroke-width': 1.3
+      }));
+      plot.x.ticks.forEach((tick, index) => {
+        const x = xScale(tick.value);
+        axisGroup.appendChild(svgNode('line', {
+          id: `panel-g-x-tick-${index}`,
+          x1: x,
+          y1: plot.x.axisLine.y1,
+          x2: x,
+          y2: plot.x.axisLine.y1 + plot.x.tickLength,
+          stroke: spec.rendering.styleTokens.tickStroke,
+          'stroke-width': 1,
+          'data-axis': 'x',
+          'data-value': tick.value
+        }));
+        addText(axisGroup, {
+          id: `panel-g-x-tick-${index}-label`,
+          text: tick.label,
+          x,
+          y: plot.x.axisLine.y1 + 17,
+          fontSize: 12,
+          anchor: 'middle'
+        }, {fontFamily, type: 'axis-tick-label'});
+      });
+      svg.appendChild(axisGroup);
+
+      const referenceGroup = svgNode('g', {'id': 'reference-lines', 'data-layer': 'reference-lines'});
+      plot.referenceLines.forEach(line => {
+        referenceGroup.appendChild(svgNode('line', {
+          id: line.id,
+          x1: line.x,
+          y1: line.y1,
+          x2: line.x,
+          y2: line.y2,
+          stroke: line.stroke,
+          'stroke-width': line.strokeWidth,
+          'stroke-dasharray': line.dasharray,
+          'data-value': line.value
+        }));
+      });
+      svg.appendChild(referenceGroup);
+
+      const rows = panel.data.series[0].rows;
+      const rowLabels = panel.annotations.find(item => item.id === 'region-labels');
+      const estimateLabels = panel.annotations.find(item => item.id === 'estimate-text');
+      const labelGroup = svgNode('g', {'id': 'region-labels', 'data-layer': 'row-labels'});
+      rows.forEach(row => {
+        addText(labelGroup, {
+          id: `region-label-${row.region}`,
+          text: row.region,
+          x: rowLabels.x,
+          y: rowPosition[row.region] + 5,
+          fill: row.color,
+          fontSize: rowLabels.fontSize,
+          fontWeight: rowLabels.fontWeight,
+          anchor: rowLabels.anchor
+        }, {fontFamily, type: 'region-label'});
+      });
+      svg.appendChild(labelGroup);
+
+      const forestGroup = svgNode('g', {'id': 'region-model-fit-marks', 'data-layer': 'forest-marks'});
+      const markSpec = panel.marks.find(mark => mark.id === 'region-model-fit-marks');
+      rows.forEach(row => {
+        const y = rowPosition[row.region];
+        const low = xScale(row.ciLow);
+        const high = xScale(row.ciHigh);
+        const point = xScale(row.estimate);
+        forestGroup.appendChild(svgNode('line', {
+          id: `ci-${row.region}`,
+          x1: low,
+          y1: y,
+          x2: high,
+          y2: y,
+          stroke: row.color,
+          'stroke-width': markSpec.errorBar.strokeWidth,
+          'data-object-type': 'confidence-interval',
+          'data-region': row.region
+        }));
+        forestGroup.appendChild(svgNode('line', {
+          id: `ci-low-cap-${row.region}`,
+          x1: low,
+          y1: y - markSpec.errorBar.capHeight / 2,
+          x2: low,
+          y2: y + markSpec.errorBar.capHeight / 2,
+          stroke: row.color,
+          'stroke-width': markSpec.errorBar.strokeWidth
+        }));
+        forestGroup.appendChild(svgNode('line', {
+          id: `ci-high-cap-${row.region}`,
+          x1: high,
+          y1: y - markSpec.errorBar.capHeight / 2,
+          x2: high,
+          y2: y + markSpec.errorBar.capHeight / 2,
+          stroke: row.color,
+          'stroke-width': markSpec.errorBar.strokeWidth
+        }));
+        forestGroup.appendChild(svgNode('circle', {
+          id: `estimate-point-${row.region}`,
+          cx: point,
+          cy: y,
+          r: markSpec.point.radius,
+          fill: row.color,
+          stroke: row.color,
+          'data-object-type': 'point-estimate',
+          'data-region': row.region,
+          'data-estimate': row.estimate
+        }));
+      });
+      svg.appendChild(forestGroup);
+
+      const estimateGroup = svgNode('g', {'id': 'estimate-text', 'data-layer': 'estimate-labels'});
+      rows.forEach(row => {
+        addText(estimateGroup, {
+          id: `estimate-text-${row.region}`,
+          text: row.labelText,
+          x: estimateLabels.x,
+          y: rowPosition[row.region] + 5,
+          fontSize: estimateLabels.fontSize,
+          fontWeight: estimateLabels.fontWeight,
+          anchor: estimateLabels.anchor
+        }, {fontFamily, type: 'estimate-label'});
+      });
+      svg.appendChild(estimateGroup);
+    }
+
+    async function loadSpec() {
+      const response = await fetch('reference-07-cross-region-small-multiples-G.json');
+      if (!response.ok) throw new Error(`Could not load JSON spec: ${response.status}`);
+      return response.json();
+    }
+
+    function setMode(mode) {
+      const frame = $('frame');
+      const generated = mode === 'generated';
+      frame.classList.toggle('show-reference', !generated);
+      $('generatedButton').classList.toggle('active', generated);
+      $('referenceButton').classList.toggle('active', !generated);
+    }
+
+    $('generatedButton').addEventListener('click', () => setMode('generated'));
+    $('referenceButton').addEventListener('click', () => setMode('reference'));
+
+    loadSpec().then(render).catch(error => {
+      $('surface').textContent = error.message;
+      console.error(error);
+    });
+  </script>
+</body>
+</html>
