+        renderRows(svg, panel, typography);
+        renderColorbar(svg, panel, typography);
+      }
+    }
+
+    async function loadSpec() {
+      try {
+        const response = await fetch('./reference-07-cross-region-small-multiples-A.json');
+        if (!response.ok) throw new Error(`HTTP ${response.status}`);
+        return response.json();
+      } catch (error) {
+        console.warn('Using embedded fallback spec because JSON fetch failed.', error);
+        return JSON.parse(el('fallback-spec').textContent);
+      }
+    }
+
+    function setupToggle(frame) {
+      const generated = el('generatedButton');
+      const reference = el('referenceButton');
+      generated.addEventListener('click', () => {
+        frame.classList.remove('show-reference');
+        generated.classList.add('active');
+        reference.classList.remove('active');
+      });
+      reference.addEventListener('click', () => {
+        frame.classList.add('show-reference');
+        reference.classList.add('active');
+        generated.classList.remove('active');
+      });
+    }
+
+    async function main() {
+      const spec = await loadSpec();
+      document.title = `${spec.id} reconstruction`;
+      el('title').textContent = 'Cross-region population rate map reconstruction';
+
+      const frame = el('frame');
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      frame.style.background = spec.canvas.background || '#ffffff';
+
+      const reference = el('reference');
+      reference.src = spec.source.path;
+
+      const surface = el('surface');
+      surface.innerHTML = '';
+      const canvas = document.createElement('canvas');
+      canvas.width = spec.canvas.width;
+      canvas.height = spec.canvas.height;
+      canvas.setAttribute('aria-label', 'Generated heatmap texture layer');
+      const svg = svgNode('svg', {
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`,
+        role: 'img',
+        'aria-label': 'Generated editable annotation layer'
+      });
+      surface.appendChild(canvas);
+      surface.appendChild(svg);
+
+      renderCanvas(canvas, spec);
+      renderSvg(svg, spec);
+      setupToggle(frame);
+    }
+
+    main();
+  </script>
+</body>
+</html>
