+        {t: 0.42, color: hexToRgb('#5f187f')},
+        {t: 0.72, color: hexToRgb('#d44842')},
+        {t: 1, color: hexToRgb('#fff06a')}
+      ];
+      const t = clamp((value - domain[0]) / (domain[1] - domain[0]), 0, 1);
+      let a = stops[0];
+      let b = stops[stops.length - 1];
+      for (let i = 0; i < stops.length - 1; i += 1) {
+        if (t >= stops[i].t && t <= stops[i + 1].t) {
+          a = stops[i];
+          b = stops[i + 1];
+          break;
+        }
+      }
+      const local = (t - a.t) / (b.t - a.t || 1);
+      return [
+        lerp(a.color[0], b.color[0], local),
+        lerp(a.color[1], b.color[1], local),
+        lerp(a.color[2], b.color[2], local)
+      ];
+    }
+
+    function textAttrs(spec, typography, extra = {}) {
+      return {
+        x: spec.x,
+        y: spec.y,
+        fill: spec.fill || typography.color || '#111111',
+        'font-family': spec.fontFamily || typography.fontFamily,
+        'font-size': spec.fontSize || typography.defaultSize || 12,
+        'font-weight': spec.fontWeight || 400,
+        'text-anchor': spec.anchor || 'start',
+        transform: spec.rotation ? `rotate(${spec.rotation} ${spec.x} ${spec.y})` : undefined,
+        ...extra
+      };
+    }
+
+    function addText(svg, spec, typography, className) {
+      const text = svgNode('text', textAttrs(spec, typography, {id: spec.id, class: className}));
+      String(spec.text || '').split('\n').forEach((line, index) => {
+        const tspan = svgNode('tspan', {
+          x: spec.x,
+          dy: index === 0 ? 0 : `${spec.lineHeight || 1.05}em`
+        });
+        tspan.textContent = line;
+        text.appendChild(tspan);
+      });
+      svg.appendChild(text);
+      return text;
+    }
+
+    function bandDistance(column, row, band, columns, rows) {
+      const x0 = band.x0 / 300 * (columns - 1);
+      const x1 = band.x1 / 300 * (columns - 1);
+      const y0 = band.y0 / Math.max(rows, 1) * (rows - 1);
+      const y1 = band.y1 / Math.max(rows, 1) * (rows - 1);
+      const dx = x1 - x0;
+      const dy = y1 - y0;
+      const denom = dx * dx + dy * dy || 1;
+      const t = clamp(((column - x0) * dx + (row - y0) * dy) / denom, 0, 1);
+      const px = x0 + dx * t;
+      const py = y0 + dy * t;
+      return Math.hypot(column - px, row - py);
+    }
+
+    function heatValue(rowSpec, column, row, randomValues) {
+      const matrix = rowSpec.matrix;
+      const recipe = rowSpec.recipe;
+      const xCm = column / (matrix.columns - 1) * 300;
+      let value = recipe.base;
+      value += (randomValues.noise - 0.5) * recipe.noise * 2;
+      value += Math.sin(row * 1.9 + randomValues.phase * 3.1) * recipe.rowStripe;
+      value += Math.sin(column * 0.43 + randomValues.phase * 9.0) * recipe.verticalTexture;
+      for (const spot of recipe.hotspots || []) {
+        const dx = (xCm - spot.x) / spot.sx;
+        const dy = (row - spot.y) / spot.sy;
+        value += spot.amp * Math.exp(-0.5 * (dx * dx + dy * dy));
+      }
+      for (const band of recipe.bands || []) {
+        const distance = bandDistance(column, row, band, matrix.columns, matrix.rows);
+        value += band.amp * Math.exp(-0.5 * Math.pow(distance / band.width, 2));
+      }
+      return clamp(value, matrix.zDomain[0], matrix.zDomain[1]);
+    }
+
+    function renderHeatmap(ctx, rowSpec) {
+      const matrix = rowSpec.matrix;
+      const box = rowSpec.bbox;
+      const rand = rng(rowSpec.recipe.seed);
+      const cellW = box.width / matrix.columns;
+      const cellH = box.height / matrix.rows;
+      ctx.save();
+      ctx.beginPath();
+      ctx.rect(box.x, box.y, box.width, box.height);
+      ctx.clip();
+      ctx.fillStyle = '#090619';
+      ctx.fillRect(box.x, box.y, box.width, box.height);
+      for (let r = 0; r < matrix.rows; r += 1) {
+        for (let c = 0; c < matrix.columns; c += 1) {
+          const value = heatValue(rowSpec, c, r, {noise: rand(), phase: rand()});
+          ctx.fillStyle = rgbToCss(colorRamp(value, matrix.zDomain));
+          ctx.globalAlpha = 0.92;
+          ctx.fillRect(box.x + c * cellW, box.y + r * cellH, Math.ceil(cellW) + 0.4, Math.ceil(cellH) + 0.4);
+        }
+      }
+      for (let i = 0; i < 160; i += 1) {
+        const x = box.x + rand() * box.width;
+        const y = box.y + rand() * box.height;
+        ctx.fillStyle = rand() > 0.45 ? 'rgba(255, 229, 80, 0.45)' : 'rgba(255, 91, 53, 0.30)';
+        ctx.fillRect(x, y, 1 + rand() * 6, 0.7 + rand() * 1.8);
+      }
+      ctx.restore();
+    }
+
+    function renderCanvas(canvas, spec) {
+      const ctx = canvas.getContext('2d');
+      ctx.fillStyle = spec.canvas.background;
+      ctx.fillRect(0, 0, spec.canvas.width, spec.canvas.height);
+      for (const panel of spec.panels || []) {
+        for (const row of panel.heatmapRows || []) renderHeatmap(ctx, row);
+      }
+    }
+
+    function renderTopAxis(svg, panel, typography) {
+      const plot = panel.plot;
+      const rowTop = panel.heatmapRows[0].bbox.y;
+      const rowLeft = panel.heatmapRows[0].bbox.x;
+      const rowRight = rowLeft + panel.heatmapRows[0].bbox.width;
+      addText(svg, plot.x.label, typography, 'axis-label');
+      for (const tick of plot.x.ticks) {
+        const x = scale(plot.x.domain, [rowLeft, rowRight], tick.value);
+        svg.appendChild(svgNode('line', {
+          id: `x-tick-${tick.value}`,
+          class: 'x-axis-tick',
+          x1: x,
+          y1: rowTop - 5,
+          x2: x,
+          y2: rowTop,
+          stroke: '#111111',
+          'stroke-width': 1
+        }));
+        addText(svg, {
+          id: `x-tick-label-${tick.value}`,
+          text: tick.label,
+          x,
+          y: rowTop - 9,
+          fontSize: 14,
+          anchor: 'middle'
+        }, typography, 'tick-label');
+      }
+    }
+
+    function renderRows(svg, panel, typography) {
+      for (const row of panel.heatmapRows || []) {
+        const box = row.bbox;
+        svg.appendChild(svgNode('rect', {
+          id: `${row.id}-plot-border`,
+          class: 'heatmap-border',
+          x: box.x,
+          y: box.y,
+          width: box.width,
+          height: box.height,
+          fill: 'none',
+          stroke: '#111111',
+          'stroke-width': 0.7
+        }));
+        addText(svg, {
+          id: `${row.id}-region-label`,
+          text: row.region,
+          x: 22,
+          y: box.y + 19,
+          fontSize: 16,
+          fill: row.labelColor,
+          anchor: 'start'
+        }, typography, 'region-label');
+        addText(svg, {
+          id: `${row.id}-count-label`,
+          text: `n=${row.nCells}`,
+          x: 21,
+          y: box.y + 37,
+          fontSize: 13,
+          fill: '#111111',
+          anchor: 'start'
+        }, typography, 'cell-count');
+      }
+    }
+
+    function renderHeaders(svg, panel, typography) {
+      addText(svg, panel.label, typography, 'panel-label');
+      addText(svg, panel.title, typography, 'panel-title');
+      addText(svg, panel.plot.leftHeader, typography, 'axis-header');
+      addText(svg, panel.plot.rightHeader, typography, 'axis-header');
+    }
+
+    function renderColorbar(svg, panel, typography) {
+      const cb = panel.colorbar;
+      const gradientId = `${cb.id}-gradient`;
+      const defs = svgNode('defs');
+      const gradient = svgNode('linearGradient', {id: gradientId, x1: '0%', y1: '0%', x2: '100%', y2: '0%'});
+      [
+        ['0%', '#090619'],
+        ['42%', '#5f187f'],
+        ['72%', '#d44842'],
+        ['100%', '#fff06a']
+      ].forEach(([offset, color]) => gradient.appendChild(svgNode('stop', {'offset': offset, 'stop-color': color})));
+      defs.appendChild(gradient);
+      svg.appendChild(defs);
+      svg.appendChild(svgNode('rect', {
+        id: cb.id,
+        x: cb.bbox.x,
+        y: cb.bbox.y,
+        width: cb.bbox.width,
+        height: cb.bbox.height,
+        fill: `url(#${gradientId})`,
+        stroke: '#555555',
+        'stroke-width': 0.8
+      }));
+      for (const tick of cb.ticks) {
+        const x = scale(cb.domain, [cb.bbox.x, cb.bbox.x + cb.bbox.width], tick.value);
+        svg.appendChild(svgNode('line', {
+          id: `${cb.id}-tick-${tick.value}`,
+          x1: x,
+          y1: cb.bbox.y + cb.bbox.height,
+          x2: x,
+          y2: cb.bbox.y + cb.bbox.height + 4,
+          stroke: '#111111',
+          'stroke-width': 0.8
+        }));
+        addText(svg, {
+          id: `${cb.id}-tick-label-${tick.value}`,
+          text: tick.label,
+          x,
+          y: cb.bbox.y + cb.bbox.height + 21,
+          fontSize: 14,
+          anchor: 'middle'
