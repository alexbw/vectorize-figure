+          class: 'x-axis-tick',
+          x1: x,
+          y1: rowTop - 5,
+          x2: x,
+          y2: rowTop,
+          stroke: '#111111',
+          'stroke-width': 1
+        }));
+        addText(svg, {
+          id: `x-tick-label-${tick.value}`,
+          text: tick.label,
+          x,
+          y: rowTop - 9,
+          fontSize: 14,
+          anchor: 'middle'
+        }, typography, 'tick-label');
+      }
+    }
+
+    function renderRows(svg, panel, typography) {
+      for (const row of panel.heatmapRows || []) {
+        const box = row.bbox;
+        svg.appendChild(svgNode('rect', {
+          id: `${row.id}-plot-border`,
+          class: 'heatmap-border',
+          x: box.x,
+          y: box.y,
+          width: box.width,
+          height: box.height,
+          fill: 'none',
+          stroke: '#111111',
+          'stroke-width': 0.7
+        }));
+        addText(svg, {
+          id: `${row.id}-region-label`,
+          text: row.region,
+          x: 22,
+          y: box.y + 19,
+          fontSize: 16,
+          fill: row.labelColor,
+          anchor: 'start'
+        }, typography, 'region-label');
+        addText(svg, {
+          id: `${row.id}-count-label`,
+          text: `n=${row.nCells}`,
+          x: 21,
+          y: box.y + 37,
+          fontSize: 13,
+          fill: '#111111',
+          anchor: 'start'
+        }, typography, 'cell-count');
+      }
+    }
+
+    function renderHeaders(svg, panel, typography) {
+      addText(svg, panel.label, typography, 'panel-label');
+      addText(svg, panel.title, typography, 'panel-title');
+      addText(svg, panel.plot.leftHeader, typography, 'axis-header');
+      addText(svg, panel.plot.rightHeader, typography, 'axis-header');
+    }
+
+    function renderColorbar(svg, panel, typography) {
+      const cb = panel.colorbar;
+      const gradientId = `${cb.id}-gradient`;
+      const defs = svgNode('defs');
+      const gradient = svgNode('linearGradient', {id: gradientId, x1: '0%', y1: '0%', x2: '100%', y2: '0%'});
+      [
+        ['0%', '#090619'],
+        ['42%', '#5f187f'],
+        ['72%', '#d44842'],
+        ['100%', '#fff06a']
+      ].forEach(([offset, color]) => gradient.appendChild(svgNode('stop', {'offset': offset, 'stop-color': color})));
+      defs.appendChild(gradient);
+      svg.appendChild(defs);
+      svg.appendChild(svgNode('rect', {
+        id: cb.id,
+        x: cb.bbox.x,
+        y: cb.bbox.y,
+        width: cb.bbox.width,
+        height: cb.bbox.height,
+        fill: `url(#${gradientId})`,
+        stroke: '#555555',
+        'stroke-width': 0.8
+      }));
+      for (const tick of cb.ticks) {
+        const x = scale(cb.domain, [cb.bbox.x, cb.bbox.x + cb.bbox.width], tick.value);
+        svg.appendChild(svgNode('line', {
+          id: `${cb.id}-tick-${tick.value}`,
+          x1: x,
+          y1: cb.bbox.y + cb.bbox.height,
+          x2: x,
+          y2: cb.bbox.y + cb.bbox.height + 4,
+          stroke: '#111111',
+          'stroke-width': 0.8
+        }));
+        addText(svg, {
+          id: `${cb.id}-tick-label-${tick.value}`,
+          text: tick.label,
+          x,
+          y: cb.bbox.y + cb.bbox.height + 21,
+          fontSize: 14,
+          anchor: 'middle'
+        }, typography, 'colorbar-tick-label');
+      }
+      addText(svg, cb.label, typography, 'colorbar-label');
+    }
+
+    function renderSvg(svg, spec) {
+      const typography = spec.typography || {};
+      for (const panel of spec.panels || []) {
+        renderHeaders(svg, panel, typography);
+        renderTopAxis(svg, panel, typography);
+        renderRows(svg, panel, typography);
+        renderColorbar(svg, panel, typography);
+      }
+    }
+
+    async function loadSpec() {
+      try {
+        const response = await fetch('./reference-07-cross-region-small-multiples-A.json');
+        if (!response.ok) throw new Error(`HTTP ${response.status}`);
+        return response.json();
+      } catch (error) {
+        console.warn('Using embedded fallback spec because JSON fetch failed.', error);
+        return JSON.parse(el('fallback-spec').textContent);
+      }
+    }
+
+    function setupToggle(frame) {
+      const generated = el('generatedButton');
+      const reference = el('referenceButton');
+      generated.addEventListener('click', () => {
+        frame.classList.remove('show-reference');
+        generated.classList.add('active');
+        reference.classList.remove('active');
+      });
+      reference.addEventListener('click', () => {
+        frame.classList.add('show-reference');
+        reference.classList.add('active');
+        generated.classList.remove('active');
+      });
+    }
+
+    async function main() {
+      const spec = await loadSpec();
+      document.title = `${spec.id} reconstruction`;
+      el('title').textContent = 'Cross-region population rate map reconstruction';
+
+      const frame = el('frame');
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      frame.style.background = spec.canvas.background || '#ffffff';
+
+      const reference = el('reference');
+      reference.src = spec.source.path;
+
+      const surface = el('surface');
+      surface.innerHTML = '';
+      const canvas = document.createElement('canvas');
+      canvas.width = spec.canvas.width;
+      canvas.height = spec.canvas.height;
+      canvas.setAttribute('aria-label', 'Generated heatmap texture layer');
+      const svg = svgNode('svg', {
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`,
+        role: 'img',
+        'aria-label': 'Generated editable annotation layer'
+      });
+      surface.appendChild(canvas);
+      surface.appendChild(svg);
+
+      renderCanvas(canvas, spec);
+      renderSvg(svg, spec);
+      setupToggle(frame);
+    }
+
+    main();
+  </script>
+</body>
+</html>
