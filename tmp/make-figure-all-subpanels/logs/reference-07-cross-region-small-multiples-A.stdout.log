  <script>
    const SVG_NS = 'http://www.w3.org/2000/svg';

    function el(id) {
      return document.getElementById(id);
    }

    function svgNode(tag, attrs = {}) {
      const node = document.createElementNS(SVG_NS, tag);
      for (const [key, value] of Object.entries(attrs)) {
        if (value !== undefined && value !== null) node.setAttribute(key, value);
      }
      return node;
    }

    function rng(seed) {
      return function random() {
        let t = seed += 0x6D2B79F5;
        t = Math.imul(t ^ (t >>> 15), t | 1);
        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
      };
    }

    function scale(domain, range, value) {
      return range[0] + (value - domain[0]) / (domain[1] - domain[0]) * (range[1] - range[0]);
    }

    function transforms(plot) {
      const box = plot.dataBbox;
      return {
        x: value => scale(plot.x.domain, [box.x, box.x + box.width], value),
        y: value => scale(plot.y.domain, [box.y + box.height, box.y], value)
      };
    }

    function textAttrs(spec, typography, extra = {}) {
      return {
        x: spec.x,
        y: spec.y,
        fill: spec.fill || typography.color || '#111111',
        'font-family': spec.fontFamily || typography.fontFamily,
        'font-size': spec.fontSize || typography.defaultSize || 12,
        'font-weight': spec.fontWeight || 400,
        'text-anchor': spec.anchor || 'start',
        transform: spec.rotation ? `rotate(${spec.rotation} ${spec.x} ${spec.y})` : undefined,
        ...extra
      };
    }

    function addText(svg, spec, typography, className) {
      const text = svgNode('text', textAttrs(spec, typography, {id: spec.id, class: className}));
      const lines = String(spec.text || '').split('\n');
      lines.forEach((line, index) => {
        const tspan = svgNode('tspan', {
          x: spec.x,
          dy: index === 0 ? 0 : `${(spec.lineHeight || 1.1)}em`
        });
        tspan.textContent = line;
        text.appendChild(tspan);
      });
      svg.appendChild(text);
      return text;
    }

    function generatedPoints(mark) {
      const recipe = mark.recipe;
      const rand = rng(recipe.seed);
      const points = [];
      for (let i = 0; i < recipe.backgroundCount; i += 1) {
        points.push([
          recipe.positionDomain[0] + rand() * (recipe.positionDomain[1] - recipe.positionDomain[0]),
          recipe.rowDomain[0] + rand() * (recipe.rowDomain[1] - recipe.rowDomain[0])
        ]);
      }
      for (const band of recipe.bands || []) {
        for (let i = 0; i < band.count; i += 1) {
          const t = rand();
          const x = band.start[0] + (band.end[0] - band.start[0]) * t + (rand() - 0.5) * 2 * band.jitterX;
          const y = band.start[1] + (band.end[1] - band.start[1]) * t + (rand() - 0.5) * 2 * band.jitterY;
          points.push([x, y]);
        }
      }
      return points;
    }

    function renderRasterMarks(ctx, panel) {
      const map = transforms(panel.plot);
      for (const mark of panel.marks || []) {
        if (mark.type !== 'raster') continue;
        ctx.save();
        if (mark.clipToPlot) {
          const b = panel.plot.dataBbox;
          ctx.beginPath();
          ctx.rect(b.x, b.y, b.width, b.height);
          ctx.clip();
        }
        ctx.globalAlpha = mark.opacity || 1;
        ctx.fillStyle = mark.color;
        const radius = mark.markerRadius || 1.2;
        for (const point of generatedPoints(mark)) {
          ctx.beginPath();
          ctx.arc(map.x(point[0]), map.y(point[1]), radius, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.restore();
      }
    }

    function renderAxes(svg, panel, typography) {
      const plot = panel.plot;
      const map = transforms(plot);
      const axisStyle = {stroke: '#111111', 'stroke-width': 1.1, fill: 'none', 'shape-rendering': 'crispEdges'};
      svg.appendChild(svgNode('line', {...axisStyle, ...plot.axes.xAxis.line, id: plot.axes.xAxis.id}));
      svg.appendChild(svgNode('line', {...axisStyle, ...plot.axes.yAxis.line, id: plot.axes.yAxis.id}));

