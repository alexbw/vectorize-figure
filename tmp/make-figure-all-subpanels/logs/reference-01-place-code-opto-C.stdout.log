      const rasterPlot = panel.rasterPlot;
      const axisY = rasterPlot.axisY;
      const axisX1 = rasterPlot.bbox.x;
      const axisX2 = rasterPlot.bbox.x + rasterPlot.bbox.width;
      const eventX = rasterX(rasterPlot, panel.event.time);

      svg.appendChild(textNode({...panel.event.label, id: 'event-label'}, defaults));
      line(svg, {x1: eventX, y1: 68, x2: eventX, y2: axisY + 7, stroke: panel.event.color, strokeWidth: 1.4, dasharray: '4 4', role: 'event-line-raster'});

      for (const group of rasterPlot.groups) {
        drawRaster(ctx, group, rasterPlot);
      }

      line(svg, {x1: axisX1, y1: axisY, x2: axisX2, y2: axisY, strokeWidth: 1.4, role: 'raster-x-axis'});

      for (const tick of rasterPlot.ticks) {
        const x = rasterX(rasterPlot, tick.value);
        line(svg, {x1: x, y1: axisY, x2: x, y2: axisY + 7, strokeWidth: 1.4, role: 'raster-x-tick'});
        const tickId = numericTickId('raster-tick', tick.label);
        svg.appendChild(textNode({id: tickId, text: tick.label, x, y: axisY + 21, fontSize: 16, anchor: 'middle'}, defaults));
      }

      svg.appendChild(textNode({...rasterPlot.xLabel, id: 'raster-x-label'}, defaults));

      const control = rasterPlot.groups[0];
      const opto = rasterPlot.groups[1];
      svg.appendChild(textNode({id: 'control-label', text: control.label, x: 44, y: 92, fontSize: 14, anchor: 'middle', fill: control.labelColor}, defaults));
      svg.appendChild(textNode({id: 'control-n', text: control.sampleLabel, x: 44, y: 136, fontSize: 14, anchor: 'middle', fill: '#111111'}, defaults));
      svg.appendChild(textNode({id: 'opto-label', text: opto.label, x: 44, y: 195, fontSize: 14, anchor: 'middle', fill: opto.labelColor}, defaults));
      svg.appendChild(textNode({id: 'opto-n', text: opto.sampleLabel, x: 44, y: 254, fontSize: 14, anchor: 'middle', fill: '#111111'}, defaults));
    }

    function renderLinePanel(svg, panel, defaults) {
      const plot = panel.linePlot;
      const box = plot.bbox;
      const eventX = xScale(plot, panel.event.time);

      for (const series of plot.series) {
        svg.appendChild(svgNode('path', {
          d: bandPath(series, plot),
          fill: series.bandFill,
          stroke: 'none',
          'data-mark-id': `${series.id}-band`,
          'data-role': 'uncertainty-band'
        }));
      }

      for (const series of plot.series) {
        svg.appendChild(svgNode('path', {
          d: pathFromPoints(series.points, plot),
          fill: 'none',
          stroke: series.stroke,
          'stroke-width': series.strokeWidth || 3,
          'stroke-linecap': 'round',
          'stroke-linejoin': 'round',
          'data-mark-id': series.id,
          'data-role': 'line-series'
        }));
      }

      line(svg, {x1: eventX, y1: box.y - 4, x2: eventX, y2: box.y + box.height + 6, stroke: panel.event.color, strokeWidth: 1.4, dasharray: '4 4', role: 'event-line-mean'});
      line(svg, {x1: box.x, y1: box.y + box.height, x2: box.x + box.width, y2: box.y + box.height, strokeWidth: 1.4, role: 'line-x-axis'});
      line(svg, {x1: box.x, y1: box.y, x2: box.x, y2: box.y + box.height, strokeWidth: 1.4, role: 'line-y-axis'});

      for (const tick of plot.x.ticks) {
        const x = xScale(plot, tick.value);
        line(svg, {x1: x, y1: box.y + box.height, x2: x, y2: box.y + box.height + 7, strokeWidth: 1.4, role: 'line-x-tick'});
        const tickId = numericTickId('line-tick', tick.label);
        svg.appendChild(textNode({id: tickId, text: tick.label, x, y: box.y + box.height + 24, fontSize: 16, anchor: 'middle'}, defaults));
      }

      for (const tick of plot.y.ticks) {
        const y = yScale(plot, tick.value);
        line(svg, {x1: box.x - 6, y1: y, x2: box.x, y2: y, strokeWidth: 1.4, role: 'line-y-tick'});
        svg.appendChild(textNode({id: `line-y-tick-${tick.label}`, text: tick.label, x: box.x - 10, y: y + 5, fontSize: 16, anchor: 'end'}, defaults));
      }

      svg.appendChild(textNode({...plot.x.label, id: 'line-x-label'}, defaults));
      svg.appendChild(textNode({...plot.y.label, id: 'line-y-label'}, defaults));

      rect(svg, {
        x: plot.lightBar.x,
        y: plot.lightBar.y,
        width: plot.lightBar.width,
        height: plot.lightBar.height,
        fill: plot.lightBar.fill,
        role: 'light-bar'
      });
      svg.appendChild(textNode({...plot.lightBar.label, id: 'light-on'}, defaults));

      for (const item of plot.legend) {
        const series = plot.series.find(candidate => candidate.id === item.seriesId);
        if (!series) continue;
        line(svg, {x1: item.x, y1: item.y, x2: item.x + 28, y2: item.y, stroke: series.stroke, strokeWidth: 3, linecap: 'round', role: 'legend-line'});
        const id = series.id === 'control-mean' ? 'legend-control' : 'legend-opto';
        svg.appendChild(textNode({id, text: series.label, x: item.textX, y: item.textY, fontSize: 13, anchor: 'start'}, defaults));
      }
    }

    function render(spec) {
      const frame = byId('frame');
      const surface = byId('surface');
      const reference = byId('reference');
      const canvasSpec = spec.canvas;
      const defaults = spec.typography || {};
      activeTextCalibration = Object.assign({}, ...(spec.panels || []).map(panel => panel.textCalibration || {}));

      byId('title').textContent = spec.id;
      document.title = `${spec.id} reconstruction`;
      frame.style.width = `${canvasSpec.width}px`;
      frame.style.height = `${canvasSpec.height}px`;
      frame.style.background = canvasSpec.background || '#ffffff';
      surface.innerHTML = '';
      reference.src = spec.source.path;

      const canvas = document.createElement('canvas');
      canvas.width = canvasSpec.width;
      canvas.height = canvasSpec.height;
      surface.appendChild(canvas);
      const ctx = canvas.getContext('2d');

      const svg = svgNode('svg', {
        width: canvasSpec.width,
        height: canvasSpec.height,
        viewBox: `0 0 ${canvasSpec.width} ${canvasSpec.height}`,
        role: 'img',
        'aria-label': `${spec.id} generated reconstruction`
      });
      surface.appendChild(svg);

      for (const panel of spec.panels) {
        const group = svgNode('g', {'data-panel-id': panel.id, 'data-role': panel.type});
        svg.appendChild(group);
        group.appendChild(textNode({...panel.label, id: 'panel-label'}, defaults));
        group.appendChild(textNode({...panel.title, id: 'panel-title'}, defaults));
        renderRasterPanel(group, ctx, panel, defaults);
        renderLinePanel(group, panel, defaults);
      }

      const afterFonts = document.fonts && document.fonts.ready ? document.fonts.ready : Promise.resolve();
      afterFonts.then(() => applyTextFits(svg));
    }

    byId('generatedButton').onclick = () => {
      byId('frame').classList.remove('show-reference');
      byId('generatedButton').classList.add('active');
      byId('referenceButton').classList.remove('active');
    };

    byId('referenceButton').onclick = () => {
      byId('frame').classList.add('show-reference');
      byId('referenceButton').classList.add('active');
      byId('generatedButton').classList.remove('active');
    };

    fetch(SPEC_URL)
      .then(response => response.json())
      .then(render)
      .catch(error => {
        byId('surface').textContent = `Failed to load ${SPEC_URL}: ${error.message}`;
      });
  </script>
