    function rect(svg, attrs) {
      svg.appendChild(svgNode('rect', {
        x: attrs.x,
        y: attrs.y,
        width: attrs.width,
        height: attrs.height,
        fill: attrs.fill || 'none',
        stroke: attrs.stroke || 'none',
        'stroke-width': attrs.strokeWidth,
        'data-role': attrs.role || 'rect'
      }));
    }

    function scale(domain, range, value) {
      return range[0] + (value - domain[0]) / (domain[1] - domain[0]) * (range[1] - range[0]);
    }

    function xScale(plot, value) {
      return scale(plot.x.domain, [plot.bbox.x, plot.bbox.x + plot.bbox.width], value);
    }

    function yScale(plot, value) {
      return scale(plot.y.domain, [plot.bbox.y + plot.bbox.height, plot.bbox.y], value);
    }

    function rasterX(rasterPlot, value) {
      const box = rasterPlot.bbox;
      return scale(rasterPlot.domain, [box.x, box.x + box.width], value);
    }

    function pathFromPoints(points, plot) {
      return points.map((point, index) => {
        const command = index === 0 ? 'M' : 'L';
        return `${command}${xScale(plot, point[0]).toFixed(2)} ${yScale(plot, point[1]).toFixed(2)}`;
      }).join(' ');
    }

    function bandPath(series, plot) {
      const halfWidth = series.bandHalfWidth || 1;
      const upper = series.points.map(point => [point[0], point[1] + halfWidth]);
      const lower = series.points.slice().reverse().map(point => [point[0], point[1] - halfWidth]);
      const all = upper.concat(lower);
      return all.map((point, index) => {
        const command = index === 0 ? 'M' : 'L';
        return `${command}${xScale(plot, point[0]).toFixed(2)} ${yScale(plot, point[1]).toFixed(2)}`;
      }).join(' ') + ' Z';
    }

    function rng(seed) {
      return function random() {
        let t = seed += 0x6D2B79F5;
        t = Math.imul(t ^ (t >>> 15), t | 1);
        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
      };
    }

    function drawRaster(ctx, group, rasterPlot) {
      const random = rng(group.seed);
      const box = group.bbox;
      const eventX = rasterX(rasterPlot, 0) - box.x;
      ctx.save();
      ctx.beginPath();
      ctx.rect(box.x, box.y, box.width, box.height);
      ctx.clip();
      ctx.fillStyle = group.color;

      for (let row = 0; row < group.rows; row += 1) {
        const y = box.y + row / group.rows * box.height + random() * 1.3;
        for (let i = 0; i < group.baselineEvents; i += 1) {
          const x = random() * box.width;
          if (x > eventX && random() < group.postEventDropProbability) continue;
          ctx.globalAlpha = 0.84 + random() * 0.16;
          ctx.fillRect(box.x + x, y, 1.35, 1.35);
        }
      }

      ctx.restore();
      ctx.globalAlpha = 1;
    }

