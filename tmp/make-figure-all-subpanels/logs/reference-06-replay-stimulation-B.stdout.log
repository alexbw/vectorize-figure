+    function clamp(value, min, max) { return Math.max(min, Math.min(max, value)); }
+    function mulberry32(seed) {
+      return function() {
+        seed |= 0; seed = seed + 0x6D2B79F5 | 0;
+        let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
+        t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
+        return ((t ^ t >>> 14) >>> 0) / 4294967296;
+      };
+    }
+    function normal(rand) {
+      const u = Math.max(rand(), 1e-9);
+      const v = Math.max(rand(), 1e-9);
+      return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
+    }
+    function hexToRgb(hex) {
+      return [1, 3, 5].map((i) => parseInt(hex.slice(i, i + 2), 16));
+    }
+    function rgbToHex(rgb) {
+      return "#" + rgb.map((v) => clamp(Math.round(v), 0, 255).toString(16).padStart(2, "0")).join("");
+    }
+    function divergingColor(scale, value) {
+      const stops = scale.stops;
+      const lower = value <= 0 ? stops[0] : stops[1];
+      const upper = value <= 0 ? stops[1] : stops[2];
+      const t = value <= 0 ? (value - scale.domain[0]) / (scale.domain[1] - scale.domain[0]) : (value - scale.domain[1]) / (scale.domain[2] - scale.domain[1]);
+      const a = hexToRgb(lower.color);
