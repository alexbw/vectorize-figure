+        y: obj.y,
+        fill: obj.fill || "#111111",
+        opacity: obj.opacity,
+        "font-size": obj.fontSize,
+        "font-weight": obj.fontWeight || 400,
+        "text-anchor": obj.anchor || "start",
+        "dominant-baseline": obj.baseline || "alphabetic",
+        transform: obj.rotation ? `rotate(${obj.rotation} ${obj.x} ${obj.y})` : null,
