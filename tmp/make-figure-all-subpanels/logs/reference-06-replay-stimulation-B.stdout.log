+      for (let i = 0; i < count; i++) {
+        bands.push({pos: rand() * length, amp: (rand() * 2 - 1) * amplitude, width: width * (0.65 + rand() * 1.1)});
+      }
+      return bands;
+    }
+    function recipeValue(recipe, x, y, rand, xBands, yBands) {
+      const diagY = recipe.diagonal.slope * x + recipe.diagonal.intercept;
