    const SVG_NS = 'http://www.w3.org/2000/svg';

    function $(id) {
      return document.getElementById(id);
    }

    function make(tag, attrs = {}) {
      const node = document.createElementNS(SVG_NS, tag);
      for (const [key, value] of Object.entries(attrs)) {
        if (value !== undefined && value !== null) node.setAttribute(key, value);
      }
      return node;
    }

    function clamp(value, min, max) {
      return Math.max(min, Math.min(max, value));
    }

    function rng(seed) {
      return function random() {
        let t = seed += 0x6D2B79F5;
        t = Math.imul(t ^ (t >>> 15), t | 1);
        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
      };
    }

    function scale(domain, range, value) {
      return range[0] + (value - domain[0]) / (domain[1] - domain[0]) * (range[1] - range[0]);
    }

    function pointScales(plot) {
      const box = plot.bbox;
      return {
        x: value => scale(plot.x.domain, [box.x, box.x + box.width], value),
        y: value => scale(plot.y.domain, [box.y + box.height, box.y], value)
      };
    }

    function appendStylesheet(href) {
      return new Promise(resolve => {
        if (!href) return resolve();
        const existing = document.querySelector(`link[data-font-import="${CSS.escape(href)}"]`);
        if (existing) return resolve();
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = href;
        link.dataset.fontImport = href;
        link.onload = () => resolve();
        link.onerror = () => {
          console.warn(`Font stylesheet failed to load: ${href}`);
          resolve();
        };
        document.head.appendChild(link);
      });
    }


