+
+    .toggle button.active {
+      background: #111111;
+      color: #ffffff;
+    }
+
+    main {
+      display: grid;
+      place-items: center;
+      min-height: calc(100vh - 55px);
+      padding: 18px;
+      box-sizing: border-box;
+    }
+
+    .frame {
+      position: relative;
+      background: #ffffff;
+      box-shadow: 0 1px 6px rgba(0, 0, 0, 0.12);
+      overflow: hidden;
+    }
+
+    .surface,
