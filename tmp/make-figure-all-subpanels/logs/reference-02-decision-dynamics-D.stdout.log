+      const group = make('g', {'data-layer': 'marks'});
+      panel.marks.forEach(mark => {
+        if (mark.type === 'referenceLine' && mark.orientation === 'horizontal') {
+          const y = sx.y(mark.value);
+          group.appendChild(make('line', {id: mark.id, x1: panel.plot.dataBbox.x, y1: y, x2: panel.plot.dataBbox.x + panel.plot.dataBbox.width, y2: y, stroke: mark.stroke, 'stroke-width': mark.strokeWidth, 'stroke-dasharray': mark.dasharray}));
+        }
+        if (mark.type === 'referenceLine' && mark.orientation === 'vertical') {
+          const x = sx.x(mark.value);
+          group.appendChild(make('line', {id: mark.id, x1: x, y1: sx.y(mark.fromY), x2: x, y2: sx.y(mark.toY), stroke: mark.stroke, 'stroke-width': mark.strokeWidth, 'stroke-dasharray': mark.dasharray}));
+        }
+        if (mark.type === 'lineSeries' && mark.dataRef === 'fitCurve') {
+          const recipe = panel.data.fitCurve;
+          const [min, max] = recipe.sampleDomain;
+          const pts = [];
+          for (let i = 0; i < recipe.sampleCount; i += 1) {
+            const x = min + (max - min) * i / (recipe.sampleCount - 1);
+            pts.push([sx.x(x), sx.y(logistic(x, recipe.parameters))]);
+          }
+          const d = pts.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p[0].toFixed(2)} ${p[1].toFixed(2)}`).join(' ');
+          group.appendChild(make('path', {id: mark.id, d, fill: 'none', stroke: mark.stroke, 'stroke-width': mark.strokeWidth}));
+        }
+        if (mark.type === 'scatterWithErrorBars') {
+          const pts = panel.data[mark.dataRef];
+          pts.forEach((pt, index) => {
+            const x = sx.x(pt.x);
+            const y = sx.y(pt.y);
+            const yLow = sx.y(pt.y - pt.yError);
+            const yHigh = sx.y(pt.y + pt.yError);
+            group.appendChild(make('line', {id: `${mark.id}-error-${index}`, 'data-point-index': index, x1: x, y1: yLow, x2: x, y2: yHigh, stroke: mark.errorBar.stroke, 'stroke-width': mark.errorBar.strokeWidth}));
+            group.appendChild(make('line', {x1: x - mark.errorBar.capWidth / 2, y1: yLow, x2: x + mark.errorBar.capWidth / 2, y2: yLow, stroke: mark.errorBar.stroke, 'stroke-width': mark.errorBar.strokeWidth}));
+            group.appendChild(make('line', {x1: x - mark.errorBar.capWidth / 2, y1: yHigh, x2: x + mark.errorBar.capWidth / 2, y2: yHigh, stroke: mark.errorBar.stroke, 'stroke-width': mark.errorBar.strokeWidth}));
+            group.appendChild(make('circle', {id: `${mark.id}-point-${index}`, 'data-x': pt.x, 'data-y': pt.y, cx: x, cy: y, r: mark.marker.radius, fill: mark.marker.fill, stroke: mark.marker.stroke, 'stroke-width': mark.marker.strokeWidth}));
+          });
+        }
+      });
+      svg.appendChild(group);
+    }
+
+    function render(spec) {
+      $('title').textContent = spec.id;
+      const frame = $('frame');
+      const surface = $('surface');
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      surface.innerHTML = '';
+      const reference = $('reference');
+      reference.src = spec.source.path;
+      reference.dataset.usage = spec.source.usage;
+
+      const svg = make('svg', {width: spec.canvas.width, height: spec.canvas.height, viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`, role: 'img', 'aria-label': `${spec.id} generated reconstruction`});
+      svg.style.background = spec.canvas.background;
+      svg.style.fontFamily = spec.typography.fontFamily;
+      svg.style.color = spec.typography.color;
+      surface.appendChild(svg);
+
+      spec.panels.forEach(panel => {
+        const panelGroup = make('g', {id: panel.id, 'data-panel': panel.id});
+        svg.appendChild(panelGroup);
+        panelGroup.appendChild(textNode(panel.label));
+        panelGroup.appendChild(textNode(panel.title));
+        const sx = scales(panel.plot);
+        renderMarks(panelGroup, panel, sx);
+        renderAxes(panelGroup, panel, sx);
+        const annotations = make('g', {'data-layer': 'annotations'});
+        panel.annotations.forEach(annotation => annotations.appendChild(textNode(annotation)));
+        panelGroup.appendChild(annotations);
+      });
+    }
+
+    async function loadSpec() {
+      const response = await fetch(SPEC_URL);
+      if (!response.ok) throw new Error(`Unable to load ${SPEC_URL}`);
+      return response.json();
+    }
+
+    $('generatedButton').addEventListener('click', () => {
+      $('frame').classList.remove('show-reference');
+      $('generatedButton').classList.add('active');
+      $('referenceButton').classList.remove('active');
+    });
+    $('referenceButton').addEventListener('click', () => {
+      $('frame').classList.add('show-reference');
+      $('referenceButton').classList.add('active');
+      $('generatedButton').classList.remove('active');
+    });
+
+    loadSpec().then(render).catch(error => {
+      console.error(error);
+      $('surface').textContent = error.message;
+    });
+  </script>
+</body>
+</html>
