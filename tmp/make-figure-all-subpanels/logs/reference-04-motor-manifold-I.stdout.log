+      const panel = spec.panels[0];
+      const seriesMap = Object.fromEntries(spec.series.map(s => [s.id, s]));
+      addText(svg, panel.label, spec.typography);
+      addText(svg, panel.title, spec.typography);
+      addText(svg, panel.subtitle, spec.typography);
+      panel.plots.forEach(plot => {
+        renderAxes(svg, plot, spec.typography);
+        renderBoxplots(svg, plot, seriesMap);
+      });
+      renderLegend(svg, panel.legend, seriesMap, spec.typography);
+      surface.appendChild(svg);
+    }
+    function setMode(referenceMode) {
+      byId('frame').classList.toggle('show-reference', referenceMode);
+      byId('generatedButton').classList.toggle('active', !referenceMode);
+      byId('referenceButton').classList.toggle('active', referenceMode);
+    }
+    byId('generatedButton').addEventListener('click', () => setMode(false));
+    byId('referenceButton').addEventListener('click', () => setMode(true));
+    loadSpec().then(render).catch(error => {
+      byId('surface').textContent = error.message;
+      console.error(error);
+    });
+  </script>
+</body>
+</html>
