+  <script>
+    const SPEC_URL = './reference-04-motor-manifold-I.json';
+    const SVG_NS = 'http://www.w3.org/2000/svg';
+
+    function byId(id) { return document.getElementById(id); }
+    function node(tag, attrs = {}) {
+      const el = document.createElementNS(SVG_NS, tag);
+      for (const [key, value] of Object.entries(attrs)) {
+        if (value !== undefined && value !== null) el.setAttribute(key, value);
+      }
+      return el;
+    }
+    function addText(svg, spec, defaults = {}) {
+      const lines = String(spec.text || '').split('\n');
+      const text = node('text', {
+        x: spec.x, y: spec.y, fill: spec.fill || defaults.color || '#111111',
+        'font-family': spec.fontFamily || defaults.fontFamily || 'Arial, Helvetica, sans-serif',
+        'font-size': spec.fontSize || defaults.defaultSize || 12,
+        'font-weight': spec.fontWeight || 400,
+        'text-anchor': spec.anchor || 'start',
+        'dominant-baseline': spec.baseline || 'alphabetic',
+        'letter-spacing': spec.letterSpacing ?? defaults.calibration?.letterSpacing ?? 0,
+        transform: spec.rotation ? `rotate(${spec.rotation} ${spec.x} ${spec.y})` : undefined,
+        'data-id': spec.id || undefined,
+        'data-role': spec.role || 'text'
+      });
+      lines.forEach((line, i) => {
+        const span = node('tspan', {x: spec.x, dy: i === 0 ? 0 : (spec.lineHeight || 14)});
+        span.textContent = line;
+        text.appendChild(span);
+      });
+      svg.appendChild(text);
