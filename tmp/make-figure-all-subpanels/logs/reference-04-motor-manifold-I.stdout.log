+      const pattern = [-0.32, 0.28, -0.15, 0.08, 0.36, -0.38, 0.18, -0.04, 0.42, -0.24, 0.0, 0.24, -0.44];
+      return pattern[i % pattern.length] * 10;
+    }
+    function renderAxes(svg, plot, defaults) {
+      const left = plot.bbox.x;
+      const right = plot.bbox.x + plot.bbox.width;
+      const bottom = plot.bbox.y + plot.bbox.height;
+      svg.appendChild(node('line', {x1: left, y1: plot.bbox.y, x2: left, y2: bottom, stroke: '#111111', 'stroke-width': 1.2, 'data-role': 'y-axis', 'data-plot': plot.id}));
