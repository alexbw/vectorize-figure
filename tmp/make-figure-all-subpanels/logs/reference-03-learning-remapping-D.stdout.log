+      const series = panel.data.series;
+
+      const axesGroup = svgEl('g', {'data-layer': 'axes'});
+      axesGroup.appendChild(svgEl('line', {...plot.axes.xAxis.line, stroke: plot.axes.xAxis.stroke, 'stroke-width': plot.axes.xAxis.strokeWidth}));
+      axesGroup.appendChild(svgEl('line', {...plot.axes.yAxis.line, stroke: plot.axes.yAxis.stroke, 'stroke-width': plot.axes.yAxis.strokeWidth}));
+
+      plot.x.ticks.forEach(tick => {
+        const x = xScale(tick.value);
+        axesGroup.appendChild(svgEl('line', {x1: x, y1: plot.axes.xAxis.line.y1, x2: x, y2: plot.axes.xAxis.line.y1 + plot.axes.xAxis.tickLength, stroke: plot.axes.xAxis.stroke, 'stroke-width': 1}));
+        addText(axesGroup, {text: tick.label, x, y: 367, fontSize: 16, fill: '#111111', anchor: 'middle'});
+      });
+
+      plot.y.ticks.forEach(tick => {
+        const y = yScale(tick.value);
+        axesGroup.appendChild(svgEl('line', {x1: plot.axes.yAxis.line.x1 - plot.axes.yAxis.tickLength, y1: y, x2: plot.axes.yAxis.line.x1, y2: y, stroke: plot.axes.yAxis.stroke, 'stroke-width': 1}));
+        addText(axesGroup, {text: tick.label, x: 66, y: y + 5, fontSize: 16, fill: '#111111', anchor: 'end'});
+      });
+
+      addText(axesGroup, plot.x.label);
+      addText(axesGroup, plot.y.label);
+      svg.appendChild(axesGroup);
+
+      const values = series.map(point => [xScale(point.day), yScale(point.correlation)]);
+      const upper = series.map(point => [xScale(point.day), yScale(point.correlation + point.sem)]);
+      const lower = series.slice().reverse().map(point => [xScale(point.day), yScale(point.correlation - point.sem)]);
+
+      const marksGroup = svgEl('g', {'data-layer': 'marks'});
+      marksGroup.appendChild(svgEl('polygon', {
+        id: 'stability-band',
+        points: formatPoints([...upper, ...lower]),
+        fill: '#8d5fb1',
+        opacity: 0.16
+      }));
+      marksGroup.appendChild(svgEl('polyline', {
+        id: 'stability-line',
+        points: formatPoints(values),
+        fill: 'none',
+        stroke: '#4b0f82',
+        'stroke-width': 2,
+        'stroke-linejoin': 'round',
+        'stroke-linecap': 'round'
+      }));
+
+      series.forEach(point => {
+        const x = xScale(point.day);
+        const y = yScale(point.correlation);
+        const yTop = yScale(point.correlation + point.sem);
+        const yBottom = yScale(point.correlation - point.sem);
+        marksGroup.appendChild(svgEl('line', {x1: x, y1: yTop, x2: x, y2: yBottom, stroke: '#4b0f82', 'stroke-width': 1.4}));
+        marksGroup.appendChild(svgEl('line', {x1: x - 2.5, y1: yTop, x2: x + 2.5, y2: yTop, stroke: '#4b0f82', 'stroke-width': 1.2}));
+        marksGroup.appendChild(svgEl('line', {x1: x - 2.5, y1: yBottom, x2: x + 2.5, y2: yBottom, stroke: '#4b0f82', 'stroke-width': 1.2}));
+        marksGroup.appendChild(svgEl('circle', {cx: x, cy: y, r: 4, fill: '#4b0f82', stroke: '#4b0f82', 'stroke-width': 1, 'data-day': point.day}));
+      });
+      svg.appendChild(marksGroup);
+
+      const textGroup = svgEl('g', {'data-layer': 'annotations'});
+      addText(textGroup, panel.label);
+      addText(textGroup, panel.title);
+      series.forEach(point => {
+        addText(textGroup, {text: point.label, x: xScale(point.day), y: yScale(point.correlation) - 26, fontSize: 14, fill: '#111111', anchor: 'middle'});
+        addText(textGroup, {text: point.n, x: xScale(point.day), y: 327, fontSize: 13, fill: '#111111', anchor: 'middle'});
+      });
+      svg.appendChild(textGroup);
+      surface.appendChild(svg);
+    }
+
+    async function loadSpec() {
+      const response = await fetch('reference-03-learning-remapping-D.json');
+      if (!response.ok) throw new Error(`Could not load JSON spec: ${response.status}`);
+      return response.json();
+    }
+
+    function setMode(mode) {
+      const frame = document.getElementById('frame');
+      const generated = document.getElementById('generated-button');
+      const reference = document.getElementById('reference-button');
+      const showReference = mode === 'reference';
+      frame.classList.toggle('show-reference', showReference);
+      generated.classList.toggle('active', !showReference);
+      reference.classList.toggle('active', showReference);
+    }
+
+    document.getElementById('generated-button').addEventListener('click', () => setMode('generated'));
+    document.getElementById('reference-button').addEventListener('click', () => setMode('reference'));
+
+    loadSpec().then(render).catch(error => {
+      document.getElementById('surface').textContent = error.message;
+      console.error(error);
+    });
+  </script>
+</body>
+</html>
