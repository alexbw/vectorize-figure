+
+      const chanceY = sy(plot.chanceLine.y);
+      el('line', {x1: box.x, y1: chanceY, x2: box.x + box.width, y2: chanceY, stroke: plot.chanceLine.stroke, 'stroke-width': 1.2, 'stroke-dasharray': plot.chanceLine.strokeDasharray});
+
+      const smoothPoints = points => {
+        const dense = [];
+        for (let i = 0; i < points.length - 1; i++) {
+          const a = points[i], b = points[i + 1];
