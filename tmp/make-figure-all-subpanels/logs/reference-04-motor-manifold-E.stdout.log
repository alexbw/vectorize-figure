+      });
+
+      el('line', {x1: box.x, y1: box.y, x2: box.x + box.width, y2: box.y, stroke: '#555', 'stroke-width': 1});
+      el('line', {x1: box.x, y1: box.y + box.height, x2: box.x + box.width, y2: box.y + box.height, stroke: '#111', 'stroke-width': 1});
+      el('line', {x1: box.x, y1: box.y, x2: box.x, y2: box.y + box.height, stroke: '#111', 'stroke-width': 1});
