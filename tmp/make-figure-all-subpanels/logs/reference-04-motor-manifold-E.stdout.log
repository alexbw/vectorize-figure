+          height: box.height,
+          fill: epoch.fill,
+          'data-epoch': epoch.id
+        });
+        text(epoch.label, {x: (sx(epoch.x0) + sx(epoch.x1)) / 2, y: box.y - 10, 'text-anchor': 'middle', class: 'epoch-label'});
+      });
+
+      el('line', {x1: box.x, y1: box.y, x2: box.x + box.width, y2: box.y, stroke: '#555', 'stroke-width': 1});
+      el('line', {x1: box.x, y1: box.y + box.height, x2: box.x + box.width, y2: box.y + box.height, stroke: '#111', 'stroke-width': 1});
+      el('line', {x1: box.x, y1: box.y, x2: box.x, y2: box.y + box.height, stroke: '#111', 'stroke-width': 1});
+
+      const axisGroup = el('g', {class: 'axis'});
+      plot.axes.x.ticks.forEach(tick => {
+        const x = sx(tick.value);
+        el('line', {x1: x, y1: box.y + box.height, x2: x, y2: box.y + box.height + 5, stroke: '#111'}, axisGroup);
+        text(tick.label, {x, y: box.y + box.height + 17, 'text-anchor': 'middle'}, axisGroup);
+      });
+      plot.axes.y.ticks.forEach(tick => {
+        const y = sy(tick.value);
+        el('line', {x1: box.x - 5, y1: y, x2: box.x, y2: y, stroke: '#111'}, axisGroup);
+        text(tick.label, {x: box.x - 10, y, 'text-anchor': 'end'}, axisGroup);
+      });
+      text(plot.axes.x.label.text, {x: box.x + box.width / 2, y: box.y + box.height + plot.axes.x.label.offset, 'text-anchor': 'middle', class: 'axis-title'});
+      text(plot.axes.y.label.text, {x: 80, y: box.y + box.height / 2, transform: `rotate(-90 80 ${box.y + box.height / 2})`, 'text-anchor': 'middle', class: 'axis-title'});
+
+      const chanceY = sy(plot.chanceLine.y);
+      el('line', {x1: box.x, y1: chanceY, x2: box.x + box.width, y2: chanceY, stroke: plot.chanceLine.stroke, 'stroke-width': 1.2, 'stroke-dasharray': plot.chanceLine.strokeDasharray});
+
+      const smoothPoints = points => {
+        const dense = [];
+        for (let i = 0; i < points.length - 1; i++) {
+          const a = points[i], b = points[i + 1];
+          for (let step = 0; step < 8; step++) {
+            const t = step / 8;
+            const x = a[0] + (b[0] - a[0]) * t;
+            const y = a[1] + (b[1] - a[1]) * t + Math.sin((i * 8 + step) * 1.9) * 1.2 + Math.sin((i * 8 + step) * 4.7) * 0.45;
