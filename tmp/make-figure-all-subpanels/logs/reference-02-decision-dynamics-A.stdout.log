+          x1: guide.x,
+          y1: guide.y1,
+          x2: guide.x,
+          y2: guide.y2,
+          stroke: timeline.guideStyle.stroke,
+          'stroke-width': timeline.guideStyle.strokeWidth,
+          'stroke-dasharray': timeline.guideStyle.dasharray,
+          'data-role': 'timeline-guide',
+          'data-event': guide.event
+        }));
+      });
+      timeline.ticks.forEach(tick => {
+        svg.appendChild(node('line', {
+          x1: tick.x,
+          y1: timeline.line.y1,
+          x2: tick.x,
+          y2: timeline.line.y1 + timeline.tickLength,
+          stroke: '#111111',
+          'stroke-width': 1,
+          'data-role': 'timeline-tick',
+          'data-value': tick.value
+        }));
+        addText(svg, {
+          text: tick.label,
+          x: tick.x,
+          y: timeline.line.y1 + 22,
+          anchor: 'middle',
+          fontSize: 14,
+          role: 'timeline-tick-label'
+        }, defaults);
+      });
+      addText(svg, timeline.label, defaults);
+    }
+
+    function drawTable(svg, table, defaults) {
+      table.columns.forEach((column, index) => {
+        const x = table.x + index * table.columnWidth;
+        svg.appendChild(node('rect', {
+          x,
+          y: table.topY,
+          width: table.columnWidth,
+          height: table.headerHeight,
+          fill: '#f7f7f7',
+          stroke: '#d0d0d0',
+          'stroke-width': 0.8,
+          'data-id': `${table.id}-${column.id}-header`
+        }));
+        svg.appendChild(node('line', {
+          x1: x,
+          y1: table.topY,
+          x2: x + table.columnWidth,
+          y2: table.topY,
+          stroke: column.accent,
+          'stroke-width': 2
+        }));
+        addText(svg, {
+          text: column.header,
+          x: x + table.columnWidth / 2,
+          y: table.topY + 23,
+          anchor: 'middle',
+          fontSize: 13
+        }, defaults);
+        if (column.process) {
+          addText(svg, {
+            text: column.process,
+            x: x + table.columnWidth / 2,
+            y: table.topY + table.headerHeight + 27,
+            anchor: 'middle',
+            fontSize: 12
+          }, defaults);
+        }
+        if (column.behavior) {
+          addText(svg, {
+            text: column.behavior,
+            x: x + table.columnWidth / 2,
+            y: table.topY + table.headerHeight + 84,
+            anchor: 'middle',
+            fontSize: 12
+          }, defaults);
+        } else if (column.behaviorRich) {
+          addRichText(svg, x + table.columnWidth / 2, table.topY + table.headerHeight + 84, column.behaviorRich, {...defaults, defaultSize: 12});
+        }
+      });
+    }
+
+    function render(spec) {
+      byId('title').textContent = spec.id;
+      const frame = byId('frame');
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      frame.style.background = spec.canvas.background;
+      byId('reference').src = spec.source.path;
+
+      const surface = byId('surface');
+      surface.innerHTML = '';
+      const svg = node('svg', {
+        viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`,
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        role: 'img',
+        'aria-label': `${spec.id} generated reconstruction`
+      });
+      svg.appendChild(node('rect', {x: 0, y: 0, width: spec.canvas.width, height: spec.canvas.height, fill: spec.canvas.background}));
+      surface.appendChild(svg);
+
+      const defaults = {
+        fontFamily: spec.typography.fontFamily,
+        defaultSize: spec.typography.defaultSize,
+        color: spec.typography.color,
+        calibration: spec.typography.calibration
+      };
+
+      spec.panels.forEach(panel => {
+        addText(svg, panel.label, defaults);
+        addText(svg, panel.title, defaults);
+        panel.epochs.forEach(epoch => {
+          addText(svg, {
+            text: epoch.title,
+            x: epoch.titleX,
+            y: epoch.titleY,
+            anchor: 'middle',
+            fontSize: 14
+          }, defaults);
+          drawScreen(svg, epoch);
+        });
+        drawTimeline(svg, panel, defaults);
+        drawTable(svg, panel.processTable, defaults);
+      });
+    }
+
+    async function boot() {
+      const response = await fetch(SPEC_URL);
+      const spec = await response.json();
+      render(spec);
+      const frame = byId('frame');
+      const generatedButton = byId('generatedButton');
+      const referenceButton = byId('referenceButton');
+      generatedButton.addEventListener('click', () => {
+        frame.classList.remove('show-reference');
+        generatedButton.classList.add('active');
+        referenceButton.classList.remove('active');
+      });
+      referenceButton.addEventListener('click', () => {
+        frame.classList.add('show-reference');
+        referenceButton.classList.add('active');
+        generatedButton.classList.remove('active');
+      });
+    }
+
+    boot().catch(error => {
+      console.error(error);
+      byId('surface').textContent = 'Failed to load reconstruction JSON.';
+    });
+  </script>
+</body>
+</html>
