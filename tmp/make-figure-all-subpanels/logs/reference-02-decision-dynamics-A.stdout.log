+{
+  "schema": "scientific_figure_reconstruction.v1",
+  "id": "reference-02-decision-dynamics-A",
+  "source": {
+    "path": "../../assets/reference/reference-02-decision-dynamics-A-reference.png",
+    "usage": "QA-only; not used by generated candidate.",
+    "notes": "First-pass reconstruction of a single trial-timeline schematic. Source was used for visual inspection only; generated layers are SVG text, lines, rectangles, circles, paths, and synthetic dot recipes."
+  },
+  "canvas": {
+    "width": 430,
+    "height": 514,
+    "background": "#ffffff"
+  },
+  "typography": {
+    "fontFamily": "Arial Narrow, Helvetica Neue, Arial, sans-serif",
+    "defaultSize": 13,
+    "color": "#111111",
+    "calibration": {
+      "letterSpacing": 0,
+      "lineHeight": 1.08,
+      "notes": "Narrow sans-serif selected to approximate compact source labels; no source raster is used during rendering."
+    }
+  },
+  "panels": [
+    {
+      "id": "panel-a",
