+            fill: "none",
+            stroke: region.color,
+            "stroke-width": index === 0 ? groupMark.ridgeStyle.strokeWidth : 0.95,
+            "stroke-opacity": index === 0 ? 1 : 0.72,
+            "stroke-linejoin": "round",
+            "stroke-linecap": "round",
+            "data-region": region.id,
+            "data-ridge-id": ridge.id,
