const cs = spec.coordinateSystems.find((item) => item.id === 'main-x');
function xScale(value) {
  const [d0, d1] = cs.domain, [r0, r1] = cs.range;
  return r0 + ((value - d0) / (d1 - d0)) * (r1 - r0);
}
function gaussian(x, mean, sigma) { const z = (x - mean) / sigma; return Math.exp(-0.5 * z * z); }
let ridgeCount = 0;
for (const region of spec.panels[0].marks[0].regions) {
  if ("'!Number.isFinite(region.baselineY)) throw new Error(`Bad baseline for ${region.id}`);
  for (const ridge of region.ridges) {
    ridgeCount++;
    for (let x = cs.domain[0]; x <= cs.domain[1]; x += 2.5) {
      let y = 0;
      for (const [mean, weight] of ridge.peaks) y += weight * gaussian(x, mean, ridge.width);
      const px = xScale(x), py = region.baselineY - Math.min(1.18, y) * ridge.height;
