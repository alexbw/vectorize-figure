+      });
+      svg.appendChild(make("line", {x1: box.x, y1: box.y + box.height, x2: box.x + box.width, y2: box.y + box.height, stroke: "#111111", "stroke-width": 1}));
+      svg.appendChild(make("line", {x1: box.x, y1: box.y, x2: box.x, y2: box.y + box.height, stroke: "#111111", "stroke-width": 1}));
+      plot.x.ticks.forEach(t => {
+        const x = sx(t.value);
+        svg.appendChild(make("line", {x1: x, y1: box.y + box.height, x2: x, y2: box.y + box.height + 6, stroke: "#111111"}));
+        addText(svg, t.label, {x, y: box.y + box.height + 22, "font-size": 16, "text-anchor": "middle", "font-family": spec.typography.fontFamily});
+      });
+      plot.y.ticks.forEach(t => {
+        const y = sy(t.value);
+        svg.appendChild(make("line", {x1: box.x - 5, y1: y, x2: box.x, y2: y, stroke: "#111111"}));
+        addText(svg, t.label, {x: box.x - 8, y: y + 5, "font-size": 15, "text-anchor": "end", "font-family": spec.typography.fontFamily});
+      });
+      addText(svg, plot.x.label.text, {x: box.x + box.width / 2, y: box.y + box.height + plot.x.label.offset, "font-size": plot.x.label.fontSize, "text-anchor": "middle", "font-family": spec.typography.fontFamily});
