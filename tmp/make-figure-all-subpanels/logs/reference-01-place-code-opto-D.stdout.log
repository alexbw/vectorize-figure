+      svg.appendChild(make("line", {x1: box.x, y1: box.y, x2: box.x, y2: box.y + box.height, stroke: "#111111", "stroke-width": 1}));
+      plot.x.ticks.forEach(t => {
+        const x = sx(t.value);
