+        svg.appendChild(make("line", {x1: box.x - 5, y1: y, x2: box.x, y2: y, stroke: "#111111"}));
+        addText(svg, t.label, {x: box.x - 8, y: y + 5, "font-size": 15, "text-anchor": "end", "font-family": spec.typography.fontFamily});
+      });
+      addText(svg, plot.x.label.text, {x: box.x + box.width / 2, y: box.y + box.height + plot.x.label.offset, "font-size": plot.x.label.fontSize, "text-anchor": "middle", "font-family": spec.typography.fontFamily});
