+        tspan.textContent = line;
+        node.appendChild(tspan);
+      });
+      if (spec.rotation) node.setAttribute('transform', `rotate(${spec.rotation} ${spec.x} ${spec.y})`);
+      svg.appendChild(node);
+      return node;
+    }
+    function renderHeatmap(canvas, spec, panel, scaleDef) {
+      const plot = panel.layoutObjects.find(o => o.id === 'place-map-plot');
+      const recipe = panel.data.find(d => d.id === 'place-map-data-recipe');
+      const box = plot.bbox;
+      const rand = rng(recipe.seed);
+      const ctx = canvas.getContext('2d');
+      const image = ctx.createImageData(box.width, box.height);
+      const rowGain = Array.from({length: recipe.rows}, () => 0.8 + rand() * 0.42);
+      for (let py = 0; py < box.height; py++) {
+        const row = py / box.height * (recipe.rows - 1);
+        const drift = recipe.features.dominantBand.startPosition + row / (recipe.rows - 1) * (recipe.features.dominantBand.endPosition - recipe.features.dominantBand.startPosition);
+        const wiggle = Math.sin(row * 0.12) * 4 + Math.sin(row * 0.027) * 8;
+        for (let px = 0; px < box.width; px++) {
+          const pos = px / box.width * recipe.columns;
+          const band = Math.exp(-Math.pow(pos - drift - wiggle, 2) / (2 * Math.pow(recipe.features.dominantBand.widthCm, 2))) * recipe.features.dominantBand.amplitude;
+          const secondary = row > 35 && row < 155 ? Math.exp(-Math.pow(pos - 55 - Math.sin(row * 0.08) * 7, 2) / 120) * recipe.features.secondaryBand.amplitude : 0;
+          const sparse = rand() < 0.015 ? rand() * 1.1 : 0;
+          const streak = (Math.sin(px * 0.65 + row * 0.08) > 0.82 ? 0.1 : 0) + (rand() - 0.5) * recipe.features.noiseAmplitude;
+          const dropout = rand() < recipe.features.rowDropout * 0.012 ? -1.2 : 0;
+          const value = clamp((band + secondary + sparse + streak + dropout) * rowGain[Math.floor(row)], 0, 2);
+          const [r, g, b] = colorAt(scaleDef, value);
+          const i = (py * box.width + px) * 4;
+          image.data[i] = r;
+          image.data[i + 1] = g;
+          image.data[i + 2] = b;
+          image.data[i + 3] = 255;
+        }
+      }
+      ctx.putImageData(image, box.x, box.y);
+    }
+    function renderAxes(svg, panel) {
+      const plot = panel.layoutObjects.find(o => o.id === 'place-map-plot');
+      const box = plot.bbox;
+      svg.appendChild(svgNode('line', {x1: box.x, y1: box.y + box.height, x2: box.x + box.width, y2: box.y + box.height, stroke: '#111111', 'stroke-width': 1}));
+      plot.axes.x.ticks.forEach(t => {
+        const x = map(plot.axes.x.domain, [box.x, box.x + box.width], t.value);
+        svg.appendChild(svgNode('line', {x1: x, y1: box.y + box.height, x2: x, y2: box.y + box.height + 5, stroke: '#111111', 'stroke-width': 1}));
+        text(svg, {text: t.label, x, y: box.y + box.height + 21, fontSize: 14, anchor: 'middle'});
+      });
+      text(svg, {text: plot.axes.x.label.text, x: box.x + box.width / 2, y: box.y + box.height + plot.axes.x.label.offset, fontSize: plot.axes.x.label.fontSize, anchor: 'middle'});
+      text(svg, plot.axes.y.label);
+      const bracket = panel.layoutObjects.find(o => o.id === 'dorsal-ventral-bracket');
+      svg.appendChild(svgNode('line', {x1: bracket.x, y1: bracket.y1, x2: bracket.x, y2: bracket.y2, stroke: '#111111', 'stroke-width': 1}));
+      svg.appendChild(svgNode('path', {d: `M${bracket.x - 4},${bracket.y1 + 8} L${bracket.x},${bracket.y1} L${bracket.x + 4},${bracket.y1 + 8}`, fill: 'none', stroke: '#111111', 'stroke-width': 1}));
+      svg.appendChild(svgNode('path', {d: `M${bracket.x - 4},${bracket.y2 - 8} L${bracket.x},${bracket.y2} L${bracket.x + 4},${bracket.y2 - 8}`, fill: 'none', stroke: '#111111', 'stroke-width': 1}));
+      bracket.labels.forEach(label => text(svg, {...label, fontSize: 14}));
+    }
+    function renderColorbar(svg, panel, scaleDef) {
+      const bar = panel.layoutObjects.find(o => o.id === 'activity-colorbar');
+      const gradient = svgNode('linearGradient', {id: 'activity-gradient', x1: '0', y1: '1', x2: '0', y2: '0'});
+      scaleDef.stops.forEach(s => gradient.appendChild(svgNode('stop', {offset: `${s.value / 2 * 100}%`, 'stop-color': s.color})));
+      const defs = svgNode('defs');
+      defs.appendChild(gradient);
+      svg.appendChild(defs);
+      svg.appendChild(svgNode('rect', {x: bar.bbox.x, y: bar.bbox.y, width: bar.bbox.width, height: bar.bbox.height, fill: 'url(#activity-gradient)', stroke: '#888888', 'stroke-width': 0.5}));
+      text(svg, bar.title);
+      bar.ticks.forEach(t => {
+        const y = map([0, 2], [bar.bbox.y + bar.bbox.height, bar.bbox.y], t.value);
+        svg.appendChild(svgNode('line', {x1: bar.bbox.x + bar.bbox.width, y1: y, x2: bar.bbox.x + bar.bbox.width + 5, y2: y, stroke: '#111111', 'stroke-width': 1}));
+        text(svg, {text: t.label, x: bar.bbox.x - 5, y: y + 4, fontSize: 11, anchor: 'end'});
+      });
+    }
+    function renderOccupancy(svg, panel) {
+      const occ = panel.layoutObjects.find(o => o.id === 'occupancy-panel');
+      const recipe = panel.data.find(d => d.id === 'occupancy-trace-data-recipe');
+      const rand = rng(recipe.seed);
+      const box = occ.bbox;
+      text(svg, occ.title);
+      svg.appendChild(svgNode('line', {x1: box.x, y1: box.y, x2: box.x, y2: box.y + box.height, stroke: '#111111', 'stroke-width': 1}));
+      svg.appendChild(svgNode('line', {x1: box.x, y1: box.y + box.height, x2: box.x + box.width, y2: box.y + box.height, stroke: '#111111', 'stroke-width': 1}));
+      occ.axes.x.ticks.forEach(t => {
+        const x = map(occ.axes.x.domain, [box.x, box.x + box.width], t.value);
+        svg.appendChild(svgNode('line', {x1: x, y1: box.y + box.height, x2: x, y2: box.y + box.height + 5, stroke: '#111111', 'stroke-width': 1}));
+        text(svg, {text: t.label, x, y: box.y + box.height + 20, fontSize: 14, anchor: 'middle'});
+      });
+      const points = [];
+      for (let i = 0; i < recipe.samples; i++) {
+        const row = 1 + i / (recipe.samples - 1) * 311;
+        let value = recipe.features.baseline + Math.sin(row * 0.09) * 8 + Math.sin(row * 0.22) * 4 + (rand() - 0.5) * recipe.features.noise;
+        recipe.features.peaks.forEach(p => value += Math.exp(-Math.pow(row - p.row, 2) / 260) * p.height);
+        value = clamp(value, 1, 68);
+        points.push([map([0, 70], [box.x, box.x + box.width], value), map([1, 312], [box.y, box.y + box.height], row)]);
+      }
+      const d = points.map((p, i) => `${i ? 'L' : 'M'}${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(' ');
+      svg.appendChild(svgNode('path', {d, fill: 'none', stroke: '#111111', 'stroke-width': 1, 'data-mark-id': 'occupancy-trace'}));
+    }
+    async function loadSpec() {
+      const response = await fetch(JSON_PATH);
+      return response.json();
+    }
+    async function render() {
+      const spec = await loadSpec();
+      const frame = $('frame');
+      const surface = $('surface');
+      const reference = $('reference');
+      const panel = spec.panels[0];
+      const colorScale = spec.colorScales.find(s => s.id === 'activity-rate');
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      reference.src = spec.source.path;
+      surface.innerHTML = '';
+      const canvas = document.createElement('canvas');
+      canvas.width = spec.canvas.width;
+      canvas.height = spec.canvas.height;
+      canvas.dataset.layer = 'generated-heatmap';
+      const svg = svgNode('svg', {viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`, width: spec.canvas.width, height: spec.canvas.height, role: 'img'});
+      svg.style.fontFamily = spec.typography.fontFamily;
+      surface.appendChild(canvas);
+      surface.appendChild(svg);
+      canvas.getContext('2d').fillStyle = spec.canvas.background;
+      canvas.getContext('2d').fillRect(0, 0, spec.canvas.width, spec.canvas.height);
+      renderHeatmap(canvas, spec, panel, colorScale);
+      text(svg, panel.label);
+      text(svg, panel.title);
+      renderAxes(svg, panel);
+      renderColorbar(svg, panel, colorScale);
+      renderOccupancy(svg, panel);
+    }
+    $('generatedButton').addEventListener('click', () => {
+      $('frame').classList.remove('show-reference');
+      $('generatedButton').classList.add('active');
+      $('referenceButton').classList.remove('active');
+    });
+    $('referenceButton').addEventListener('click', () => {
+      $('frame').classList.add('show-reference');
+      $('referenceButton').classList.add('active');
+      $('generatedButton').classList.remove('active');
+    });
+    render().catch(error => {
+      console.error(error);
+      $('surface').textContent = 'Failed to load reconstruction JSON.';
+    });
+  </script>
+</body>
+</html>
