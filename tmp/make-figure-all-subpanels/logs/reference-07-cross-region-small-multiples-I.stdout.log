+      font-family: Arial Narrow, Arial, Helvetica, sans-serif;
+      letter-spacing: 0;
+    }
+  </style>
+</head>
+<body>
+  <div class="toolbar">
+    <label><input id="toggle-reference" type="checkbox"> Show QA reference</label>
+  </div>
+  <div class="stage">
+    <section class="figure-shell" aria-label="Generated reconstruction">
+      <div class="figure-label">Generated editable reconstruction</div>
+      <div id="candidate" class="candidate-wrap">
+        <canvas id="residual-canvas" width="991" height="319"></canvas>
+        <svg id="overlay-svg" role="img" aria-labelledby="candidate-title"></svg>
+      </div>
+    </section>
+    <section id="qa-panel" class="figure-shell" aria-label="QA reference image" hidden>
+      <div class="figure-label">QA reference image (source raster, not part of generated candidate)</div>
+      <img id="qa-reference" alt="QA reference source raster">
+    </section>
+  </div>
+
+  <script>
+    const specUrl = "reference-07-cross-region-small-multiples-I.json";
+    const svgNS = "http://www.w3.org/2000/svg";
+
+    function svgEl(name, attrs = {}, parent) {
+      const node = document.createElementNS(svgNS, name);
+      Object.entries(attrs).forEach(([key, value]) => node.setAttribute(key, value));
+      if (parent) parent.appendChild(node);
+      return node;
+    }
+
+    function textNode(parent, text, attrs = {}) {
+      const node = svgEl("text", attrs, parent);
+      node.textContent = text;
+      return node;
+    }
+
+    function mulberry32(seed) {
+      let t = seed >>> 0;
+      return function next() {
+        t += 0x6D2B79F5;
+        let x = Math.imul(t ^ (t >>> 15), 1 | t);
+        x ^= x + Math.imul(x ^ (x >>> 7), 61 | x);
+        return ((x ^ (x >>> 14)) >>> 0) / 4294967296;
+      };
+    }
+
+    function clamp(value, min, max) {
+      return Math.max(min, Math.min(max, value));
+    }
+
+    function residualRgb(value) {
+      const v = clamp(value, -1, 1);
+      const white = [255, 255, 255];
+      const blue = [21, 71, 255];
+      const red = [255, 74, 36];
+      const end = v < 0 ? blue : red;
+      const t = Math.pow(Math.abs(v), 0.72);
+      return white.map((channel, index) => Math.round(channel + (end[index] - channel) * t));
+    }
+
+    function drawResidualPanel(ctx, panel) {
+      const {plotBbox: box, recipe} = panel;
+      const width = Math.round(box.width);
+      const height = Math.round(box.height);
+      const image = ctx.createImageData(width, height);
+      const rand = mulberry32(recipe.seed);
+      const rowOffsets = Array.from({length: panel.rowCount}, () => (rand() - 0.5) * 0.75);
+      const rowBands = Array.from({length: panel.rowCount}, () => 0.65 + rand() * 1.1);
+
+      for (let y = 0; y < height; y += 1) {
+        const row = Math.floor(y / height * panel.rowCount);
+        const rowPhase = rowOffsets[row] || 0;
+        const band = rowBands[row] || 1;
+        for (let x = 0; x < width; x += 1) {
+          const xp = x / Math.max(1, width - 1);
+          const yp = y / Math.max(1, height - 1);
+          const center = Math.exp(-Math.pow((xp - 0.53) / 0.22, 2)) * recipe.centerPeak;
+          const stripe = Math.sin((yp * recipe.verticalFrequency + xp * 2.2 + rowPhase) * Math.PI * 2) * 0.20 * band;
+          const broad = Math.sin((xp * 3.1 + rowPhase) * Math.PI * 2) * 0.13;
+          const sparse = rand() < recipe.speckleDensity ? (rand() - 0.5) * 1.7 : 0;
+          const grain = (rand() - 0.5) * recipe.noise;
+          let value = recipe.dominantSign + center + stripe + broad + sparse + grain;
+          if (rand() < 0.09) value *= 0.18;
+          const [r, g, b] = residualRgb(value);
+          const index = (y * width + x) * 4;
+          image.data[index] = r;
+          image.data[index + 1] = g;
+          image.data[index + 2] = b;
+          image.data[index + 3] = value === 0 ? 0 : 230;
+        }
+      }
+      ctx.putImageData(image, box.x, box.y);
+    }
+
+    function xFor(box, value) {
+      return box.x + (value / 300) * box.width;
+    }
+
+    function renderAxes(svg, spec, smallPanel, index) {
+      const box = smallPanel.plotBbox;
+      const axisGroup = svgEl("g", {"id": `${smallPanel.id}-axes`, "data-region": smallPanel.region}, svg);
+      svgEl("rect", {
+        x: box.x,
+        y: box.y,
+        width: box.width,
+        height: box.height,
+        fill: "none",
+        stroke: "#333",
+        "stroke-width": 1
+      }, axisGroup);
+
+      spec.panels[0].plot.x.ticks.forEach(tick => {
+        const x = xFor(box, tick.value);
+        svgEl("line", {x1: x, x2: x, y1: box.y + box.height, y2: box.y + box.height + 5, stroke: "#111", "stroke-width": 1}, axisGroup);
+        textNode(axisGroup, tick.label, {
+          x,
+          y: box.y + box.height + 19,
+          "font-size": 14,
+          "text-anchor": "middle",
+          fill: "#111"
+        });
+      });
+      textNode(axisGroup, spec.panels[0].plot.x.label.text, {
+        x: box.x + box.width / 2,
+        y: box.y + box.height + 39,
+        "font-size": 14,
+        "text-anchor": "middle",
+        fill: "#111"
+      });
+
+      if (index === 0) {
+        textNode(axisGroup, "1", {
+          x: box.x - 9,
+          y: box.y + 4,
+          "font-size": 14,
+          "text-anchor": "end",
+          fill: "#111"
+        });
+        textNode(axisGroup, "N", {
+          x: box.x - 9,
+          y: box.y + box.height + 4,
+          "font-size": 14,
+          "text-anchor": "end",
+          fill: "#111"
+        });
+        const yLabel = spec.panels[0].plot.y.label;
+        textNode(axisGroup, yLabel.text, {
+          x: yLabel.x,
+          y: yLabel.y,
+          "font-size": yLabel.fontSize,
+          "text-anchor": yLabel.textAnchor,
+          transform: `rotate(${yLabel.rotation} ${yLabel.x} ${yLabel.y})`,
+          fill: "#111"
+        });
+      }
+    }
+
+    function render(spec) {
+      const canvas = document.getElementById("residual-canvas");
+      const ctx = canvas.getContext("2d");
+      canvas.width = spec.canvas.width;
+      canvas.height = spec.canvas.height;
+      ctx.fillStyle = spec.canvas.background;
+      ctx.fillRect(0, 0, spec.canvas.width, spec.canvas.height);
+
+      const svg = document.getElementById("overlay-svg");
+      svg.replaceChildren();
+      svg.setAttribute("viewBox", `0 0 ${spec.canvas.width} ${spec.canvas.height}`);
+      svg.setAttribute("data-generated-from", spec.id);
+      svgEl("title", {id: "candidate-title"}, svg).textContent = "Generated reconstruction of panel I";
+
+      const panel = spec.panels[0];
+      const multiples = panel.layoutObjects.find(item => item.id === "region-small-multiples").panels;
+
+      multiples.forEach(item => drawResidualPanel(ctx, item));
+
+      textNode(svg, panel.label.text, {
+        id: panel.label.id,
+        x: panel.label.x,
+        y: panel.label.y,
+        "font-size": panel.label.fontSize,
+        "font-weight": panel.label.fontWeight,
+        fill: spec.typography.color
+      });
+      textNode(svg, panel.title.text, {
+        id: panel.title.id,
+        x: panel.title.x,
+        y: panel.title.y,
+        "font-size": panel.title.fontSize,
+        "font-weight": panel.title.fontWeight,
+        fill: spec.typography.color
+      });
+
+      const topFragments = panel.layoutObjects.find(item => item.id === "top-clipped-neighbor-axis-fragments");
+      topFragments.texts.forEach(fragment => {
+        textNode(svg, fragment.text, {
+          x: fragment.x,
+          y: fragment.y,
+          "font-size": fragment.fontSize,
+          "text-anchor": fragment.textAnchor || "start",
+          fill: "#111"
+        });
+      });
+
+      multiples.forEach((item, index) => {
+        textNode(svg, item.title.text, {
+          x: item.title.x,
+          y: item.title.y,
+          "font-size": item.title.fontSize,
+          "text-anchor": item.title.textAnchor,
+          fill: item.title.color
+        });
+        renderAxes(svg, spec, item, index);
+      });
+
+      const qaImage = document.getElementById("qa-reference");
+      qaImage.src = spec.source.path;
+      qaImage.width = spec.source.nativeWidth;
+      qaImage.height = spec.source.nativeHeight;
+    }
+
+    document.getElementById("toggle-reference").addEventListener("change", event => {
+      document.getElementById("qa-panel").hidden = !event.target.checked;
+    });
+
+    fetch(specUrl)
+      .then(response => response.json())
+      .then(render)
+      .catch(error => {
+        document.body.insertAdjacentHTML("beforeend", `<pre>${String(error)}</pre>`);
+      });
+  </script>
+</body>
+</html>
