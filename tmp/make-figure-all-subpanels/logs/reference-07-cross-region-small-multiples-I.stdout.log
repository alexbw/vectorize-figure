+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>reference-07-cross-region-small-multiples-I reconstruction</title>
+  <style>
+    :root {
+      color: #111;
+      background: #f5f5f5;
