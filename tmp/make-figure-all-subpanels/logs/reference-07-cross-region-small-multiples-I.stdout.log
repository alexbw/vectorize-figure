+  <script>
+    const specUrl = "reference-07-cross-region-small-multiples-I.json";
+    const svgNS = "http://www.w3.org/2000/svg";
+
+    function svgEl(name, attrs = {}, parent) {
+      const node = document.createElementNS(svgNS, name);
+      Object.entries(attrs).forEach(([key, value]) => node.setAttribute(key, value));
+      if (parent) parent.appendChild(node);
+      return node;
+    }
+
+    function textNode(parent, text, attrs = {}) {
+      const node = svgEl("text", attrs, parent);
+      node.textContent = text;
+      return node;
+    }
+
+    function mulberry32(seed) {
+      let t = seed >>> 0;
+      return function next() {
+        t += 0x6D2B79F5;
+        let x = Math.imul(t ^ (t >>> 15), 1 | t);
+        x ^= x + Math.imul(x ^ (x >>> 7), 61 | x);
+        return ((x ^ (x >>> 14)) >>> 0) / 4294967296;
+      };
+    }
+
+    function clamp(value, min, max) {
+      return Math.max(min, Math.min(max, value));
+    }
+
+    function residualRgb(value) {
+      const v = clamp(value, -1, 1);
+      const white = [255, 255, 255];
+      const blue = [21, 71, 255];
+      const red = [255, 74, 36];
+      const end = v < 0 ? blue : red;
+      const t = Math.pow(Math.abs(v), 0.72);
+      return white.map((channel, index) => Math.round(channel + (end[index] - channel) * t));
+    }
+
+    function drawResidualPanel(ctx, panel) {
+      const {plotBbox: box, recipe} = panel;
+      const width = Math.round(box.width);
+      const height = Math.round(box.height);
+      const image = ctx.createImageData(width, height);
+      const rand = mulberry32(recipe.seed);
+      const rowOffsets = Array.from({length: panel.rowCount}, () => (rand() - 0.5) * 0.75);
+      const rowBands = Array.from({length: panel.rowCount}, () => 0.65 + rand() * 1.1);
+
+      for (let y = 0; y < height; y += 1) {
+        const row = Math.floor(y / height * panel.rowCount);
+        const rowPhase = rowOffsets[row] || 0;
+        const band = rowBands[row] || 1;
+        for (let x = 0; x < width; x += 1) {
+          const xp = x / Math.max(1, width - 1);
+          const yp = y / Math.max(1, height - 1);
+          const center = Math.exp(-Math.pow((xp - 0.53) / 0.22, 2)) * recipe.centerPeak;
+          const stripe = Math.sin((yp * recipe.verticalFrequency + xp * 2.2 + rowPhase) * Math.PI * 2) * 0.20 * band;
+          const broad = Math.sin((xp * 3.1 + rowPhase) * Math.PI * 2) * 0.13;
+          const sparse = rand() < recipe.speckleDensity ? (rand() - 0.5) * 1.7 : 0;
+          const grain = (rand() - 0.5) * recipe.noise;
+          let value = recipe.dominantSign + center + stripe + broad + sparse + grain;
+          if (rand() < 0.09) value *= 0.18;
+          const [r, g, b] = residualRgb(value);
+          const index = (y * width + x) * 4;
+          image.data[index] = r;
+          image.data[index + 1] = g;
+          image.data[index + 2] = b;
+          image.data[index + 3] = value === 0 ? 0 : 230;
+        }
+      }
+      ctx.putImageData(image, box.x, box.y);
+    }
+
+    function xFor(box, value) {
+      return box.x + (value / 300) * box.width;
+    }
+
+    function renderAxes(svg, spec, smallPanel, index) {
+      const box = smallPanel.plotBbox;
