+      width: 991px;
+      background: #fff;
+      border: 1px solid #ddd;
+    }
+    .figure-label {
+      padding: 6px 8px;
+      border-bottom: 1px solid #e5e5e5;
+      font-size: 12px;
+      font-weight: 700;
+    }
+    .candidate-wrap {
+      position: relative;
+      width: 991px;
+      height: 319px;
+      background: #fff;
+    }
