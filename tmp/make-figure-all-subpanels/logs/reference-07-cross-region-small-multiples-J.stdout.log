+        text(svg, {x: 165, y: y + 4, value: region.label, fontSize: 14, fill: region.color, family: typography.fontFamily});
+        const x1 = xFor(region.ciLow);
+        const x2 = xFor(region.ciHigh);
+        const xm = xFor(region.mean);
+        svg.appendChild(make('line', {x1, y1: y, x2, y2: y, stroke: region.color, 'stroke-width': 1}));
+        svg.appendChild(make('line', {x1, y1: y - 2.5, x2: x1, y2: y + 2.5, stroke: region.color, 'stroke-width': 1}));
+        svg.appendChild(make('line', {x1: x2, y1: y - 2.5, x2, y2: y + 2.5, stroke: region.color, 'stroke-width': 1}));
+        svg.appendChild(make('circle', {cx: xm, cy: y, r: 3.4, fill: region.color}));
+        text(svg, {x: 431, y: y + 4, value: region.display, fontSize: 12, family: typography.fontFamily});
+      });
+    }
+
+    $('generatedButton').addEventListener('click', () => {
+      $('frame').classList.remove('show-reference');
+      $('generatedButton').classList.add('active');
+      $('referenceButton').classList.remove('active');
+    });
+    $('referenceButton').addEventListener('click', () => {
+      $('frame').classList.add('show-reference');
+      $('referenceButton').classList.add('active');
+      $('generatedButton').classList.remove('active');
+    });
+
+    fetch(specUrl).then(response => response.json()).then(render).catch(error => {
+      document.body.insertAdjacentHTML('beforeend', `<pre>${String(error)}</pre>`);
+    });
+  </script>
+</body>
+</html>
