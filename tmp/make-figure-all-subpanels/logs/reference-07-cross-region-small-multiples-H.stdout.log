+  <script>
+    const specUrl = "reference-07-cross-region-small-multiples-H.json";
+    const svgNS = "http://www.w3.org/2000/svg";
+
+    function el(name, attrs = {}, parent) {
+      const node = document.createElementNS(svgNS, name);
+      Object.entries(attrs).forEach(([key, value]) => node.setAttribute(key, value));
+      if (parent) parent.appendChild(node);
+      return node;
+    }
+
+    function textNode(parent, text, attrs = {}) {
+      const node = el("text", attrs, parent);
+      node.textContent = text;
+      return node;
+    }
+
+    function colorAt(value, scale) {
+      if (value === null || value === undefined) return scale.missingColor;
+      const t = Math.max(0, Math.min(1, (value - scale.domain[0]) / (scale.domain[1] - scale.domain[0])));
+      const start = [255, 255, 255];
+      const end = [11, 60, 149];
+      const rgb = start.map((s, i) => Math.round(s + (end[i] - s) * t));
+      return `rgb(${rgb[0]}, ${rgb[1]}, ${rgb[2]})`;
+    }
+
+    function fmt(value) {
+      return value === null ? "\u2014" : value.toFixed(2);
+    }
+
+    function render(spec) {
+      const svg = document.getElementById("candidate");
+      svg.replaceChildren();
+      svg.setAttribute("viewBox", `0 0 ${spec.canvas.width} ${spec.canvas.height}`);
+      svg.setAttribute("data-generated-from", spec.id);
+      el("title", {id: "candidate-title"}, svg).textContent = "Generated reconstruction of panel H";
+      el("rect", {x: 0, y: 0, width: spec.canvas.width, height: spec.canvas.height, fill: spec.canvas.background}, svg);
+
+      const panel = spec.panels[0];
