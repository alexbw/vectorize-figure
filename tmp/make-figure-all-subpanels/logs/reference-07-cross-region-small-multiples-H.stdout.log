--- /dev/null
+++ b/outputs/reference-07-cross-region-small-multiples-H-make-figure-batch/reference-07-cross-region-small-multiples-H.html
@@ -0,0 +1,247 @@
+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>reference-07-cross-region-small-multiples-H reconstruction</title>
+  <style>
+    :root {
+      color: #111;
+      background: #f5f5f5;
+      font-family: Arial, Helvetica, sans-serif;
+    }
+    body {
+      margin: 0;
+      padding: 18px;
+    }
+    .toolbar {
+      display: flex;
+      align-items: center;
+      gap: 10px;
+      margin: 0 0 12px;
+      font-size: 13px;
+    }
+    .stage {
+      display: flex;
+      gap: 18px;
+      align-items: flex-start;
+      flex-wrap: wrap;
+    }
+    .figure-shell {
+      background: #fff;
+      border: 1px solid #ddd;
+      width: 398px;
+    }
+    .figure-label {
+      padding: 6px 8px;
+      border-bottom: 1px solid #e5e5e5;
+      font-size: 12px;
+      font-weight: 700;
+    }
+    #candidate, #qa-reference {
+      display: block;
+      width: 398px;
+      height: 330px;
+    }
+    #qa-panel[hidden] {
+      display: none;
+    }
+    text {
+      font-family: Arial, Helvetica, sans-serif;
+      letter-spacing: 0;
+    }
+  </style>
+</head>
+<body>
+  <div class="toolbar">
+    <label><input id="toggle-reference" type="checkbox"> Show QA reference</label>
+  </div>
+  <div class="stage">
+    <section class="figure-shell" aria-label="Generated reconstruction">
+      <div class="figure-label">Generated editable reconstruction</div>
+      <svg id="candidate" role="img" aria-labelledby="candidate-title"></svg>
+    </section>
+    <section id="qa-panel" class="figure-shell" aria-label="QA reference image" hidden>
+      <div class="figure-label">QA reference image (source raster, not part of generated candidate)</div>
+      <img id="qa-reference" alt="QA reference source raster">
+    </section>
+  </div>
+
+  <script>
+    const specUrl = "reference-07-cross-region-small-multiples-H.json";
+    const svgNS = "http://www.w3.org/2000/svg";
+
+    function el(name, attrs = {}, parent) {
+      const node = document.createElementNS(svgNS, name);
+      Object.entries(attrs).forEach(([key, value]) => node.setAttribute(key, value));
+      if (parent) parent.appendChild(node);
+      return node;
+    }
+
+    function textNode(parent, text, attrs = {}) {
+      const node = el("text", attrs, parent);
+      node.textContent = text;
+      return node;
+    }
+
+    function colorAt(value, scale) {
+      if (value === null || value === undefined) return scale.missingColor;
+      const t = Math.max(0, Math.min(1, (value - scale.domain[0]) / (scale.domain[1] - scale.domain[0])));
+      const start = [255, 255, 255];
+      const end = [11, 60, 149];
+      const rgb = start.map((s, i) => Math.round(s + (end[i] - s) * t));
+      return `rgb(${rgb[0]}, ${rgb[1]}, ${rgb[2]})`;
+    }
+
+    function fmt(value) {
+      return value === null ? "\u2014" : value.toFixed(2);
+    }
+
+    function render(spec) {
+      const svg = document.getElementById("candidate");
+      svg.replaceChildren();
+      svg.setAttribute("viewBox", `0 0 ${spec.canvas.width} ${spec.canvas.height}`);
+      svg.setAttribute("data-generated-from", spec.id);
+      el("title", {id: "candidate-title"}, svg).textContent = "Generated reconstruction of panel H";
+      el("rect", {x: 0, y: 0, width: spec.canvas.width, height: spec.canvas.height, fill: spec.canvas.background}, svg);
+
+      const panel = spec.panels[0];
+      const grid = spec.coordinateSystems.find(item => item.id === "heatmap-grid");
+      const scale = spec.coordinateSystems.find(item => item.id === "decoding-color");
+      const data = panel.data;
+
+      textNode(svg, panel.label.text, {
+        id: panel.label.id,
+        x: panel.label.x,
+        y: panel.label.y,
+        "font-size": panel.label.fontSize,
+        "font-weight": panel.label.fontWeight,
+        fill: spec.typography.color
+      });
+      textNode(svg, panel.title.text, {
+        id: panel.title.id,
+        x: panel.title.x,
+        y: panel.title.y,
+        "font-size": panel.title.fontSize,
+        "font-weight": panel.title.fontWeight,
+        fill: spec.typography.color
+      });
+
+      const corner = panel.layoutObjects.find(item => item.id === "train-test-corner");
+      corner.lines.forEach(line => textNode(svg, line.text, {
+        x: line.x,
+        y: line.y,
+        "font-size": line.fontSize,
+        fill: spec.typography.color
+      }));
+
+      const matrix = el("g", {"id": "heatmap-cells", "data-mark-type": "heatmap"}, svg);
+      data.values.forEach((row, r) => {
+        row.forEach((value, c) => {
+          const x = grid.bbox.x + c * grid.cellWidth;
+          const y = grid.bbox.y + r * grid.cellHeight;
+          el("rect", {
+            x,
+            y,
+            width: grid.cellWidth,
+            height: grid.cellHeight,
+            fill: colorAt(value, scale),
+            stroke: "#eef2f8",
+            "stroke-width": 1,
+            "data-row": data.rows[r],
+            "data-column": data.columns[c],
+            "data-value": value === null ? "missing" : value
+          }, matrix);
+          textNode(matrix, fmt(value), {
+            x: x + grid.cellWidth / 2,
+            y: y + grid.cellHeight / 2 + 4,
+            "text-anchor": "middle",
+            "font-size": 10,
+            fill: "#111"
+          });
+        });
+      });
+
+      const frame = panel.layoutObjects.find(item => item.id === "matrix-frame");
+      el("rect", {
+        x: frame.bbox.x,
+        y: frame.bbox.y,
+        width: frame.bbox.width,
+        height: frame.bbox.height,
+        fill: "none",
+        stroke: frame.stroke,
+        "stroke-width": frame.strokeWidth
+      }, svg);
+
+      const regionLabels = panel.annotations.find(item => item.id === "region-labels");
+      data.rows.forEach((region, index) => {
+        textNode(svg, region, {
+          x: regionLabels.rowLabelX,
+          y: grid.bbox.y + index * grid.cellHeight + grid.cellHeight / 2 + regionLabels.rowLabelDy,
+          "font-size": regionLabels.fontSize,
+          "text-anchor": "end",
+          fill: regionLabels.colors[region]
+        });
+      });
+      data.columns.forEach((region, index) => {
+        textNode(svg, region, {
+          x: grid.bbox.x + index * grid.cellWidth + grid.cellWidth / 2,
+          y: regionLabels.columnLabelY,
+          "font-size": regionLabels.fontSize,
+          "text-anchor": "middle",
+          fill: regionLabels.colors[region]
+        });
+      });
+
+      const colorbar = panel.layoutObjects.find(item => item.id === "colorbar");
+      const defs = el("defs", {}, svg);
+      const gradient = el("linearGradient", {id: "decoding-color-gradient", x1: "0%", x2: "100%", y1: "0%", y2: "0%"}, defs);
+      el("stop", {offset: "0%", "stop-color": scale.range[0]}, gradient);
+      el("stop", {offset: "100%", "stop-color": scale.range[1]}, gradient);
+      textNode(svg, colorbar.label.text, {
+        x: colorbar.label.x,
+        y: colorbar.label.y,
+        "font-size": colorbar.label.fontSize,
+        "text-anchor": colorbar.label.textAnchor,
+        fill: spec.typography.color
+      });
+      el("rect", {
+        x: colorbar.bbox.x,
+        y: colorbar.bbox.y,
+        width: colorbar.bbox.width,
+        height: colorbar.bbox.height,
+        fill: "url(#decoding-color-gradient)",
+        stroke: "#111",
+        "stroke-width": 0.8
+      }, svg);
+      colorbar.ticks.forEach(tick => {
+        const x = colorbar.bbox.x + (tick.value - scale.domain[0]) / (scale.domain[1] - scale.domain[0]) * colorbar.bbox.width;
+        el("line", {x1: x, x2: x, y1: colorbar.bbox.y + colorbar.bbox.height, y2: colorbar.bbox.y + colorbar.bbox.height + 5, stroke: "#111", "stroke-width": 0.8}, svg);
+        textNode(svg, tick.label, {
+          x,
+          y: colorbar.bbox.y + colorbar.bbox.height + 19,
+          "font-size": 12,
+          "text-anchor": "middle",
+          fill: spec.typography.color
+        });
+      });
+
+      const qaImage = document.getElementById("qa-reference");
+      qaImage.src = spec.source.path;
+      qaImage.width = spec.source.nativeWidth;
+      qaImage.height = spec.source.nativeHeight;
+    }
+
+    document.getElementById("toggle-reference").addEventListener("change", event => {
+      document.getElementById("qa-panel").hidden = !event.target.checked;
+    });
+
+    fetch(specUrl)
+      .then(response => response.json())
+      .then(render)
+      .catch(error => {
+        document.body.insertAdjacentHTML("beforeend", `<pre>${String(error)}</pre>`);
+      });
+  </script>
+</body>
+</html>
