+        "text-anchor": colorbar.label.textAnchor,
+        fill: spec.typography.color
+      });
+      el("rect", {
+        x: colorbar.bbox.x,
+        y: colorbar.bbox.y,
+        width: colorbar.bbox.width,
+        height: colorbar.bbox.height,
+        fill: "url(#decoding-color-gradient)",
+        stroke: "#111",
+        "stroke-width": 0.8
+      }, svg);
+      colorbar.ticks.forEach(tick => {
+        const x = colorbar.bbox.x + (tick.value - scale.domain[0]) / (scale.domain[1] - scale.domain[0]) * colorbar.bbox.width;
+        el("line", {x1: x, x2: x, y1: colorbar.bbox.y + colorbar.bbox.height, y2: colorbar.bbox.y + colorbar.bbox.height + 5, stroke: "#111", "stroke-width": 0.8}, svg);
+        textNode(svg, tick.label, {
+          x,
+          y: colorbar.bbox.y + colorbar.bbox.height + 19,
+          "font-size": 12,
+          "text-anchor": "middle",
+          fill: spec.typography.color
+        });
+      });
+
+      const qaImage = document.getElementById("qa-reference");
+      qaImage.src = spec.source.path;
+      qaImage.width = spec.source.nativeWidth;
+      qaImage.height = spec.source.nativeHeight;
+    }
+
+    document.getElementById("toggle-reference").addEventListener("change", event => {
+      document.getElementById("qa-panel").hidden = !event.target.checked;
+    });
+
+    fetch(specUrl)
+      .then(response => response.json())
+      .then(render)
+      .catch(error => {
+        document.body.insertAdjacentHTML("beforeend", `<pre>${String(error)}</pre>`);
+      });
+  </script>
+</body>
+</html>
