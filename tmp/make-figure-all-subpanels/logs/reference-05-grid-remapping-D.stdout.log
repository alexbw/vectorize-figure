+      const canvas = document.createElement("canvas");
+      canvas.width = spec.canvas.width;
+      canvas.height = spec.canvas.height;
+      surface.appendChild(canvas);
+      const ctx = canvas.getContext("2d");
+      const svg = make("svg", {width: spec.canvas.width, height: spec.canvas.height, viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`});
+      svg.style.fontFamily = spec.typography.fontFamily;
+      surface.appendChild(svg);
+
+      const panel = spec.panels[0];
+      const plot = panel.plot;
+      addText(svg, panel.label);
+      addText(svg, panel.title);
+
+      svg.appendChild(make("line", {x1: plot.axisBbox.x, y1: plot.axisBbox.y, x2: plot.axisBbox.x, y2: plot.axisBbox.y + plot.axisBbox.height, stroke: "#111111", "stroke-width": 1.4, "data-axis": "y"}));
+      for (const tick of plot.y.ticks) {
+        const y = yScale(plot, tick.value);
+        svg.appendChild(make("line", {x1: plot.axisBbox.x - 6, y1: y, x2: plot.axisBbox.x, y2: y, stroke: "#111111", "stroke-width": 1.2, "data-axis": "y", "data-value": tick.value}));
+        addText(svg, {id: `y-tick-${tick.label}`, text: tick.label, x: plot.axisBbox.x - 14, y: y + 5, fontSize: 18, anchor: "end"});
+      }
+      addText(svg, {...plot.y.label, id: "y-axis-label", fontSize: 20, anchor: "middle"});
+
+      const zero = panel.marks.find((m) => m.id === "zero-line");
+      svg.appendChild(make("line", {x1: zero.x1, y1: yScale(plot, zero.value), x2: zero.x2, y2: yScale(plot, zero.value), stroke: zero.stroke, "stroke-width": zero.strokeWidth, "stroke-dasharray": zero.dasharray, "data-mark-id": zero.id}));
+
+      for (const mark of panel.marks.filter((m) => m.type === "violin")) {
+        const dist = distFor(panel, mark.distribution);
+        svg.appendChild(make("path", {d: violinPath(panel, plot, dist), fill: dist.violin.fill, "fill-opacity": dist.violin.fillOpacity, stroke: dist.violin.stroke, "stroke-width": dist.violin.strokeWidth, "data-mark-id": mark.id, "data-distribution": dist.id}));
+      }
