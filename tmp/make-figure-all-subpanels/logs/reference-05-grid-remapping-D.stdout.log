+        const category = catFor(panel, dist.category);
+        const rand = mulberry32(dist.seed + 99);
+        ctx.fillStyle = mark.fill;
+        ctx.globalAlpha = mark.opacity;
+        for (const value of generateValues(dist)) {
+          const x = category.x + (rand() * 2 - 1) * mark.jitterHalfWidth * Math.pow(rand(), 0.55);
