+        const gy = Math.floor((field.yDomain[1] - p.y) / (field.yDomain[1] - field.yDomain[0]) * (grid.rows - 1));
+        const rx = Math.ceil(grid.kernelX / (plot.dataBbox.width / grid.cols));
+        const ry = Math.ceil(grid.kernelY / (plot.dataBbox.height / grid.rows));
