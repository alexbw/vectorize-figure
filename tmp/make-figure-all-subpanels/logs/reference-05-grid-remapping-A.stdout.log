+      const lines = ann.title.text.split("\n");
+      lines.forEach((line, i) => text(svg, {text: line, x: ann.title.x, y: ann.title.y - 14 + i * 16, fontSize: ann.title.fontSize, anchor: ann.title.anchor}));
