+    function linePath(plot, points) {
+      return points.map((pt, i) => `${i ? "L" : "M"} ${xScale(plot, pt[0]).toFixed(2)} ${yScale(plot, pt[1]).toFixed(2)}`).join(" ");
+    }
+    function interpolateColor(stops, t) {
+      const hexToRgb = (hex) => [1, 3, 5].map((i) => parseInt(hex.slice(i, i + 2), 16));
+      const rgbToHex = (rgb) => "#" + rgb.map((v) => clamp(Math.round(v), 0, 255).toString(16).padStart(2, "0")).join("");
+      const scaled = t * (stops.length - 1);
+      const i = Math.min(stops.length - 2, Math.floor(scaled));
+      const local = scaled - i;
+      const a = hexToRgb(stops[i].color);
+      const b = hexToRgb(stops[i + 1].color);
