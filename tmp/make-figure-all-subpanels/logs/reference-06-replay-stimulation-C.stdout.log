+        svg.appendChild(make('line', {
+          x1: x,
+          y1: box.y + box.height + 20,
+          x2: x,
+          y2: box.y + box.height + 26,
+          stroke: axisStroke,
+          'stroke-width': axisWidth,
+          'data-axis': `${plot.id}-x`,
+          'data-value': tick.value
+        }));
+        appendText(svg, {
+          text: tick.label,
+          x,
+          y: box.y + box.height + 41,
+          fontSize: tickFontSize,
+          anchor: 'middle'
+        }, {fontFamily});
+      }
+
+      if (plot.x.label) appendText(svg, plot.x.label, {fontFamily});
+      if (plot.y.label) appendText(svg, plot.y.label, {fontFamily});
+    }
+
+    function renderLine(svg, mark, system) {
+      const project = pointProjector(system);
