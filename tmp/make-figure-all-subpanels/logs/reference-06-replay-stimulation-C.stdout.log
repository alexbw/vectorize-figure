+          x1: box.x,
+          y1: box.y + box.height + 20,
+          x2: box.x + box.width,
+          y2: box.y + box.height + 20,
+          stroke: axisStroke,
+          'stroke-width': axisWidth,
+          'data-axis': `${plot.id}-x`
+        }));
+      }
+
+      const xDomain = plot.x.domain;
+      for (const tick of plot.x.ticks || []) {
