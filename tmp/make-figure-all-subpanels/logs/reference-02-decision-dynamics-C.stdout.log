  <script>
    const SPEC_URL = './reference-02-decision-dynamics-C.json';

    async function loadSpec() {
      try {
        const response = await fetch(SPEC_URL, {cache: 'no-store'});
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        return await response.json();
      } catch (error) {
        const embedded = document.getElementById('fallback-spec').textContent.trim();
        if (embedded) return JSON.parse(embedded);
        throw error;
      }
    }

    function mulberry32(seed) {
      let a = seed >>> 0;
      return function random() {
        a += 0x6D2B79F5;
        let t = a;
        t = Math.imul(t ^ (t >>> 15), t | 1);
        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
      };
    }

    function xScale(plot, value) {
      const [d0, d1] = [-500, 1600];
      return plot.dataBbox.x + ((value - d0) / (d1 - d0)) * plot.dataBbox.width;
    }

    function colorForZ(z) {
      const clamp = Math.max(-3, Math.min(3, z));
      const lerp = (a, b, t) => Math.round(a + (b - a) * t);
      const blue = [11, 88, 198];
      const white = [247, 247, 247];
      const red = [240, 74, 46];
      const t = clamp < 0 ? (clamp + 3) / 3 : clamp / 3;
      const c0 = clamp < 0 ? blue : white;
      const c1 = clamp < 0 ? white : red;
      return [lerp(c0[0], c1[0], t), lerp(c0[1], c1[1], t), lerp(c0[2], c1[2], t), 255];
    }

    function featureValue(feature, time, row) {
      const dx = (time - feature.xCenter) / feature.xWidth;
      const dy = (row - feature.rowCenter) / feature.rowWidth;
      return feature.amplitude * Math.exp(-0.5 * (dx * dx + dy * dy));
    }

    function synthesizeMatrix(recipe) {
      const random = mulberry32(recipe.seed);
      const matrix = [];
      const rowOffsets = Array.from({length: recipe.rows}, () => (random() - 0.5) * recipe.noise.rowBanding);
      for (let r = 0; r < recipe.rows; r++) {
        const row = [];
        let carry = 0;
        for (let c = 0; c < recipe.columns; c++) {
          const time = -500 + (c / (recipe.columns - 1)) * 2100;
          let z = rowOffsets[r] + 0.16 * Math.sin((r * 0.23) + (c * 0.035));
          for (const feature of recipe.features) z += featureValue(feature, time, r + 1);
          z += (random() - 0.5) * recipe.noise.pixelNoise;
          carry = carry * recipe.noise.horizontalSmoothing + z * (1 - recipe.noise.horizontalSmoothing);
          row.push(Math.max(-3, Math.min(3, carry * 1.45)));
        }
        matrix.push(row);
      }
      return matrix;
    }

    function drawHeatmap(ctx, plot) {
      const {x, y, width, height} = plot.dataBbox;
      const matrix = synthesizeMatrix(plot.heatmap.recipe);
      const rows = matrix.length;
      const cols = matrix[0].length;
      const image = ctx.createImageData(cols, rows);
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const rgba = colorForZ(matrix[r][c]);
          const i = (r * cols + c) * 4;
          image.data[i] = rgba[0];
          image.data[i + 1] = rgba[1];
          image.data[i + 2] = rgba[2];
          image.data[i + 3] = rgba[3];
        }
      }
      const off = document.createElement('canvas');
      off.width = cols;
      off.height = rows;
      off.getContext('2d').putImageData(image, 0, 0);
      ctx.save();
      ctx.imageSmoothingEnabled = true;
      ctx.drawImage(off, x, y, width, height);
      ctx.restore();
    }

    function svgEl(name, attrs = {}) {
      const node = document.createElementNS('http://www.w3.org/2000/svg', name);
      for (const [key, value] of Object.entries(attrs)) node.setAttribute(key, value);
      return node;
    }

    function addText(svg, text, x, y, attrs = {}) {
      const node = svgEl('text', {x, y, ...attrs});
      node.textContent = text;
      svg.appendChild(node);
      return node;
    }

    function addRichTitle(svg, parts, anchor) {
      const text = svgEl('text', {x: anchor.x, y: anchor.y});
      for (const part of parts) {
        const tspan = svgEl('tspan', {
          fill: part.fill || '#111',
          'font-size': part.fontSize || 14,
          'font-weight': part.fontWeight || 400,
          'font-style': part.fontStyle || 'normal'
        });
        tspan.textContent = part.text;
        text.appendChild(tspan);
      }
      svg.appendChild(text);
    }

    function renderAxes(svg, plot, showXLabels) {
      const b = plot.dataBbox;
      svg.appendChild(svgEl('rect', {x: b.x, y: b.y, width: b.width, height: b.height, fill: 'none', stroke: '#111', 'stroke-width': 1}));
      for (const tick of plot.x.ticks) {
        const x = xScale(plot, tick.value);
        svg.appendChild(svgEl('line', {x1: x, y1: b.y + b.height, x2: x, y2: b.y + b.height + 4, stroke: '#111', 'stroke-width': 1}));
        if (showXLabels) addText(svg, tick.label, x, b.y + b.height + 18, {'font-size': 12, 'text-anchor': 'middle'});
      }
      for (const tick of plot.y.ticks) {
        const y = tick.value === 1 ? b.y + 5 : b.y + b.height - 8;
        svg.appendChild(svgEl('line', {x1: b.x - 4, y1: y, x2: b.x, y2: y, stroke: '#111', 'stroke-width': 1}));
        addText(svg, tick.label, b.x - 8, y + 4, {'font-size': 14, 'text-anchor': 'end'});
      }
      for (const eventValue of [0, 1100]) {
        const x = xScale(plot, eventValue);
        svg.appendChild(svgEl('line', {x1: x, y1: b.y, x2: x, y2: b.y + b.height, stroke: '#111', 'stroke-width': 1, 'stroke-dasharray': '5 3'}));
      }
    }

    function renderColorbar(svg, spec) {
      const colorbar = spec.panels[0].layoutObjects.find(o => o.id === 'z-score-colorbar');
      const gradient = svgEl('linearGradient', {id: 'z-score-gradient', x1: '0%', y1: '100%', x2: '0%', y2: '0%'});
      [['0%', '#0b58c6'], ['50%', '#f7f7f7'], ['100%', '#f04a2e']].forEach(([offset, color]) => {
        gradient.appendChild(svgEl('stop', {offset, 'stop-color': color}));
      });
      const defs = svgEl('defs');
      defs.appendChild(gradient);
      svg.appendChild(defs);
      svg.appendChild(svgEl('rect', {x: colorbar.x, y: colorbar.y, width: colorbar.width, height: colorbar.height, fill: 'url(#z-score-gradient)', stroke: '#111'}));
      addText(svg, colorbar.label.text, colorbar.label.x, colorbar.label.y, {'font-size': 12});
      for (const tick of colorbar.ticks) {
        const y = colorbar.y + ((3 - tick.value) / 6) * colorbar.height;
        svg.appendChild(svgEl('line', {x1: colorbar.x + colorbar.width, y1: y, x2: colorbar.x + colorbar.width + 4, y2: y, stroke: '#111'}));
        addText(svg, tick.label, colorbar.x + colorbar.width + 8, y + 4, {'font-size': 16});
      }
    }

    function renderEpochStrip(svg, spec) {
      const strip = spec.panels[0].layoutObjects.find(o => o.id === 'epoch-strip');
      const b = strip.bbox;
      for (const segment of strip.segments) {
        const x0 = b.x + ((segment.x0 + 500) / 2100) * b.width;
        const x1 = b.x + ((segment.x1 + 500) / 2100) * b.width;
        svg.appendChild(svgEl('rect', {x: x0, y: b.y, width: x1 - x0, height: b.height, fill: segment.fill, stroke: segment.stroke}));
        addText(svg, segment.label, (x0 + x1) / 2, b.y + 18, {'font-size': 10, 'text-anchor': 'middle'});
      }
    }

    function render(spec) {
      const ctx = document.getElementById('heatmap-layer').getContext('2d');
      ctx.fillStyle = spec.canvas.background;
      ctx.fillRect(0, 0, spec.canvas.width, spec.canvas.height);
      const panel = spec.panels[0];
      panel.plots.forEach(plot => drawHeatmap(ctx, plot));

      const svg = document.getElementById('svg-layer');
      svg.innerHTML = '';
      addText(svg, panel.label.text, panel.label.x, panel.label.y, {'font-size': panel.label.fontSize, 'font-weight': panel.label.fontWeight});
      addText(svg, panel.title.text, panel.title.x, panel.title.y, {'font-size': panel.title.fontSize, 'font-weight': panel.title.fontWeight});
      panel.plots.forEach((plot, index) => {
        addRichTitle(svg, plot.title, plot.titleAnchor);
        renderAxes(svg, plot, true);
        if (index === 1) {
          const yl = plot.y.label;
          addText(svg, yl.text, yl.x, yl.y, {'font-size': yl.fontSize, 'text-anchor': 'middle', transform: `rotate(${yl.rotation} ${yl.x} ${yl.y})`});
          const xl = plot.x.label;
          addText(svg, xl.text, xl.x, xl.y, {'font-size': xl.fontSize, 'text-anchor': 'middle'});
        }
      });
      renderColorbar(svg, spec);
      renderEpochStrip(svg, spec);
    }

    document.getElementById('qa-toggle').addEventListener('change', event => {
      document.getElementById('qa-reference').classList.toggle('hidden', !event.target.checked);
    });

    loadSpec().then(render).catch(error => {
      document.body.appendChild(document.createTextNode(`Could not load reconstruction spec: ${error.message}`));
    });
  </script>
</body>
</html>

