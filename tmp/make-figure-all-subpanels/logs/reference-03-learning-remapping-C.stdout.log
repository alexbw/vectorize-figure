+          stroke: spec.rendering.styleTokens.gridStroke,
+          'stroke-width': 1,
+          'stroke-dasharray': '2 3',
+          'data-value': value
+        }));
+      }
+      svg.appendChild(grid);
+
+      const rows = make('g', {'data-layer': 'trace-rows'});
+      for (const row of plot.rows) {
+        const group = make('g', {'data-row-id': row.id});
+        group.appendChild(textNode({
+          text: row.label,
+          x: row.labelAnchor.x,
+          y: row.labelAnchor.y,
+          fontSize: 14,
+          anchor: 'start'
+        }, {id: `${row.id}-label`}));
+        group.appendChild(make('line', {x1: row.axis.x, y1: row.axis.yTop, x2: row.axis.x, y2: row.axis.yBottom, stroke: '#111111', 'stroke-width': 1}));
+        for (const tick of row.axis.tickValues) {
+          const y = scale(row.domain, [row.axis.yBottom, row.axis.yTop], tick);
+          group.appendChild(make('line', {x1: row.axis.x - 5, y1: y, x2: row.axis.x, y2: y, stroke: '#111111', 'stroke-width': 1, 'data-tick-value': tick}));
+          group.appendChild(textNode({text: String(tick), x: row.axis.x - 10, y: y + 4, fontSize: 13, anchor: 'end'}, {id: `${row.id}-tick-${tick}`}));
+        }
+        group.appendChild(make('path', {
+          d: tracePath(row, xDomain, xRange),
+          fill: 'none',
+          stroke: row.traceColor,
+          'stroke-width': row.kind === 'speed' ? 1.05 : 1.25,
+          'stroke-linejoin': 'round',
+          'stroke-linecap': 'round',
+          'data-mark-type': 'lineSeries',
+          'data-row-id': row.id
+        }));
+        rows.appendChild(group);
+      }
+      svg.appendChild(rows);
+
+      const xAxis = make('g', {'data-layer': 'day-labels'});
+      for (const tick of plot.x.ticks) {
