+        xAxis.appendChild(textNode({text: tick.label, x, y: 466, fontSize: 14, anchor: 'middle'}, {id: `day-${tick.label.replace(/\s+/g, '-').toLowerCase()}`}));
+      }
+      svg.appendChild(xAxis);
+
+      for (const annotation of panel.annotations) {
+        if (annotation.type === 'text') {
+          svg.appendChild(textNode(annotation));
+        } else if (annotation.type === 'scaleBar') {
+          const g = make('g', {'data-id': annotation.id});
+          g.appendChild(make('line', {x1: annotation.x1, y1: annotation.y, x2: annotation.x2, y2: annotation.y, stroke: '#111111', 'stroke-width': 3}));
+          g.appendChild(textNode({text: annotation.label, x: annotation.labelX, y: annotation.labelY, fontSize: 12, anchor: 'middle'}));
+          svg.appendChild(g);
+        }
+      }
