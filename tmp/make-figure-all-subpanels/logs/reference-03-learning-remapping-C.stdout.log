+  <script>
+    const SVG_NS = 'http://www.w3.org/2000/svg';
+    const JSON_FILE = 'reference-03-learning-remapping-C.json';
+
+    function $(id) {
+      return document.getElementById(id);
+    }
+
+    function make(tag, attrs = {}) {
+      const node = document.createElementNS(SVG_NS, tag);
+      for (const [key, value] of Object.entries(attrs)) {
+        if (value !== undefined && value !== null) node.setAttribute(key, value);
+      }
+      return node;
+    }
+
+    function seededRandom(seed) {
+      return function random() {
+        let t = seed += 0x6D2B79F5;
+        t = Math.imul(t ^ (t >>> 15), t | 1);
+        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
+        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
+      };
+    }
+
+    function scale(domain, range, value) {
+      return range[0] + ((value - domain[0]) / (domain[1] - domain[0])) * (range[1] - range[0]);
+    }
+
+    function textNode(textSpec, extra = {}) {
+      const node = make('text', {
+        x: textSpec.x,
+        y: textSpec.y,
+        'font-size': textSpec.fontSize || extra.fontSize || 14,
+        'font-weight': textSpec.fontWeight || extra.fontWeight || 400,
+        'text-anchor': textSpec.anchor || extra.anchor || 'start',
+        fill: textSpec.fill || extra.fill || '#111111',
+        transform: textSpec.rotation ? `rotate(${textSpec.rotation} ${textSpec.x} ${textSpec.y})` : undefined,
+        'data-id': textSpec.id || extra.id
+      });
+      node.textContent = textSpec.text;
+      return node;
+    }
+
+    function tracePath(row, xDomain, xRange) {
+      const random = seededRandom(row.recipe.seed);
+      const [yMin, yMax] = row.domain;
+      const yRange = [row.axis.yBottom, row.axis.yTop];
+      const samples = row.recipe.samples;
+      const points = [];
+      let smooth = row.baseline || 0;
+      for (let i = 0; i < samples; i += 1) {
+        const t = xDomain[0] + (i / (samples - 1)) * (xDomain[1] - xDomain[0]);
+        const rough = (random() - 0.5) * row.recipe.noise * 2;
+        smooth = smooth * 0.56 + rough * 0.44;
+        let value = (row.baseline || 0) + smooth + Math.sin(t * 6.1 + row.recipe.seed) * (row.recipe.drift || 0);
+        for (const spike of row.recipe.spikes) {
+          const [center, amp, width] = spike;
+          const d = (t - center) / width;
+          value += amp * Math.exp(-0.5 * d * d);
+        }
+        if (row.kind === 'speed') {
+          value = Math.max(0, value + Math.abs(rough) * 2.2);
+        }
+        const x = scale(xDomain, xRange, t);
+        const y = scale([yMin, yMax], yRange, Math.max(yMin, Math.min(yMax, value)));
+        points.push([x, y]);
+      }
+      return points.map((p, i) => `${i ? 'L' : 'M'}${p[0].toFixed(1)},${p[1].toFixed(1)}`).join(' ');
+    }
+
+    function render(spec) {
+      document.title = `${spec.id} reconstruction`;
+      $('title').textContent = spec.id;
+      const frame = $('frame');
