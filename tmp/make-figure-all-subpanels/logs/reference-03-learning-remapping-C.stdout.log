+        'data-id': textSpec.id || extra.id
+      });
+      node.textContent = textSpec.text;
+      return node;
+    }
+
+    function tracePath(row, xDomain, xRange) {
+      const random = seededRandom(row.recipe.seed);
+      const [yMin, yMax] = row.domain;
+      const yRange = [row.axis.yBottom, row.axis.yTop];
+      const samples = row.recipe.samples;
+      const points = [];
+      let smooth = row.baseline || 0;
+      for (let i = 0; i < samples; i += 1) {
+        const t = xDomain[0] + (i / (samples - 1)) * (xDomain[1] - xDomain[0]);
