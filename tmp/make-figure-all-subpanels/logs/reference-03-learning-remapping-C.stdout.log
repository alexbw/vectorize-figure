+        const group = make('g', {'data-row-id': row.id});
+        group.appendChild(textNode({
+          text: row.label,
+          x: row.labelAnchor.x,
+          y: row.labelAnchor.y,
+          fontSize: 14,
+          anchor: 'start'
+        }, {id: `${row.id}-label`}));
