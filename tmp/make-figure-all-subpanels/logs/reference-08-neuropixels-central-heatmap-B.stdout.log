+<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1">
+  <title>reference-08-neuropixels-central-heatmap-B reconstruction</title>
+  <style>
+    :root {
+      color-scheme: light;
+      --ink: #111111;
+      --paper: #ffffff;
+      --chrome: #d8d8d8;
+    }
+    html,
+    body {
+      margin: 0;
+      min-height: 100%;
+      background: #f3f3f3;
+      font-family: Arial, Helvetica, sans-serif;
+      color: var(--ink);
+    }
+    .page {
+      padding: 18px;
+    }
+    .figure-wrap {
+      display: inline-block;
+      border: 1px solid var(--chrome);
+      background: var(--paper);
+    }
+    .stage {
+      position: relative;
+      width: 391px;
+      height: 268px;
+      background: var(--paper);
+      overflow: hidden;
+    }
+    .stage canvas,
+    .stage svg {
+      position: absolute;
+      inset: 0;
+      width: 391px;
+      height: 268px;
+    }
+    .stage canvas {
+      z-index: 1;
+    }
+    .stage svg {
+      z-index: 2;
+      pointer-events: none;
+    }
+    .caption {
+      margin-top: 8px;
+      font-size: 12px;
+      color: #444444;
+    }
+  </style>
+</head>
+<body>
+  <main class="page">
+    <section class="figure-wrap" aria-label="Generated reconstruction">
+      <div id="stage" class="stage"></div>
+    </section>
+    <div class="caption">Generated reconstruction only. Source raster is not used as a visual layer.</div>
+  </main>
+
+  <script>
+    const fallbackSpec = null;
+    const specUrl = 'reference-08-neuropixels-central-heatmap-B.json';
+
+    function mulberry32(seed) {
+      let t = seed >>> 0;
+      return function rand() {
+        t += 0x6D2B79F5;
+        let r = Math.imul(t ^ (t >>> 15), 1 | t);
+        r ^= r + Math.imul(r ^ (r >>> 7), 61 | r);
+        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
+      };
+    }
+
+    function gaussian(rand) {
+      const u = Math.max(rand(), 1e-9);
+      const v = Math.max(rand(), 1e-9);
+      return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
+    }
+
+    function mapX(plot, value) {
+      const box = plot.dataBbox;
+      const [d0, d1] = plot.x.domain;
+      return box.x + ((value - d0) / (d1 - d0)) * box.width;
+    }
+
+    function mapY(plot, value) {
+      const box = plot.dataBbox;
+      const [d0, d1] = plot.y.domain;
+      return box.y + ((value - d0) / (d1 - d0)) * box.height;
+    }
+
+    function inDropout(recipe, t, rand) {
+      for (const window of recipe.dropoutWindows || []) {
+        if (t >= window.timeRange[0] && t <= window.timeRange[1]) {
+          return rand() > window.keepProbability;
+        }
+      }
+      return false;
+    }
+
+    function drawRaster(canvas, panel) {
+      const ctx = canvas.getContext('2d');
+      const plot = panel.plot;
+      const mark = panel.marks.find((item) => item.type === 'raster');
+      const recipe = mark.generationRecipe;
+      const rand = mulberry32(recipe.seed);
+      const style = mark.style;
+
+      ctx.clearRect(0, 0, canvas.width, canvas.height);
+      ctx.fillStyle = style.fill;
+      ctx.globalAlpha = style.alpha;
+
+      const emit = (t, row, w = style.width, h = style.height) => {
+        if (t < plot.x.domain[0] || t > plot.x.domain[1] || row < plot.y.domain[0] || row > plot.y.domain[1]) return;
+        if (inDropout(recipe, t, rand)) return;
+        const x = Math.round(mapX(plot, t));
+        const y = Math.round(mapY(plot, row));
+        ctx.fillRect(x, y, w, h);
+      };
+
+      const bg = recipe.backgroundEvents;
+      for (let i = 0; i < bg.count; i += 1) {
+        const t = bg.timeRange[0] + rand() * (bg.timeRange[1] - bg.timeRange[0]);
+        const row = bg.rowRange[0] + rand() * (bg.rowRange[1] - bg.rowRange[0]);
+        emit(t, row);
+      }
+
+      for (const band of recipe.bands) {
+        for (let i = 0; i < band.count; i += 1) {
+          const t = band.center + gaussian(rand) * band.sigma;
+          const row = band.rowRange[0] + rand() * (band.rowRange[1] - band.rowRange[0]) + gaussian(rand) * band.rowJitter;
+          emit(t, row);
+        }
+      }
+
+      for (const rowBand of recipe.horizontalRowBands) {
+        for (let i = 0; i < rowBand.count; i += 1) {
+          const t = rowBand.timeRange[0] + rand() * (rowBand.timeRange[1] - rowBand.timeRange[0]);
+          const row = rowBand.centerRow + (rand() - 0.5) * rowBand.heightRows;
+          emit(t, row, 1, 1);
+        }
+      }
+
+      ctx.globalAlpha = 1;
+    }
+
+    function svgEl(tag, attrs = {}) {
+      const node = document.createElementNS('http://www.w3.org/2000/svg', tag);
+      for (const [key, value] of Object.entries(attrs)) {
+        node.setAttribute(key, String(value));
+      }
+      return node;
+    }
+
+    function addText(svg, textSpec, className) {
+      const text = svgEl('text', {
+        id: textSpec.id,
+        x: textSpec.x,
+        y: textSpec.y,
+        'font-size': textSpec.fontSize,
+        'font-family': 'Arial, Helvetica, sans-serif',
+        'font-weight': textSpec.fontWeight || 400,
+        fill: '#111111',
+        'text-anchor': textSpec.textAnchor || 'start',
+        class: className
+      });
+      if (textSpec.rotation) {
+        text.setAttribute('transform', `rotate(${textSpec.rotation} ${textSpec.x} ${textSpec.y})`);
+        text.setAttribute('dominant-baseline', 'middle');
+      }
+      text.textContent = textSpec.text;
+      svg.appendChild(text);
+    }
+
+    function drawAxes(svg, panel, spec) {
+      const plot = panel.plot;
+      const tokens = spec.rendering.styleTokens;
+      const axisStyle = {
+        stroke: tokens.axisStroke,
+        'stroke-width': tokens.axisStrokeWidth,
+        'shape-rendering': 'crispEdges'
+      };
+
+      svg.appendChild(svgEl('line', {...axisStyle, id: plot.axes.xAxis.id, ...plot.axes.xAxis.line}));
+      svg.appendChild(svgEl('line', {...axisStyle, id: plot.axes.yAxis.id, ...plot.axes.yAxis.line}));
+
+      for (const tick of plot.x.ticks) {
+        const x = mapX(plot, tick.value);
+        const y = plot.axes.xAxis.line.y1;
+        svg.appendChild(svgEl('line', {
+          ...axisStyle,
+          x1: x,
+          y1: y,
+          x2: x,
+          y2: y + plot.axes.xAxis.tickLength,
+          'data-axis': 'x',
+          'data-value': tick.value
+        }));
+        const label = svgEl('text', {
+          x,
+          y: y + 24,
+          'font-size': tokens.tickFontSize,
+          'font-family': 'Arial, Helvetica, sans-serif',
+          fill: tokens.tickLabelColor,
+          'text-anchor': 'middle',
+          'data-axis': 'x',
+          'data-value': tick.value
+        });
+        label.textContent = tick.label;
+        svg.appendChild(label);
+      }
+
+      for (const tick of plot.y.ticks) {
+        const x = plot.axes.yAxis.line.x1;
+        const y = mapY(plot, tick.value);
+        svg.appendChild(svgEl('line', {
+          ...axisStyle,
+          x1: x - plot.axes.yAxis.tickLength,
+          y1: y,
+          x2: x,
+          y2: y,
+          'data-axis': 'y',
+          'data-value': tick.value
+        }));
+        const label = svgEl('text', {
+          x: x - 11,
+          y: y + 5,
+          'font-size': tokens.tickFontSize,
+          'font-family': 'Arial, Helvetica, sans-serif',
+          fill: tokens.tickLabelColor,
+          'text-anchor': 'end',
+          'data-axis': 'y',
+          'data-value': tick.value
+        });
+        label.textContent = tick.label;
+        svg.appendChild(label);
+      }
+
+      addText(svg, plot.x.label, 'axis-label');
+      addText(svg, plot.y.label, 'axis-label');
+    }
+
+    function render(spec) {
+      const panel = spec.panels[0];
+      const stage = document.getElementById('stage');
+      stage.style.width = `${spec.canvas.width}px`;
+      stage.style.height = `${spec.canvas.height}px`;
+      stage.innerHTML = '';
+
+      const canvas = document.createElement('canvas');
+      canvas.width = spec.canvas.width;
+      canvas.height = spec.canvas.height;
+      canvas.setAttribute('data-layer', 'generated-raster-marks');
+      stage.appendChild(canvas);
+      drawRaster(canvas, panel);
+
+      const svg = svgEl('svg', {
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`,
+        role: 'img',
+        'aria-label': 'Generated spike raster reconstruction'
+      });
+      svg.appendChild(svgEl('rect', {
+        x: 0,
+        y: 0,
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        fill: spec.canvas.background
+      }));
+      drawAxes(svg, panel, spec);
+      addText(svg, panel.label, 'panel-label');
+      addText(svg, panel.title, 'panel-title');
+      for (const annotation of panel.annotations) addText(svg, annotation, 'annotation');
+      stage.appendChild(svg);
+    }
+
+    fetch(specUrl)
+      .then((response) => response.ok ? response.json() : fallbackSpec)
+      .then((spec) => render(spec))
+      .catch((error) => {
+        document.body.insertAdjacentHTML('beforeend', `<pre>${error.message}</pre>`);
+      });
+  </script>
