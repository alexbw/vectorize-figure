+      text(svg, panel.label);
+      text(svg, panel.title);
+      renderHeatmap(ctx, panel.marks.find(m => m.type === 'heatmap'), spec.coordinateSystems.probabilityColor);
+      renderMatrixAxes(svg, panel);
+      renderColorbar(ctx, svg, panel.layoutObjects.find(o => o.id === 'probability-colorbar'), spec.coordinateSystems.probabilityColor);
+      renderLegend(svg, panel.layoutObjects.find(o => o.id === 'layer-legend'));
+      renderRightTrace(svg, panel, trace, spec.coordinateSystems['rightTrace.xy']);
+    }
+    $('generatedButton').addEventListener('click', () => {
+      $('frame').classList.remove('show-reference');
+      $('generatedButton').classList.add('active');
+      $('referenceButton').classList.remove('active');
+    });
+    $('referenceButton').addEventListener('click', () => {
+      $('frame').classList.add('show-reference');
+      $('referenceButton').classList.add('active');
+      $('generatedButton').classList.remove('active');
+    });
+    loadSpec().then(render).catch(error => {
+      document.body.insertAdjacentHTML('beforeend', `<pre style="color:#a00;padding:16px">${String(error)}</pre>`);
+      throw error;
+    });
+  </script>
+</body>
+</html>
