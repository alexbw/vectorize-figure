+      const local = raw - index;
+      return rgbToHex([
+        lerp(colors[index][0], colors[index + 1][0], local),
+        lerp(colors[index][1], colors[index + 1][1], local),
+        lerp(colors[index][2], colors[index + 1][2], local)
+      ]);
+    }
+
+    function renderHeatmap(svg, spec, panel) {
+      const plot = panel.plot;
+      const box = plot.dataBbox;
+      const colorScale = spec.coordinateSystems.find(system => system.id === plot.colorScale);
+      const cellW = box.width / plot.matrix[0].length;
+      const cellH = box.height / plot.matrix.length;
+      const layer = make('g', {'data-layer': 'heatmap', 'data-panel': panel.id});
+      svg.appendChild(layer);
+
+      plot.matrix.forEach((row, rowIndex) => {
+        row.forEach((value, columnIndex) => {
+          const x = box.x + columnIndex * cellW;
+          const y = box.y + rowIndex * cellH;
+          layer.appendChild(make('rect', {
+            x, y, width: cellW, height: cellH,
+            fill: value === null ? '#f5f5f5' : colorAt(colorScale, value),
+            stroke: plot.axes.grid.stroke,
+            'stroke-width': plot.axes.grid.strokeWidth,
+            'data-row-day': rowIndex + 1,
+            'data-column-day': columnIndex + 1,
+            'data-value': value === null ? 'missing' : value.toFixed(2)
+          }));
+          addText(layer, {
+            text: value === null ? plot.missingValue.label : value.toFixed(2),
+            x: x + cellW / 2,
+            y: y + cellH / 2 + (value === null ? 5 : 4),
+            fontSize: value === null ? plot.missingValue.fontSize : plot.cellText.fontSize,
+            fill: value === null ? plot.missingValue.fill : plot.cellText.fill,
+            anchor: 'middle',
+            id: `cell-${rowIndex + 1}-${columnIndex + 1}-label`
+          });
+        });
+      });
+      layer.appendChild(make('rect', {
+        x: box.x, y: box.y, width: box.width, height: box.height,
+        fill: 'none',
+        stroke: plot.axes.box.stroke,
+        'stroke-width': plot.axes.box.strokeWidth,
+        'data-id': 'heatmap-border'
+      }));
+    }
+
+    function renderAxes(svg, panel) {
+      const plot = panel.plot;
+      const box = plot.dataBbox;
+      const cellW = box.width / plot.x.ticks.length;
+      const cellH = box.height / plot.y.ticks.length;
+      const axisLayer = make('g', {'data-layer': 'axes', 'data-panel': panel.id});
+      svg.appendChild(axisLayer);
+
+      plot.x.ticks.forEach((tick, index) => {
+        addText(axisLayer, {
+          text: tick.label,
+          x: box.x + index * cellW + cellW / 2,
+          y: box.y + box.height + 22,
+          fontSize: 16,
+          anchor: 'middle',
+          id: `x-tick-${tick.value}`
+        });
+      });
+      plot.y.ticks.forEach((tick, index) => {
+        addText(axisLayer, {
+          text: tick.label,
+          x: box.x - 14,
+          y: box.y + index * cellH + cellH / 2 + 5,
+          fontSize: 16,
+          anchor: 'end',
+          id: `y-tick-${tick.value}`
+        });
+      });
+      addText(axisLayer, plot.x.label);
+      addText(axisLayer, plot.y.label);
+    }
+
+    function renderColorbar(svg, spec, legend) {
+      const colorScale = spec.coordinateSystems.find(system => system.id === legend.scale);
+      const defs = svg.querySelector('defs') || svg.insertBefore(make('defs'), svg.firstChild);
+      const gradient = make('linearGradient', {id: `${legend.id}-gradient`, x1: '0%', y1: '100%', x2: '0%', y2: '0%'});
+      colorScale.colors.forEach((color, index) => {
+        gradient.appendChild(make('stop', {
+          offset: `${index / (colorScale.colors.length - 1) * 100}%`,
+          'stop-color': color
+        }));
+      });
+      defs.appendChild(gradient);
+
+      const box = legend.bbox;
+      const layer = make('g', {'data-layer': 'colorbar', 'data-id': legend.id});
+      svg.appendChild(layer);
+      addText(layer, legend.title);
+      layer.appendChild(make('rect', {
+        x: box.x, y: box.y, width: box.width, height: box.height,
+        fill: `url(#${legend.id}-gradient)`,
+        stroke: '#777777',
+        'stroke-width': 0.8
+      }));
+      legend.ticks.forEach(tick => {
+        const t = (tick.value - colorScale.domain[0]) / (colorScale.domain[1] - colorScale.domain[0]);
+        const y = box.y + box.height - t * box.height;
+        layer.appendChild(make('line', {
+          x1: box.x + box.width,
+          x2: box.x + box.width + legend.tickLength,
+          y1: y,
+          y2: y,
+          stroke: '#111111',
+          'stroke-width': 0.8
+        }));
+        addText(layer, {
+          text: tick.label,
+          x: box.x + box.width + legend.tickLength + 7,
+          y: y + 4,
+          fontSize: 14,
+          anchor: 'start',
+          id: `${legend.id}-tick-${tick.value}`
+        });
+      });
+    }
+
+    function render(spec) {
+      const svg = document.getElementById('svg-layer');
+      svg.innerHTML = '';
+      svg.setAttribute('viewBox', `0 0 ${spec.canvas.width} ${spec.canvas.height}`);
+      svg.style.background = spec.canvas.background;
+      svg.style.fontFamily = spec.typography.fontFamily;
+
+      const panel = spec.panels[0];
+      svg.appendChild(make('rect', {x: 0, y: 0, width: spec.canvas.width, height: spec.canvas.height, fill: spec.canvas.background}));
+      addText(svg, panel.label);
+      addText(svg, panel.title);
+      renderHeatmap(svg, spec, panel);
+      renderAxes(svg, panel);
+      panel.legends.forEach(legend => renderColorbar(svg, spec, legend));
+    }
+
+    async function loadSpec() {
+      try {
+        const response = await fetch('reference-03-learning-remapping-B.json', {cache: 'no-store'});
+        if (response.ok) return await response.json();
+      } catch (error) {
+        console.warn('Using fallback spec because adjacent JSON could not be loaded.', error);
+      }
+      return JSON.parse(document.getElementById('fallback-spec').textContent);
+    }
+
+    document.getElementById('qa-toggle').addEventListener('change', event => {
+      document.getElementById('qa-reference').classList.toggle('hidden', !event.target.checked);
+    });
+
+    loadSpec().then(render);
+  </script>
+</body>
+</html>
