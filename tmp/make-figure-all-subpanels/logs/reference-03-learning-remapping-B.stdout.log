+  <title>reference-03-learning-remapping-B reconstruction</title>
+  <style>
+    html, body {
+      margin: 0;
+      background: #eeeeee;
+      color: #111111;
+      font-family: Arial, Helvetica, sans-serif;
+    }
+    .stage {
+      display: flex;
+      gap: 16px;
+      align-items: flex-start;
+      padding: 16px;
