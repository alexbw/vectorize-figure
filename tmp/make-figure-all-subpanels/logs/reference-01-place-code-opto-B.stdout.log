+        svgEl("line", {x1: x, y1: xAxis.line.y1, x2: x, y2: xAxis.line.y1 + xAxis.tickLength, stroke: "var(--axis)", "stroke-width": 1}, axisLayer);
+        drawText(textLayer, tick.label, {x, y: xAxis.line.y1 + 23, "font-size": 16, "text-anchor": "middle", fill: spec.typography.color, "data-axis": "x", "data-value": tick.value});
+      }
+      for (const tick of yAxis.ticks) {
