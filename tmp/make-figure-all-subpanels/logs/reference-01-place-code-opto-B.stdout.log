+      svgEl("line", {id: xAxis.id, x1: xAxis.line.x1, y1: xAxis.line.y1, x2: xAxis.line.x2, y2: xAxis.line.y2, stroke: "var(--axis)", "stroke-width": 1.1}, axisLayer);
