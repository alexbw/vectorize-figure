+  <script id="fallback-spec" type="application/json">{"schema":"scientific_figure_reconstruction.v1","id":"reference-06-replay-stimulation-A","source":{"path":"../../assets/reference/reference-06-replay-stimulation-A-reference.png","usage":"QA-only; not used by generated candidate."},"canvas":{"width":378,"height":500,"background":"#ffffff"},"typography":{"fontFamily":"Arial Narrow, Helvetica Neue Condensed, Arial, Helvetica, sans-serif","defaultSize":14,"color":"#111111"},"panels":[]}</script>
+  <script>
+    const SVG_NS = 'http://www.w3.org/2000/svg';
+
+    function el(id) {
+      return document.getElementById(id);
+    }
+
+    function svgNode(tag, attrs = {}) {
+      const node = document.createElementNS(SVG_NS, tag);
+      for (const [key, value] of Object.entries(attrs)) {
+        if (value !== undefined && value !== null) node.setAttribute(key, value);
+      }
+      return node;
+    }
+
+    function rng(seed) {
+      return function random() {
+        let t = seed += 0x6D2B79F5;
+        t = Math.imul(t ^ (t >>> 15), t | 1);
+        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
+        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
+      };
+    }
+
+    function scale(domain, range, value) {
+      return range[0] + (value - domain[0]) / (domain[1] - domain[0]) * (range[1] - range[0]);
+    }
+
+    function transforms(plot) {
+      const box = plot.dataBbox;
+      return {
+        x: value => scale(plot.x.domain, [box.x, box.x + box.width], value),
