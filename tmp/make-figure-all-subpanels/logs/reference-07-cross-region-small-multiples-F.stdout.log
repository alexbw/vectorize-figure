+            'stroke-opacity': 0.82,
+            'shape-rendering': 'crispEdges',
+            'data-object-id': `${group.id}-event-${index}`,
+            'data-group-id': group.id,
+            'data-position-cm': event.x.toFixed(2),
+            'data-row': event.row
+          }));
+        });
+      });
+
+      const bottomY = panel.groups[panel.groups.length - 1].box.y + panel.groups[panel.groups.length - 1].box.height;
+      x.ticks.forEach((tick) => {
+        const tx = xScale(tick.value, xDomain, xRange);
+        svg.appendChild(svgNode('line', {
+          x1: tx,
+          y1: bottomY,
+          x2: tx,
+          y2: bottomY + 6,
+          stroke: '#111111',
+          'stroke-width': 1,
+          'shape-rendering': 'crispEdges',
+          'data-object-id': `x-tick-${tick.value}`
+        }));
+        addText(svg, {
+          text: tick.label,
+          x: tx,
+          y: bottomY + 20,
+          fontSize: 14,
+          anchor: 'middle',
+          id: `x-tick-label-${tick.value}`
+        }, font);
+      });
+    }
+
+    async function loadSpec() {
+      try {
+        const response = await fetch(specFile, {cache: 'no-store'});
+        if (!response.ok) throw new Error(`HTTP ${response.status}`);
+        return response.json();
+      } catch (error) {
+        return JSON.parse($('fallback-spec').textContent);
+      }
+    }
+
+    $('generatedButton').addEventListener('click', () => {
+      $('frame').classList.remove('show-reference');
+      $('generatedButton').classList.add('active');
+      $('referenceButton').classList.remove('active');
+    });
+
+    $('referenceButton').addEventListener('click', () => {
+      $('frame').classList.add('show-reference');
+      $('referenceButton').classList.add('active');
+      $('generatedButton').classList.remove('active');
+    });
+
+    loadSpec().then(render);
+  </script>
