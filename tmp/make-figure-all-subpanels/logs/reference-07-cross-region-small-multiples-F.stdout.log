+        y: 0,
+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        fill: spec.canvas.background
+      }));
+
+      const panel = spec.panels[0];
+      const font = {
+        fontFamily: spec.typography.fontFamily,
+        fontSize: spec.typography.defaultSize,
+        color: spec.typography.color
+      };
+
+      addText(svg, panel.plot.x.label, font);
+      addText(svg, panel.label, font);
+      addText(svg, panel.title, font);
+
+      const x = panel.plot.x;
+      const dataBox = panel.plot.dataBbox;
+      const xDomain = x.domain;
+      const xRange = [dataBox.x, dataBox.x + dataBox.width];
+
+      panel.groups.forEach((group) => {
+        const box = group.box;
+        const labelX = 17;
+        addText(svg, {
+          text: group.label,
+          x: labelX,
+          y: box.y + 14,
+          fontSize: 14,
+          fontWeight: 400,
+          fill: group.color,
+          id: `${group.id}-label`
+        }, font);
+        addText(svg, {
+          text: `(${group.count})`,
+          x: labelX - 1,
+          y: box.y + 32,
+          fontSize: 14,
+          fontWeight: 400,
+          fill: '#111111',
+          id: `${group.id}-count`
+        }, font);
+
+        svg.appendChild(svgNode('line', {
+          x1: box.x,
+          y1: box.y - 1,
+          x2: box.x + box.width,
+          y2: box.y - 1,
+          stroke: '#111111',
+          'stroke-width': 1,
+          'shape-rendering': 'crispEdges',
+          'data-object-id': `${group.id}-top-rule`
+        }));
+        svg.appendChild(svgNode('line', {
