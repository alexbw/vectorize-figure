+        width: spec.canvas.width,
+        height: spec.canvas.height,
+        role: 'img',
+        'aria-label': 'Generated sparse population raster reconstruction'
+      });
+      surface.appendChild(svg);
+
+      svg.appendChild(svgNode('rect', {
