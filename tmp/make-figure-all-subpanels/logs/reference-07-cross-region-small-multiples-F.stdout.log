+  <script>
+    const SVG_NS = 'http://www.w3.org/2000/svg';
+    const specFile = 'reference-07-cross-region-small-multiples-F.json';
+
+    function $(id) {
+      return document.getElementById(id);
+    }
+
+    function svgNode(tag, attrs = {}) {
+      const node = document.createElementNS(SVG_NS, tag);
+      for (const [key, value] of Object.entries(attrs)) {
+        if (value !== undefined && value !== null) node.setAttribute(key, value);
+      }
+      return node;
+    }
+
+    function mulberry32(seed) {
+      return function next() {
+        let t = seed += 0x6D2B79F5;
+        t = Math.imul(t ^ (t >>> 15), t | 1);
+        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
+        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
+      };
+    }
+
+    function randn(random) {
+      const u = Math.max(random(), 1e-7);
+      const v = Math.max(random(), 1e-7);
+      return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
+    }
+
+    function clamp(value, min, max) {
+      return Math.max(min, Math.min(max, value));
+    }
+
+    function xScale(value, domain, range) {
+      const t = (value - domain[0]) / (domain[1] - domain[0]);
+      return range[0] + t * (range[1] - range[0]);
+    }
+
+    function makeRasterEvents(group, xDomain) {
+      const recipe = group.generationRecipe;
+      const random = mulberry32(recipe.seed);
+      const events = [];
+      for (let i = 0; i < recipe.baselineEvents; i += 1) {
+        events.push({
+          x: xDomain[0] + random() * (xDomain[1] - xDomain[0]),
+          row: Math.floor(random() * group.rowCount)
+        });
+      }
+      recipe.clusters.forEach((cluster) => {
+        for (let i = 0; i < cluster.events; i += 1) {
+          events.push({
+            x: clamp(cluster.center + randn(random) * cluster.spread, xDomain[0], xDomain[1]),
+            row: Math.floor(random() * group.rowCount)
+          });
+        }
+      });
+      return events.sort((a, b) => a.x - b.x);
+    }
+
+    function addText(svg, textSpec, defaults = {}) {
+      const text = svgNode('text', {
+        x: textSpec.x,
+        y: textSpec.y,
+        'font-family': textSpec.fontFamily || defaults.fontFamily,
+        'font-size': textSpec.fontSize || defaults.fontSize,
