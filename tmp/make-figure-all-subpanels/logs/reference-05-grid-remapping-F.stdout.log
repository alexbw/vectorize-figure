+        svg.appendChild(svgEl("line", { class: "paired-link", x1: xA, y1: yA, x2: xB, y2: yB, stroke: paired.style.lineStroke, "stroke-width": paired.style.lineWidth, "stroke-opacity": paired.style.lineOpacity, "data-animal": row.id }));
+      });
+      paired.data.forEach(row => {
+        svg.appendChild(svgEl("circle", { class: "environment-a-point", cx: xA, cy: y(row.A), r: paired.markerRadius, fill: paired.style.fillA, stroke: "#5a2209", "stroke-width": 0.5, "data-animal": row.id }));
