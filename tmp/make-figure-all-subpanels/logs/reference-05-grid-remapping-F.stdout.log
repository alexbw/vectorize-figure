+      const left = violin.outline.slice().reverse().map(p => [violin.centerX - p.halfWidth, y(p.y)]);
+      const d = `${pathFromPoints(right)} L ${left.map(p => `${p[0].toFixed(1)} ${p[1].toFixed(1)}`).join(" L ")} Z`;
+      svg.appendChild(svgEl("path", { id: violin.id, d, fill: violin.fill, "fill-opacity": violin.fillOpacity, stroke: violin.stroke, "stroke-width": violin.strokeWidth }));
+      violin.interiorBands.forEach((band, index) => {
+        svg.appendChild(svgEl("rect", { class: "violin-band", x: violin.centerX - band.width / 2, y: y(band.y2), width: band.width, height: y(band.y1) - y(band.y2), fill: band.fill, opacity: band.opacity, "data-band": index }));
+      });
+      svg.appendChild(svgEl("line", { id: "violin-whisker", x1: violin.centerX, y1: y(violin.summary.whiskers[0]), x2: violin.centerX, y2: y(violin.summary.whiskers[1]), stroke: "#111111", "stroke-width": 1.4 }));
+      svg.appendChild(svgEl("line", { id: "violin-q1", x1: violin.centerX - 17, y1: y(violin.summary.quartiles[0]), x2: violin.centerX + 17, y2: y(violin.summary.quartiles[0]), stroke: tokens.quartileStroke, "stroke-width": 1.6 }));
