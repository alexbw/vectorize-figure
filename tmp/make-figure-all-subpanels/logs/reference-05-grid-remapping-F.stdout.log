+      });
+      plot.axes.xAxis.categories.forEach(cat => {
+        const label = svgEl("text", { x: cat.x, y: 441, "font-size": 19, "text-anchor": "middle", fill: cat.color });
+        label.textContent = cat.label;
+        svg.appendChild(label);
+      });
+    }
+    function renderViolinInset(svg, panel, spec) {
+      const tokens = spec.styleTokens;
+      const cs = spec.coordinateSystems.find(d => d.id === "delta.xy");
+      const box = cs.plotBbox;
+      const y = value => yScale(box, cs.y.domain, value);
+      panel.annotations.filter(a => a.type === "text").forEach(a => {
+        if (a.id === "p-value") {
+          const text = svgEl("text", { id: a.id, x: a.x, y: a.y, "font-size": a.fontSize, "font-style": "italic", fill: "#111111" });
+          text.append("p = 2.7 \u00d7 10");
+          const sup = svgEl("tspan", { "baseline-shift": "super", "font-size": 10 });
+          sup.textContent = "-6";
+          text.appendChild(sup);
+          svg.appendChild(text);
+        } else {
+          drawText(svg, a);
+        }
+      });
+      const axis = panel.annotations.find(a => a.id === "delta-axis");
+      svg.appendChild(svgEl("line", { id: axis.id, x1: axis.x, y1: box.y, x2: axis.x, y2: box.y + box.height, stroke: tokens.axisStroke, "stroke-width": 1.5 }));
+      axis.ticks.forEach(tick => {
+        const yy = y(tick.value);
+        svg.appendChild(svgEl("line", { class: "tick delta-y", x1: axis.x, y1: yy, x2: axis.x - 6, y2: yy, stroke: tokens.axisStroke, "stroke-width": 1.2, "data-value": tick.value }));
+        const label = svgEl("text", { x: axis.x - 10, y: yy + 5, "font-size": 18, "text-anchor": "end", fill: "#111111" });
+        label.textContent = tick.label;
+        svg.appendChild(label);
+      });
+      const zeroLine = panel.annotations.find(a => a.id === "delta-zero-line");
+      svg.appendChild(svgEl("line", { id: zeroLine.id, x1: zeroLine.x1, y1: y(zeroLine.value), x2: zeroLine.x2, y2: y(zeroLine.value), stroke: tokens.dashStroke, "stroke-width": 1.4, "stroke-dasharray": zeroLine.dasharray }));
+      const violin = panel.marks.find(mark => mark.id === "delta-violin");
