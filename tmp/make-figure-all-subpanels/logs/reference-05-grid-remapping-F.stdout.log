+      for (const [key, value] of Object.entries(attrs)) {
+        if (value !== undefined && value !== null) node.setAttribute(key, String(value));
+      }
+      return node;
+    }
+    function yScale(box, domain, value) {
+      return box.y + box.height - ((value - domain[0]) / (domain[1] - domain[0])) * box.height;
+    }
+    function multilineText(parent, item) {
+      const text = svgEl("text", {
+        id: item.id,
+        x: item.x,
+        y: item.y,
+        "font-size": item.fontSize,
+        "font-weight": item.fontWeight || 400,
+        "font-style": item.fontStyle || "normal",
+        "text-anchor": item.anchor || "start",
+        fill: item.fill || "#111111"
+      });
+      const lines = item.text.split("\n");
+      lines.forEach((line, index) => {
+        const span = svgEl("tspan", { x: item.x, dy: index === 0 ? 0 : item.fontSize * 1.1 });
+        span.textContent = line;
+        text.appendChild(span);
+      });
+      parent.appendChild(text);
+    }
+    function drawText(parent, item) {
+      if (item.text.includes("\n")) return multilineText(parent, item);
+      const text = svgEl("text", {
+        id: item.id,
+        x: item.x,
+        y: item.y,
+        "font-size": item.fontSize,
+        "font-weight": item.fontWeight || 400,
+        "font-style": item.fontStyle || "normal",
+        "text-anchor": item.anchor || "start",
+        fill: item.fill || "#111111",
+        transform: item.rotation ? `rotate(${item.rotation} ${item.x} ${item.y})` : null
+      });
+      text.textContent = item.text;
+      parent.appendChild(text);
+    }
+    function pathFromPoints(points) {
+      return points.map((p, i) => `${i ? "L" : "M"} ${p[0].toFixed(1)} ${p[1].toFixed(1)}`).join(" ");
+    }
+    function render(spec) {
+      $("title").textContent = spec.id;
+      const frame = $("frame");
+      frame.style.width = `${spec.canvas.width}px`;
+      frame.style.height = `${spec.canvas.height}px`;
+      const reference = $("reference");
+      reference.src = spec.source.path;
+      const surface = $("surface");
+      surface.innerHTML = "";
+      const svg = svgEl("svg", { viewBox: `0 0 ${spec.canvas.width} ${spec.canvas.height}`, width: spec.canvas.width, height: spec.canvas.height, role: "img" });
+      svg.style.fontFamily = spec.typography.fontFamily;
+      surface.appendChild(svg);
+      svg.appendChild(svgEl("rect", { x: 0, y: 0, width: spec.canvas.width, height: spec.canvas.height, fill: spec.canvas.background }));
+      const panel = spec.panels[0];
+      drawText(svg, panel.label);
+      drawText(svg, panel.title);
+      renderPairedPlot(svg, panel, spec);
+      renderViolinInset(svg, panel, spec);
+    }
+    function renderPairedPlot(svg, panel, spec) {
+      const tokens = spec.styleTokens;
+      const plot = panel.plot;
+      const box = plot.bbox;
+      const yDomain = spec.coordinateSystems.find(d => d.id === "paired.xy").y.domain;
+      const y = value => yScale(box, yDomain, value);
+      svg.appendChild(svgEl("line", { id: plot.axes.yAxis.id, x1: box.x, y1: box.y, x2: box.x, y2: box.y + box.height, stroke: tokens.axisStroke, "stroke-width": 1.6 }));
+      plot.axes.yAxis.ticks.forEach(tick => {
+        const yy = y(tick.value);
+        svg.appendChild(svgEl("line", { class: "tick paired-y", x1: box.x, y1: yy, x2: box.x - plot.axes.yAxis.tickLength, y2: yy, stroke: tokens.axisStroke, "stroke-width": 1.3, "data-value": tick.value }));
+        const label = svgEl("text", { x: box.x - 12, y: yy + 5, "font-size": 18, "text-anchor": "end", fill: "#111111" });
+        label.textContent = tick.label;
+        svg.appendChild(label);
+      });
+      drawText(svg, { id: "paired-y-label", ...plot.axes.yAxis.label, fontSize: 18, fontWeight: 400, anchor: "middle" });
+      const zeroY = y(plot.axes.zeroLine.value);
+      svg.appendChild(svgEl("line", { id: plot.axes.zeroLine.id, x1: plot.axes.zeroLine.x1, y1: zeroY, x2: plot.axes.zeroLine.x2, y2: zeroY, stroke: tokens.dashStroke, "stroke-width": 1.5, "stroke-dasharray": plot.axes.zeroLine.dasharray }));
+      const paired = panel.marks.find(mark => mark.id === "paired-remapping-lines");
+      const xA = paired.xPositions.A;
+      const xB = paired.xPositions.B;
